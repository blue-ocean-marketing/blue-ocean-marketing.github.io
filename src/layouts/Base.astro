---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Musterwebsites & Komponenten für Ihr Gewerbe — Blue Ocean Marketing' } = Astro.props;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=optional" rel="stylesheet" />
  <style is:global>
    @import "../styles/global.css";
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: #0d0d14;
      color: #e2e8f0;
      font-family: 'Inter', system-ui, sans-serif;
      margin: 0;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
