  /* Mobile: Glacier Split stacks */
  @media (max-width: 700px) {
    :global(#glacier-split-grid) {
      grid-template-columns: 1fr !important;
    }
    :global(#glacier-split-right) {
      min-height: 260px !important;
      order: -1;
    }
    :global(#neon-fade) {
      align-items: flex-end;
    }
  }

  /* Show times badge on larger screens */
  @media (min-width: 1024px) {
    .es-times { display: block !important; }
