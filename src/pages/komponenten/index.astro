---
import Base from '../../layouts/Base.astro';
---
<Base title="Komponenten-Bibliothek — Blue Ocean Marketing">

<!-- ═══════════════════════════════════════════════════════════
     DEMO BANNER
════════════════════════════════════════════════════════════════ -->
<div style="background: #060610; color: #64748b; text-align: center; padding: 0.6rem 1rem; font-size: 0.75rem; border-bottom: 1px solid rgba(0,150,199,0.2); position: sticky; top: 0; z-index: 100;">
  <a href="/" style="color: #0096c7; text-decoration: none; font-weight: 600;">← Demo-Übersicht</a>
  &nbsp;·&nbsp; Komponenten-Bibliothek — Blue Ocean Marketing
</div>

<!-- ═══════════════════════════════════════════════════════════
     PAGE HEADER
════════════════════════════════════════════════════════════════ -->
<section style="padding: 5rem 2rem 3.5rem; text-align: center; max-width: 760px; margin: 0 auto;">
  <span style="display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #0096c7; background: rgba(0,150,199,0.1); border: 1px solid rgba(0,150,199,0.25); padding: 0.3rem 0.875rem; border-radius: 100px; margin-bottom: 1.5rem;">Bibliothek</span>
  <h1 style="font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 700; color: #f1f5f9; line-height: 1.2; margin: 0 0 1rem;">Komponenten-Bibliothek</h1>
  <p style="color: #64748b; font-size: 1rem; line-height: 1.7; margin: 0;">
    Jeder Baustein einmal richtig gebaut — bereit für jeden Kunden. Farbe, Text und Bilder werden individuell angepasst, die Struktur bleibt.
  </p>
</section>

<!-- ═══════════════════════════════════════════════════════════
     SECTION HEADING: HERO
════════════════════════════════════════════════════════════════ -->
<div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem 1.5rem; display: flex; align-items: baseline; gap: 1.25rem;">
  <h2 style="font-size: 1.1rem; font-weight: 700; color: #e2e8f0; margin: 0;">Hero Sektionen</h2>
  <span style="font-size: 0.8rem; color: #334155;">4 Varianten</span>
  <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.07);"></div>
</div>


<!-- ═══════════════════════════════════════════════════════════
     [Hero] Glacier Split
════════════════════════════════════════════════════════════════ -->
<div style="margin-bottom: 4px;">
  <!-- Meta strip -->
  <div style="background: #0d0d14; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1.25rem 2rem; display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <div>
      <span style="display: inline-block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #52b788; background: rgba(82,183,136,0.1); border: 1px solid rgba(82,183,136,0.25); padding: 0.22rem 0.7rem; border-radius: 100px; margin-bottom: 0.6rem;">[Hero] Glacier Split</span>
      <p style="color: #64748b; font-size: 0.82rem; margin: 0 0 0.625rem; max-width: 500px;">Geteilter Aufbau: Text links, Bild rechts. Klar, vertrauenswürdig — ideal wenn der erste Eindruck Seriosität signalisieren soll.</p>
      <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
        {['Zahnarzt', 'Physiotherapie', 'Beratung', 'Versicherung', 'Allgemeinmedizin'].map((t) => (
          <span style="background: rgba(255,255,255,0.04); color: #475569; font-size: 0.7rem; padding: 0.18rem 0.55rem; border-radius: 5px;">{t}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- [Hero] Glacier Split — PREVIEW -->
  <div style="overflow: hidden;">
    <section id="glacier-split-grid" style="display: grid; grid-template-columns: 1fr 1fr; min-height: 82vh; font-family: 'Inter', system-ui, sans-serif;">

      <!-- LEFT: content -->
      <div style="background: #ffffff; padding: clamp(2.5rem, 6vw, 5rem); display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden;">
        <!-- Subtle top-left accent -->
        <div style="position: absolute; top: -60px; left: -60px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(0,150,199,0.07) 0%, transparent 70%); pointer-events: none;"></div>

        <span data-gs="badge" style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; color: #0096c7; background: rgba(0,150,199,0.08); border: 1px solid rgba(0,150,199,0.2); padding: 0.3rem 0.875rem; border-radius: 100px; margin-bottom: 1.75rem; width: fit-content;">
          <span style="width: 6px; height: 6px; background: #0096c7; border-radius: 50%; flex-shrink: 0;"></span>
          Zahnarztpraxis Müller · Pforzheim
        </span>

        <h1 data-gs="title" style="font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 700; line-height: 1.15; color: #0f172a; margin: 0 0 1.25rem;">
          Ihr Lächeln.<br>
          <span style="color: #0096c7;">Unsere Leidenschaft.</span>
        </h1>

        <p data-gs="desc" style="font-size: clamp(0.9rem, 1.3vw, 1rem); color: #475569; line-height: 1.75; margin: 0 0 2rem; max-width: 400px;">
          Moderne Zahnmedizin in entspannter Atmosphäre. Wir nehmen uns Zeit für Sie — vom ersten Gespräch bis zum strahlenden Ergebnis.
        </p>

        <div data-gs="ctas" style="display: flex; gap: 0.875rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
          <a href="#" style="background: #0096c7; color: white; padding: 0.875rem 1.75rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600; text-decoration: none; min-height: 44px; display: inline-flex; align-items: center; box-shadow: 0 4px 16px rgba(0,150,199,0.3);">
            Termin online buchen
          </a>
          <a href="#" style="background: transparent; color: #334155; padding: 0.875rem 1.75rem; border-radius: 10px; font-size: 0.9rem; font-weight: 600; text-decoration: none; min-height: 44px; display: inline-flex; align-items: center; border: 1.5px solid #e2e8f0;">
            Leistungen ansehen
          </a>
        </div>

        <!-- Trust row -->
        <div data-gs="trust" style="display: flex; align-items: center; gap: 1.25rem; padding-top: 1.75rem; border-top: 1px solid #f1f5f9; flex-wrap: wrap;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style="display: flex; gap: 1px;">
              {'★★★★★'.split('').map(() => (
                <span style="color: #f59e0b; font-size: 0.9rem;">★</span>
              ))}
            </div>
            <span style="font-size: 0.8rem; color: #64748b; font-weight: 500;">4.9 Google</span>
          </div>
          <div style="width: 1px; height: 20px; background: #e2e8f0;"></div>
          <span style="font-size: 0.8rem; color: #64748b;">500+ Patienten</span>
          <div style="width: 1px; height: 20px; background: #e2e8f0;"></div>
          <span style="font-size: 0.8rem; color: #64748b;">Seit 2008</span>
        </div>
      </div>

      <!-- RIGHT: image placeholder -->
      <div id="glacier-split-right" style="position: relative; overflow: hidden; min-height: 380px;">
        <!-- Atmospheric gradient background -->
        <div style="position: absolute; inset: 0; background: linear-gradient(140deg, #b8dcea 0%, #6fb8d0 30%, #2e90b0 60%, #1a7090 100%);"></div>
        <!-- Depth layers -->
        <div style="position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 35% 40%, rgba(255,255,255,0.25) 0%, transparent 55%);"></div>
        <!-- Subtle grid overlay -->
        <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 50px 50px;"></div>
        <!-- Decorative circles -->
        <div style="position: absolute; top: 15%; right: 12%; width: 180px; height: 180px; border: 1.5px solid rgba(255,255,255,0.15); border-radius: 50%;"></div>
        <div style="position: absolute; top: 22%; right: 19%; width: 120px; height: 120px; border: 1px solid rgba(255,255,255,0.1); border-radius: 50%;"></div>
        <!-- Floating badge -->
        <div data-gs="image" style="position: absolute; bottom: 2.5rem; left: 2rem; background: rgba(255,255,255,0.95); border-radius: 14px; padding: 1rem 1.25rem; box-shadow: 0 8px 32px rgba(0,0,0,0.15); max-width: 200px;">
          <div style="font-size: 0.72rem; color: #64748b; margin-bottom: 0.3rem; font-weight: 500;">Nächster freier Termin</div>
          <div style="font-size: 0.95rem; font-weight: 700; color: #0f172a;">Mo, 12. Mai · 10:30</div>
          <div style="margin-top: 0.625rem; background: #0096c7; color: white; text-align: center; padding: 0.4rem; border-radius: 7px; font-size: 0.78rem; font-weight: 600;">Jetzt buchen</div>
        </div>
        <!-- Decorative bottom-right -->
        <div style="position: absolute; bottom: -30px; right: -30px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);"></div>
      </div>
    </section>

    <!-- Mobile stacked version (shown only on small screens) -->
    <style>
      @media (max-width: 680px) {
        .gs-grid { grid-template-columns: 1fr !important; }
        .gs-right { min-height: 260px !important; }
      }
    </style>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════════════
     [Hero] Neon Fade
════════════════════════════════════════════════════════════════ -->
<div style="margin-bottom: 4px;">
  <!-- Meta strip -->
  <div style="background: #0d0d14; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1.25rem 2rem; display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <div>
      <span style="display: inline-block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #00b4d8; background: rgba(0,180,216,0.1); border: 1px solid rgba(0,180,216,0.25); padding: 0.22rem 0.7rem; border-radius: 100px; margin-bottom: 0.6rem;">[Hero] Neon Fade</span>
      <p style="color: #64748b; font-size: 0.82rem; margin: 0 0 0.625rem; max-width: 500px;">Cineastischer Vollbild-Hero. Atmosphärischer Hintergrund, große Headline mit Motion-Fade beim Laden. Für Premium-Brands die sofort Eindruck machen wollen.</p>
      <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
        {['Kosmetikstudio', 'Immobilien', 'Restaurant', 'Premium-Hotel', 'Fotograf'].map((t) => (
          <span style="background: rgba(255,255,255,0.04); color: #475569; font-size: 0.7rem; padding: 0.18rem 0.55rem; border-radius: 5px;">{t}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- [Hero] Neon Fade — PREVIEW -->
  <section id="neon-fade" style="position: relative; min-height: 82vh; overflow: hidden; display: flex; align-items: flex-end; font-family: 'Inter', system-ui, sans-serif;">

    <!-- Atmospheric background -->
    <div style="position: absolute; inset: 0; background:
      radial-gradient(ellipse 65% 75% at 68% 28%, rgba(0,110,170,0.32) 0%, transparent 58%),
      radial-gradient(ellipse 45% 45% at 18% 72%, rgba(0,60,100,0.2) 0%, transparent 55%),
      radial-gradient(ellipse 30% 30% at 85% 75%, rgba(0,80,130,0.15) 0%, transparent 50%),
      linear-gradient(145deg, #04060e 0%, #070d1c 45%, #050810 100%);
    "></div>

    <!-- Subtle grid texture -->
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px); background-size: 65px 65px; pointer-events: none;"></div>

    <!-- Animated ambient orb -->
    <div id="nf-orb" style="position: absolute; width: 65vw; height: 65vw; max-width: 680px; max-height: 680px; background: radial-gradient(circle, rgba(0,150,199,0.14) 0%, transparent 68%); border-radius: 50%; top: -18%; right: -8%; pointer-events: none; animation: nfOrb 11s ease-in-out infinite alternate;"></div>

    <!-- Gradient overlays for readability -->
    <div style="position: absolute; inset: 0; background:
      linear-gradient(to right, rgba(4,6,14,0.82) 0%, rgba(4,6,14,0.35) 55%, rgba(4,6,14,0.05) 100%),
      linear-gradient(to top, rgba(4,6,14,0.95) 0%, rgba(4,6,14,0.45) 35%, rgba(4,6,14,0.05) 65%);
      pointer-events: none;
    "></div>

    <!-- Content -->
    <div style="position: relative; z-index: 2; padding: clamp(2.5rem, 5vw, 4.5rem) clamp(1.5rem, 6vw, 5rem); max-width: 700px; padding-bottom: clamp(3.5rem, 6vw, 5rem);">

      <div data-nf="badge" style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.2); padding: 0.3rem 0.875rem; border-radius: 100px; margin-bottom: 1.75rem; backdrop-filter: blur(8px); background: rgba(255,255,255,0.05);">
        <span style="width: 6px; height: 6px; background: #00d4ff; border-radius: 50%; box-shadow: 0 0 8px #00d4ff; flex-shrink: 0;"></span>
        Studio Lumière · Kosmetik &amp; Ästhetik
      </div>

      <h1 data-nf="title" style="font-size: clamp(2.8rem, 6.5vw, 5.5rem); font-weight: 700; line-height: 1.05; color: #ffffff; margin: 0 0 1.5rem; letter-spacing: -0.025em;">
        Schönheit,<br>
        <span style="background: linear-gradient(90deg, #00b4d8, #7dd3fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">die bleibt.</span>
      </h1>

      <p data-nf="desc" style="font-size: clamp(0.9rem, 1.4vw, 1.05rem); color: rgba(255,255,255,0.55); line-height: 1.78; margin: 0 0 2.25rem; max-width: 440px; font-weight: 300;">
        Hochwertige Behandlungen in einem Raum, der selbst Entspannung verkörpert. Für Menschen, die das Beste für sich wählen.
      </p>

      <div data-nf="ctas" style="display: flex; gap: 0.875rem; flex-wrap: wrap; margin-bottom: 2.75rem;">
        <a href="#" style="background: #0096c7; color: white; padding: 0.9rem 1.875rem; border-radius: 100px; font-size: 0.88rem; font-weight: 600; text-decoration: none; min-height: 44px; display: inline-flex; align-items: center; box-shadow: 0 4px 20px rgba(0,150,199,0.4), 0 0 40px rgba(0,150,199,0.12);">
          Termin buchen →
        </a>
        <a href="#" style="background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.8); padding: 0.9rem 1.875rem; border-radius: 100px; font-size: 0.88rem; font-weight: 600; text-decoration: none; min-height: 44px; display: inline-flex; align-items: center; border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px);">
          Behandlungen
        </a>
      </div>

      <!-- Trust row -->
      <div data-nf="trust" style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div style="display: flex; gap: 1px;">
            {'★★★★★'.split('').map(() => (
              <span style="color: #f59e0b; font-size: 0.85rem;">★</span>
            ))}
          </div>
          <span style="font-size: 0.78rem; color: rgba(255,255,255,0.4);">5.0 · 180 Bewertungen</span>
        </div>
        <div style="width: 1px; height: 16px; background: rgba(255,255,255,0.1);"></div>
        <span style="font-size: 0.78rem; color: rgba(255,255,255,0.4);">1.200+ Kunden</span>
        <div style="width: 1px; height: 16px; background: rgba(255,255,255,0.1);"></div>
        <span style="font-size: 0.78rem; color: rgba(255,255,255,0.4);">Seit 2016</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div data-nf="scroll" style="position: absolute; bottom: 2rem; right: 2.5rem; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; opacity: 0.4; pointer-events: none;">
      <div style="width: 1px; height: 40px; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.6)); animation: scrollLine 2s ease-in-out infinite;"></div>
      <span style="font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.6); writing-mode: vertical-rl;">Scroll</span>
    </div>

  </section>
</div>


<!-- ═══════════════════════════════════════════════════════════
     [Hero] Editorial Stack
════════════════════════════════════════════════════════════════ -->
<div style="margin-bottom: 4px;">
  <!-- Meta strip -->
  <div style="background: #0d0d14; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 1.25rem 2rem; display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <div>
      <span style="display: inline-block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #d4a041; background: rgba(212,160,65,0.1); border: 1px solid rgba(212,160,65,0.25); padding: 0.22rem 0.7rem; border-radius: 100px; margin-bottom: 0.6rem;">[Hero] Editorial Stack</span>
      <p style="color: #64748b; font-size: 0.82rem; margin: 0 0 0.625rem; max-width: 500px;">Typografie als Design. Die Headline dominiert — kein Bild nötig. Mutig, modern und sofort erkennbar. Funktioniert auf Hell und Dunkel.</p>
      <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
        {['Restaurant', 'Agentur', 'Fotografie', 'Architektur', 'Mode & Design'].map((t) => (
          <span style="background: rgba(255,255,255,0.04); color: #475569; font-size: 0.7rem; padding: 0.18rem 0.55rem; border-radius: 5px;">{t}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- [Hero] Editorial Stack — PREVIEW -->
  <section id="editorial" style="position: relative; min-height: 82vh; overflow: hidden; background: #0a0808; display: flex; align-items: center; font-family: 'Inter', system-ui, sans-serif;">

    <!-- Warm accent orb background -->
    <div style="position: absolute; top: -15%; right: -5%; width: 70vw; height: 70vw; max-width: 700px; max-height: 700px; background: radial-gradient(circle, rgba(212,140,40,0.12) 0%, transparent 65%); border-radius: 50%; pointer-events: none; animation: esOrb 14s ease-in-out infinite alternate;"></div>
    <div style="position: absolute; bottom: -20%; left: -10%; width: 50vw; height: 50vw; max-width: 500px; max-height: 500px; background: radial-gradient(circle, rgba(180,60,40,0.08) 0%, transparent 65%); border-radius: 50%; pointer-events: none;"></div>

    <!-- Subtle noise texture via pattern -->
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px); background-size: 80px 80px; pointer-events: none;"></div>

    <div style="position: relative; z-index: 2; width: 100%; padding: clamp(2.5rem, 6vw, 5rem);">

      <!-- Top label -->
      <div data-es="badge" style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem;">
        <span style="font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #d4a041;">Trattoria Fuoco</span>
        <div style="flex: 1; max-width: 80px; height: 1px; background: rgba(212,160,65,0.4);"></div>
        <span style="font-size: 0.68rem; letter-spacing: 0.1em; color: rgba(255,255,255,0.25); text-transform: uppercase;">Stuttgart · Mitte</span>
      </div>

      <!-- BIG word -->
      <div data-es="word" style="overflow: hidden;">
        <h1 style="font-size: clamp(5rem, 14vw, 13rem); font-weight: 800; line-height: 0.88; color: #ffffff; margin: 0; letter-spacing: -0.04em; white-space: nowrap; overflow: hidden; text-overflow: clip;">
          CUCINA<span style="color: #d4a041; display: inline-block; margin-left: 0.05em;">.</span>
        </h1>
        <h1 style="font-size: clamp(5rem, 14vw, 13rem); font-weight: 800; line-height: 0.88; color: rgba(255,255,255,0.08); margin: 0 0 0.15em; letter-spacing: -0.04em; white-space: nowrap; overflow: hidden; text-overflow: clip;">
          FUOCO
        </h1>
      </div>

      <!-- Divider line -->
      <div data-es="line" style="width: 100%; max-width: 520px; height: 1px; background: linear-gradient(to right, rgba(212,160,65,0.6), rgba(212,160,65,0.1), transparent); margin: 2rem 0; transform-origin: left;"></div>

      <!-- Sub + CTA row -->
      <div style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 2rem; max-width: 800px;">
        <div data-es="sub">
          <p style="font-size: clamp(0.9rem, 1.4vw, 1rem); color: rgba(255,255,255,0.4); line-height: 1.75; margin: 0; max-width: 380px; font-weight: 300;">
            Authentische norditalienische Küche. Holzofen, Handgemachtes, Gastfreundschaft ohne Kompromiss — seit 1994 in Stuttgart.
          </p>
        </div>
        <div data-es="cta" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
          <a href="#" style="color: #d4a041; font-size: 0.88rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; border: 1.5px solid rgba(212,160,65,0.4); border-radius: 100px; min-height: 44px;">
            Tisch reservieren
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#" style="color: rgba(255,255,255,0.4); font-size: 0.88rem; text-decoration: none; font-weight: 500; min-height: 44px; display: inline-flex; align-items: center;">
            Speisekarte →
          </a>
        </div>
      </div>

      <!-- Bottom right: opening times badge -->
      <div style="position: absolute; bottom: 2.5rem; right: 2.5rem; text-align: right; display: none;" class="es-times">
        <div style="font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.2); margin-bottom: 0.25rem;">Geöffnet</div>
        <div style="font-size: 0.82rem; color: rgba(255,255,255,0.35);">Di–So · 17:30–23:00</div>
      </div>
    </div>

  </section>
</div>


<!-- ═══════════════════════════════════════════════════════════
     [Hero] Estate Cinematic
════════════════════════════════════════════════════════════════ -->
<div style="margin-bottom: 4px;">
  <!-- Meta strip -->
