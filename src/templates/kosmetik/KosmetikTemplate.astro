---
// [Template] Kosmetik — Beauty-Studio-Demo (Hero-Termine · Behandlungen · Vorher/Nachher · Bewertungen)
// Datengetrieben aus Client-Config (Form: clients/_schema.json). Styles 1:1 portiert,
// nur Markenfarben sind CSS-Variablen aus config.marke.farben. #1a1a1a / #faf8f5 bleiben
// bewusst neutral (Luxus-Look der Branche, keine injizierte Markenfarbe).
// Genutzte Config-Felder: marke, kontakt(+instagram), leistungen(titel,icon,preis,dauer,hot), bewertungen.
// Sample-Inhalt (nicht personalisiert, agentur-gepflegt): Hero-Terminslots, Trust-Bar, Vorher/Nachher.
import { Image } from 'astro:assets';
import { clientImage } from '../_shared/clientImage';

interface Farben { primary: string; secondary?: string; accent?: string }
interface Config {
  slug: string;
  marke: { name: string; slogan?: string | null; logo?: string | null; farben: Farben };
  kontakt: { adresse?: string | null; telefon: string; email: string; instagram?: string | null };
  hero?: { ueberschrift?: string } | null;
  leistungen?: { icon?: string; titel: string; preis?: string; dauer?: string; hot?: boolean }[];
  bewertungen?: { name: string; sterne: number; text: string }[];
}

const { config } = Astro.props as { config: Config };
const { slug } = config;
const { name, slogan, logo, farben } = config.marke;
const { adresse, telefon, email, instagram } = config.kontakt;
const behandlungen = config.leistungen ?? [];
const bewertungen = config.bewertungen ?? [];

const cssVars =
  `--c-primary:${farben.primary};` +
  `--c-secondary:${farben.secondary ?? farben.primary};` +
  `--c-accent:${farben.accent ?? farben.primary};`;

const logoImg = clientImage(slug, logo);
const nameWords = name.split(' ');

// Sichere zweizeilige Headline: erste Aussage normal, Rest kursiv.
// Ersetzt das fehleranfällige slogan.split('.')[1] des Originals (crashte ohne Punkt).
const rawTitle = config.hero?.ueberschrift ?? slogan ?? name;
const dot = rawTitle.indexOf('.');
const hasSecond = dot >= 0 && rawTitle.slice(dot + 1).trim().length > 0;
const titleLine1 = hasSecond ? rawTitle.slice(0, dot + 1) : rawTitle;
const titleLine2 = hasSecond ? rawTitle.slice(dot + 1).trim() : '';

// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde personalisiert)
const terminSlots = [
  { tag: 'Mo, 12.05.', uhrzeit: '10:00 Uhr', behandlung: 'Gesichtsbehandlung' },
  { tag: 'Di, 13.05.', uhrzeit: '14:30 Uhr', behandlung: 'Microneedling' },
  { tag: 'Mi, 14.05.', uhrzeit: '11:00 Uhr', behandlung: 'Hyaluron-Filler' },
];
const trustStats = [
  { val: '8+', label: 'Jahre Erfahrung' },
  { val: '2.000+', label: 'Behandlungen' },
  { val: '4,9 ★', label: 'Ø Bewertung' },
  { val: '100%', label: 'Vegane Produkte' },
];
const vorherNachher = [
  { behandlung: 'Microneedling', vorher: 'Unebene Textur, Poren', nachher: 'Glatte, strahlende Haut' },
  { behandlung: 'Hyaluron-Filler', vorher: 'Tiefe Nasolabialfalten', nachher: 'Definierte, volle Konturen' },
  { behandlung: 'Intensiv-Peeling', vorher: 'Pigmentflecken, matter Teint', nachher: 'Gleichmäßiger, frischer Teint' },
];
---
<!doctype html>
<html lang="de" style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{name}{slogan ? ` — ${slogan}` : ''}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600&display=optional" rel="stylesheet" />
  <style is:global>
    :root {
      --c-primary-dark: color-mix(in srgb, var(--c-primary) 70%, black);
      --c-p-08: color-mix(in srgb, var(--c-primary) 8%, transparent);
      --c-p-10: color-mix(in srgb, var(--c-primary) 10%, transparent);
      --c-p-12: color-mix(in srgb, var(--c-primary) 12%, transparent);
      --c-p-20: color-mix(in srgb, var(--c-primary) 20%, transparent);
      --c-a-30: color-mix(in srgb, var(--c-accent) 30%, transparent);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #2d2d2d; background: #faf8f5; }
    .serif { font-family: 'Cormorant Garamond', Georgia, serif; }

    /* DEMO BANNER */
    .demo-banner {
      background: #0d0d14; color: #94a3b8;
      text-align: center; padding: 0.6rem 1rem;
      font-size: 0.75rem; position: sticky; top: 0; z-index: 100;
      border-bottom: 1px solid var(--c-a-30);
    }
    .demo-banner a { color: var(--c-accent); text-decoration: none; font-weight: 600; }
    .demo-banner .cta-btn { background: var(--c-accent); color: white; padding: 0.2rem 0.75rem; border-radius: 4px; margin-left: 0.75rem; }

    /* NAV */
    nav {
      background: rgba(250,248,245,0.95); backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(0,0,0,0.06);
      padding: 1.25rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 37px; z-index: 50;
    }
    .logo { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; color: #1a1a1a; letter-spacing: 0.02em; }
    .logo span { color: var(--c-primary); }
    .logo img { height: 40px; width: auto; display: block; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: #6b6b6b; text-decoration: none; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.02em; }
    .nav-book { background: #1a1a1a; color: white; padding: 0.6rem 1.5rem; border-radius: 100px; font-size: 0.85rem; font-weight: 500; text-decoration: none; }
    @media (max-width: 768px) { .nav-links { display: none; } }

    /* HERO */
    .hero {
      min-height: 90vh; display: flex; align-items: center;
      padding: 5rem 2rem;
      background: linear-gradient(135deg, #faf8f5 0%, color-mix(in srgb, var(--c-primary) 6%, #faf8f5) 40%, color-mix(in srgb, var(--c-primary) 14%, white) 100%);
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; top: -100px; right: -100px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, var(--c-p-08) 0%, transparent 70%);
      border-radius: 50%;
    }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; width: 100%; }
    @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } }

    .hero-tag {
      display: inline-block; background: var(--c-p-10);
      border: 1px solid var(--c-p-20); color: var(--c-primary-dark);
      border-radius: 100px; padding: 0.35rem 1rem;
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em;
      text-transform: uppercase; margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 600; line-height: 1.15; color: #1a1a1a;
      margin-bottom: 1.25rem;
    }
    .hero h1 em { color: var(--c-primary); font-style: italic; }
    .hero p { color: #6b6b6b; font-size: 1rem; line-height: 1.75; margin-bottom: 2rem; }
    .hero-actions { display: flex; gap: 1rem; }
    .btn-dark { background: #1a1a1a; color: white; padding: 0.875rem 2rem; border-radius: 100px; font-size: 0.9rem; font-weight: 500; text-decoration: none; }
    .btn-outline { background: transparent; color: #1a1a1a; border: 1.5px solid #1a1a1a; padding: 0.875rem 2rem; border-radius: 100px; font-size: 0.9rem; font-weight: 500; text-decoration: none; }

    .hero-visual {
      background: white; border-radius: 24px;
      box-shadow: 0 30px 80px var(--c-p-12);
      overflow: hidden;
    }
    .hero-visual-header {
      background: linear-gradient(135deg, var(--c-primary), var(--c-accent));
      padding: 2.5rem 2rem; color: white; text-align: center;
    }
    .hero-visual-header h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; margin-bottom: 0.25rem; }
    .hero-visual-header p { opacity: 0.85; font-size: 0.875rem; }
    .hero-visual-body { padding: 1.5rem; }
    .termin-slot {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.875rem 1rem; border-radius: 10px;
      background: #faf8f5; margin-bottom: 0.625rem;
      font-size: 0.875rem; cursor: pointer;
    }
    .termin-slot strong { color: #1a1a1a; }
    .slot-badge {
      font-size: 0.72rem; font-weight: 600; padding: 0.2rem 0.625rem;
      border-radius: 100px;
    }
    .free { background: rgba(82,183,136,0.15); color: #2d7a57; }
    .book-btn {
      display: block; background: #1a1a1a; color: white;
      text-align: center; padding: 0.875rem; border-radius: 100px;
      font-size: 0.875rem; font-weight: 500; text-decoration: none;
      margin-top: 1.25rem;
    }

    /* SECTIONS */
    section { padding: 5rem 2rem; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 3.5rem; }
    .section-eyebrow {
      font-size: 0.72rem; font-weight: 700; color: var(--c-primary);
      text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 600;
      color: #1a1a1a; line-height: 1.2;
    }
    .section-sub { color: #6b6b6b; font-size: 0.95rem; max-width: 500px; margin: 0.75rem auto 0; line-height: 1.7; }

    /* BEHANDLUNGEN */
    .behandlung-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .behandlung-card {
      background: white; border-radius: 16px;
      padding: 1.75rem; position: relative;
      border: 1px solid rgba(0,0,0,0.06);
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .behandlung-card:hover { box-shadow: 0 8px 30px var(--c-p-10); transform: translateY(-2px); }
    .hot-badge {
      position: absolute; top: 1rem; right: 1rem;
      background: var(--c-primary); color: white;
      font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.5rem;
      border-radius: 100px; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .b-icon { font-size: 1.8rem; margin-bottom: 1rem; }
    .b-name { font-size: 1rem; font-weight: 600; color: #1a1a1a; margin-bottom: 0.3rem; }
    .b-meta { display: flex; gap: 1rem; font-size: 0.8rem; color: #6b6b6b; margin-bottom: 1rem; }
    .b-preis { font-size: 1.1rem; font-weight: 600; color: var(--c-primary); }
    .b-book { display: block; text-align: center; background: #faf8f5; color: #1a1a1a; border: 1px solid rgba(0,0,0,0.1); padding: 0.5rem; border-radius: 8px; font-size: 0.8rem; font-weight: 500; text-decoration: none; margin-top: 1rem; }

    /* VORHER NACHHER */
    .vn-bg { background: #1a1a1a; }
    .vn-title { color: white; }
    .vn-sub { color: #6b6b6b !important; }
    .vn-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .vn-card { border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); }
    .vn-header { background: var(--c-p-20); padding: 1rem 1.25rem; font-size: 0.85rem; font-weight: 600; color: var(--c-accent); }
    .vn-body { background: rgba(255,255,255,0.04); padding: 1.25rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .vn-col { }
    .vn-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem; }
    .vorher .vn-label { color: #ef476f; }
    .nachher .vn-label { color: #52b788; }
    .vn-text { font-size: 0.875rem; color: #d1d5db; line-height: 1.5; }

    /* BEWERTUNGEN */
    .bew-bg { background: #faf8f5; }
    .bew-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .bew-card { background: white; border-radius: 16px; padding: 2rem; border: 1px solid rgba(0,0,0,0.06); }
    .bew-sterne { color: var(--c-primary); font-size: 0.9rem; margin-bottom: 1rem; letter-spacing: 0.1em; }
    .bew-text { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: #2d2d2d; line-height: 1.65; margin-bottom: 1rem; font-style: italic; }
    .bew-author { font-size: 0.8rem; font-weight: 600; color: var(--c-primary); }

    /* BOOKING CTA */
    .cta-bg {
      background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-accent) 100%);
      text-align: center; color: white;
    }
    .cta-bg h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 600; margin-bottom: 1rem; }
    .cta-bg p { opacity: 0.85; font-size: 1rem; line-height: 1.7; max-width: 500px; margin: 0 auto 2rem; }
    .cta-white-btn { display: inline-block; background: white; color: var(--c-primary); padding: 0.875rem 2.5rem; border-radius: 100px; font-size: 0.95rem; font-weight: 600; text-decoration: none; }

    /* FOOTER */
    footer { background: #1a1a1a; color: #6b6b6b; padding: 2rem; text-align: center; font-size: 0.8rem; }
    footer a { color: var(--c-primary); text-decoration: none; }
  </style>
</head>
<body>

<!-- DEMO BANNER -->
<div class="demo-banner">
  🎨 Musterseite von <a href="/">Blue Ocean Marketing</a> — mit Ihrem Branding in 48h personalisiert.
  <a href="https://blue-ocean.marketing/kontakt/" target="_blank" rel="noopener" class="cta-btn">Demo anfragen →</a>
</div>

<!-- NAV -->
<nav>
  <div class="logo">
    {logoImg
      ? <Image src={logoImg} alt={name} height={40} width={Math.round(40 * (logoImg.width / logoImg.height))} />
      : <Fragment>{nameWords[0]} {nameWords.length > 1 && <span>{nameWords.slice(1).join(' ')}</span>}</Fragment>}
  </div>
  <ul class="nav-links">
    <li><a href="#behandlungen">Behandlungen</a></li>
    <li><a href="#ergebnisse">Ergebnisse</a></li>
    <li><a href="#bewertungen">Bewertungen</a></li>
    <li><a href="#buchen">Buchen</a></li>
  </ul>
  <a href="#buchen" class="nav-book">Termin buchen</a>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-tag">✦ Premium Beauty Studio</div>
      <h1>{titleLine1}{titleLine2 && <Fragment><br /><em>{titleLine2}</em></Fragment>}</h1>
      <p>Individuelle Behandlungen für Ihre Haut — mit modernsten Methoden, natürlichen Produkten und einem Team das wirklich zuhört.</p>
      <div class="hero-actions">
        <a href="#buchen" class="btn-dark">Termin buchen</a>
        <a href="#behandlungen" class="btn-outline">Leistungen ansehen</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-visual-header">
        <h3>Nächste freie Termine</h3>
        <p>Einfach online buchen — ohne Wartezeit</p>
      </div>
      <div class="hero-visual-body">
        {terminSlots.map(t => (
          <div class="termin-slot">
            <div>
              <strong>{t.tag} · {t.uhrzeit}</strong>
              <div style="font-size: 0.78rem; color: #6b6b6b; margin-top: 0.1rem;">{t.behandlung}</div>
            </div>
            <span class="slot-badge free">Frei</span>
          </div>
        ))}
        <a href="#buchen" class="book-btn">Alle Termine ansehen →</a>
      </div>
    </div>
  </div>
</div>

<!-- TRUST BAR -->
<section style="padding: 2rem; background: white; border-bottom: 1px solid rgba(0,0,0,0.06);">
  <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; text-align: center;">
    {trustStats.map(s => (
      <div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--c-primary);">{s.val}</div>
        <div style="font-size: 0.78rem; color: #6b6b6b; margin-top: 0.2rem;">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- BEHANDLUNGEN -->
<section id="behandlungen">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow">Was wir anbieten</div>
      <h2 class="section-title">Unsere Behandlungen</h2>
      <p class="section-sub">Von der sanften Reinigung bis zur professionellen Anti-Aging-Therapie.</p>
    </div>
    <div class="behandlung-grid">
      {behandlungen.map(b => (
        <div class="behandlung-card">
          {b.hot && <div class="hot-badge">Beliebt</div>}
          <div class="b-icon">{b.icon}</div>
          <div class="b-name">{b.titel}</div>
          <div class="b-meta">
            {b.dauer && <span>⏱ {b.dauer}</span>}
          </div>
          {b.preis && <div class="b-preis">{b.preis}</div>}
          <a href="#buchen" class="b-book">Termin buchen →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- VORHER NACHHER -->
<section id="ergebnisse" class="vn-bg">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow" style="color: var(--c-accent);">Echte Ergebnisse</div>
      <h2 class="section-title vn-title">Vorher · Nachher</h2>
      <p class="section-sub vn-sub">Keine Filter, keine Bearbeitung — nur das, was unsere Behandlungen wirklich bewirken.</p>
    </div>
    <div class="vn-grid">
      {vorherNachher.map(vn => (
        <div class="vn-card">
          <div class="vn-header">{vn.behandlung}</div>
          <div class="vn-body">
            <div class="vn-col vorher">
              <div class="vn-label">Vorher</div>
              <div class="vn-text">{vn.vorher}</div>
            </div>
            <div class="vn-col nachher">
              <div class="vn-label">Nachher</div>
              <div class="vn-text">{vn.nachher}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BEWERTUNGEN -->
<section id="bewertungen" class="bew-bg">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow">Kundenstimmen</div>
      <h2 class="section-title">Das sagen unsere Kundinnen</h2>
      <p class="section-sub">Über 2.000 Behandlungen — von echten Kundinnen bewertet.</p>
    </div>
    <div class="bew-grid">
      {bewertungen.map(b => (
        <div class="bew-card">
          <div class="bew-sterne">{'★'.repeat(b.sterne)}</div>
          <div class="bew-text">„{b.text}"</div>
          <div class="bew-author">— {b.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BOOKING CTA -->
<section id="buchen" class="cta-bg">
  <div class="section-inner">
    <h2>Bereit für Ihre Verwandlung?</h2>
    <p>Buchen Sie jetzt Ihren Wunschtermin — online, einfach, ohne Wartezeit.</p>
    <a href={`tel:${telefon}`} class="cta-white-btn">📞 {telefon}</a>
    <div style="margin-top: 1rem; opacity: 0.7; font-size: 0.875rem;">
      oder schreiben Sie uns: <a href={`mailto:${email}`} style="color: white; font-weight: 600;">{email}</a>
    </div>
    {instagram && <div style="margin-top: 0.625rem; opacity: 0.6; font-size: 0.8rem;">{instagram}</div>}
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: #d1d5db; margin-bottom: 0.5rem;">{name}</p>
  <p>{adresse ? `${adresse} · ` : ''}{telefon}</p>
  <p style="margin-top: 0.5rem;">
    <a href="#">Impressum</a> · <a href="#">Datenschutz</a>
  </p>
  <p style="margin-top: 0.75rem; font-size: 0.72rem; opacity: 0.4;">
    Demo erstellt von <a href="/" style="color: var(--c-accent);">Blue Ocean Marketing</a>
  </p>
</footer>

</body>
</html>
