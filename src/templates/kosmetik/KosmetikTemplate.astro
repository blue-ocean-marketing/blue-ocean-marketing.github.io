<script>
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Scroll-Reveal beim Eintreten */
    var els = document.querySelectorAll('.reveal');
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach(function (e) { e.classList.add('in'); });
    } else {
      var io = new IntersectionObserver(function (ents) {
        ents.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { rootMargin: '0px 0px -12% 0px', threshold: 0.12 });
      els.forEach(function (e) { io.observe(e); });
    }

    /* [Hero] Studio Open — Geräte-Reel + Crossfade.
       Reduced-Motion oder Save-Data → gar kein Video, Poster bleibt stehen. */
    (function () {
      var cine = document.querySelector('.cine');
      if (!cine) return;
      var conn = navigator.connection || {};
      if (reduce || conn.saveData === true) return;

      var sel = window.matchMedia('(max-width: 767px)').matches ? 'm' : 'd';
      var vids = [];
      [].slice.call(cine.querySelectorAll('.cine-vid')).forEach(function (v) {
        if (v.getAttribute('data-reel') === sel) vids.push(v);
        else if (v.parentNode) v.parentNode.removeChild(v);
      });
      if (!vids.length) return;
      vids.forEach(function (v) { v.src = v.getAttribute('data-src'); v.load(); });

      function play(v) { var p = v.play(); if (p && p.catch) p.catch(function () {}); }

      if (vids.length === 1) {
        vids[0].loop = true;
        vids[0].classList.add('on');
        play(vids[0]);
        return;
      }

      var i = 0, switching = false;
      function show(n) { vids[n].classList.add('on'); vids[n].currentTime = 0; play(vids[n]); }
      function advance() {
        if (switching) return;
        switching = true;
        var prev = vids[i];
        i = (i + 1) % vids.length;
        show(i);
        setTimeout(function () {
          prev.classList.remove('on'); prev.pause();
          switching = false;
        }, 1200);
      }
      vids.forEach(function (v) {
        v.addEventListener('timeupdate', function () {
          if (v === vids[i] && v.duration && v.currentTime >= v.duration - 1.0) advance();
        });
        v.addEventListener('ended', function () { if (v === vids[i]) advance(); });
      });
      show(0);
    })();
  })();
</script>

<!-- [Showcase] Insta Reel Strip Controller — Lazy-Load + Autoplay-on-Visible -->
<script>
  (function () {
    var strip = document.querySelector('[data-rs-strip]');
    if (!strip) return;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var conn = navigator.connection || {};
    if (reduce || conn.saveData === true) return; /* Posters bleiben, Videos nicht geladen */

    var tiles = [].slice.call(strip.querySelectorAll('[data-rs-tile]'));
    if (!tiles.length || !('IntersectionObserver' in window)) return;

    function loadAndPlay(tile) {
      var v = tile.querySelector('video');
      if (!v) return;
      if (!v.src) {
        var src = v.getAttribute('data-rs-src');
        if (src) { v.src = src; v.load(); }
      }
      var p = v.play();
      if (p && p.catch) p.catch(function () {});
      tile.classList.add('is-playing');
    }
    function pause(tile) {
      var v = tile.querySelector('video');
      if (v && !v.paused) v.pause();
    }

    var io = new IntersectionObserver(function (ents) {
      ents.forEach(function (en) {
        if (en.isIntersecting) loadAndPlay(en.target);
        else pause(en.target);
      });
    }, { root: null, threshold: 0.55 });
    tiles.forEach(function (t) { io.observe(t); });

    /* Pause auch bei Tab-Wechsel — spart Bandbreite */
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) tiles.forEach(pause);
    });
  })();
</script>

<!-- [Ergebnisse] Cinema Split-Reel Controller — 3D-Karussell + drag-bare Splits -->
<script>
  (function () {
    var reel = document.querySelector('[data-vn-reel]');
    if (!reel) return;
    var wrap = reel.parentNode;
    var slides = [].slice.call(reel.querySelectorAll('.vn-slide'));
    var n = slides.length;
    if (!n) return;
    var dots = [].slice.call(wrap.querySelectorAll('[data-vn-dot]'));
    var prevBtn = reel.querySelector('.vn-nav--prev');
    var nextBtn = reel.querySelector('.vn-nav--next');
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var current = Math.floor(n / 2);
    var autoId = null;

    function render() {
      for (var i = 0; i < n; i++) {
        var diff = i - current;
        if (diff > n / 2) diff -= n;
        if (diff < -n / 2) diff += n;
        var pos = Math.abs(diff) > 2 ? 'hidden' : String(diff);
        slides[i].setAttribute('data-pos', pos);
      }
      for (var j = 0; j < dots.length; j++) {
        if (j === current) dots[j].classList.add('is-active');
        else dots[j].classList.remove('is-active');
      }
    }
    function go(i) { current = ((i % n) + n) % n; render(); }
    function next() { go(current + 1); }
    function prev() { go(current - 1); }
    function stopAuto() { if (autoId) { clearInterval(autoId); autoId = null; } }
    function startAuto() {
      if (reduce || autoId) return;
      autoId = setInterval(next, 5500);
    }

    nextBtn.addEventListener('click', function () { stopAuto(); next(); });
    prevBtn.addEventListener('click', function () { stopAuto(); prev(); });
    dots.forEach(function (d, i) {
      d.addEventListener('click', function () { stopAuto(); go(i); });
    });

    /* Auto-rotate pausiert, sobald User interagiert (hover, touch). */
    reel.addEventListener('pointerenter', stopAuto);
    reel.addEventListener('touchstart', stopAuto, { passive: true });

    /* Pause auch wenn ausserhalb des Viewports (Tab-Wechsel, weit nach unten gescrollt) */
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (ents) {
        ents.forEach(function (en) {
          if (en.isIntersecting) startAuto();
          else stopAuto();
        });
      }, { threshold: 0.25 });
      io.observe(reel);
    } else {
      startAuto();
    }

    /* Tastatur: ← → schalten, wenn Reel im Fokus */
    reel.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') { stopAuto(); next(); }
      else if (e.key === 'ArrowLeft') { stopAuto(); prev(); }
    });

    /* Pro Slide: Vorher/Nachher-Split mit Drag-Handle.
       Clip-path-Driven, Pointer-Events normalisiert (Maus + Touch + Pen). */
    slides.forEach(function (slide) {
      var split = slide.querySelector('.vn-split');
      if (!split) return;
      var handle = split.querySelector('.vn-handle');
      if (!handle) return;
      var dragging = false;

      function setSplit(clientX) {
        var rect = split.getBoundingClientRect();
        if (!rect.width) return;
        var pct = ((clientX - rect.left) / rect.width) * 100;
        if (pct < 6) pct = 6;
        if (pct > 94) pct = 94;
        split.style.setProperty('--split', pct.toFixed(2) + '%');
      }
      function onDown(e) {
        if (slide.getAttribute('data-pos') !== '0') return;
        dragging = true; stopAuto();
        try { handle.setPointerCapture(e.pointerId); } catch (_) {}
        setSplit(e.clientX);
        e.preventDefault();
      }
      function onMove(e) { if (dragging) { setSplit(e.clientX); e.preventDefault(); } }
      function onUp(e) {
        if (!dragging) return;
        dragging = false;
        try { handle.releasePointerCapture(e.pointerId); } catch (_) {}
      }
      handle.addEventListener('pointerdown', onDown);
      handle.addEventListener('pointermove', onMove);
      handle.addEventListener('pointerup', onUp);
      handle.addEventListener('pointercancel', onUp);

      /* Klick neben den Handle setzt ihn an die Klickposition */
      split.addEventListener('click', function (e) {
        if (slide.getAttribute('data-pos') !== '0') return;
        if (e.target.closest('.vn-handle') || e.target.closest('.vn-nav')) return;
        stopAuto();
        setSplit(e.clientX);
      });

      /* Tastatur auf Handle: ← → in 4%-Schritten */
      handle.addEventListener('keydown', function (e) {
        if (slide.getAttribute('data-pos') !== '0') return;
        var cur = parseFloat(getComputedStyle(split).getPropertyValue('--split')) || 50;
        if (e.key === 'ArrowLeft')  { cur = Math.max(6, cur - 4); split.style.setProperty('--split', cur + '%'); stopAuto(); e.preventDefault(); }
        else if (e.key === 'ArrowRight') { cur = Math.min(94, cur + 4); split.style.setProperty('--split', cur + '%'); stopAuto(); e.preventDefault(); }
      });
    });

    render();
  })();
</script>

<!-- [Scorecard] Controller — DOM-getrieben, dependency-frei, idempotent -->
<script>
  (function () {
    var card = document.querySelector('[data-sc]');
    if (!card) return;
    var steps = [].slice.call(card.querySelectorAll('.sc-step'));
    var order = steps.map(function (s) { return s.getAttribute('data-step'); });
    var qEls = [].slice.call(card.querySelectorAll('.sc-q'));
    var bar = card.querySelector('.sc-progress > i');
    var picks = {};
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function go(name) {
      steps.forEach(function (s) { s.hidden = (s.getAttribute('data-step') !== name); });
      var i = order.indexOf(name);
      if (bar) bar.style.width = Math.round((i / (order.length - 1)) * 100) + '%';
      try { card.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'center' }); }
      catch (e) { card.scrollIntoView(); }
    }
    function step(from, dir) {
      var i = order.indexOf(from);
      go(order[Math.max(0, Math.min(order.length - 1, i + dir))]);
    }

    card.querySelectorAll('.sc-start').forEach(function (b) {
      b.addEventListener('click', function () { go(order[1]); });
    });
    qEls.forEach(function (q) {
      var key = q.getAttribute('data-step');
      q.querySelectorAll('.sc-opt').forEach(function (opt) {
        opt.addEventListener('click', function () {
          q.querySelectorAll('.sc-opt').forEach(function (o) { o.classList.remove('is-sel'); });
          opt.classList.add('is-sel');
          picks[key] = parseFloat(opt.getAttribute('data-points')) || 0;
          step(key, 1);
        });
      });
    });
    card.querySelectorAll('[data-back]').forEach(function (b) {
      b.addEventListener('click', function () {
        step(b.closest('.sc-step').getAttribute('data-step'), -1);
      });
    });

    function valid() {
      var n = card.querySelector('[data-req="name"]');
      var m = card.querySelector('[data-req="email"]');
      return n && n.value.trim().length > 1 &&
             m && /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(m.value.trim());
    }
    card.querySelectorAll('.sc-reveal').forEach(function (b) {
      b.addEventListener('click', function () {
        var err = card.querySelector('[data-err]');
        if (!valid()) { if (err) err.hidden = false; return; }
        if (err) err.hidden = true;
        var max = 0, got = 0;
        qEls.forEach(function (q) {
          var pts = [].slice.call(q.querySelectorAll('.sc-opt')).map(function (o) {
            return parseFloat(o.getAttribute('data-points')) || 0;
          });
          max += Math.max.apply(null, pts.concat([0]));
          got += picks[q.getAttribute('data-step')] || 0;
        });
        var pct = max > 0 ? Math.round((got / max) * 100) : 0;
        var tiers = [].slice.call(card.querySelectorAll('.sc-tier')).sort(function (a, b2) {
          return (+a.getAttribute('data-min')) - (+b2.getAttribute('data-min'));
        });
        var tier = tiers[0];
        tiers.forEach(function (t) { if (pct >= (+t.getAttribute('data-min'))) tier = t; });
        var sEl = card.querySelector('[data-score]'); if (sEl) sEl.textContent = pct;
        var lEl = card.querySelector('[data-tierlabel]'); if (lEl && tier) lEl.textContent = tier.getAttribute('data-label');
        var mEl = card.querySelector('[data-tiermsg]'); if (mEl && tier) mEl.textContent = tier.textContent;
        go('result');
      });
    });
    card.querySelectorAll('[data-restart]').forEach(function (b) {
      b.addEventListener('click', function () {
        picks = {};
        card.querySelectorAll('.sc-opt.is-sel').forEach(function (o) { o.classList.remove('is-sel'); });
        card.querySelectorAll('.sc-in').forEach(function (i) { i.value = ''; });
        var err = card.querySelector('[data-err]'); if (err) err.hidden = true;
        go('intro');
      });
    });
  })();
</script>

<!-- [Sticky] Mobile CTA Bar — Visibility-Toggle: zeigt Bar erst wenn Hero raus-gescrollt ist -->
<script>
  (function () {
    var bar = document.querySelector('[data-sticky-cta]');
    var hero = document.querySelector('.cine');
    if (!bar || !hero) return;
    if (!('IntersectionObserver' in window)) {
      bar.setAttribute('data-visible', 'true');
      return;
    }
    var io = new IntersectionObserver(function (ents) {
      ents.forEach(function (en) {
        if (en.isIntersecting) bar.removeAttribute('data-visible');
        else bar.setAttribute('data-visible', 'true');
      });
    }, { threshold: 0, rootMargin: '-80px 0px 0px 0px' });
    io.observe(hero);
  })();
</script>

