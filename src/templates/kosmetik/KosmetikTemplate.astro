---
// [Template] Kosmetik — „Studio Cinema" (Nav · Video-Hero · Assurance · Trust · Behandlungen · Vorher/Nachher · Ablauf · Team · Stimmen · Scorecard · Kontakt)
// Flavor A-light der Template-Formel: Cinematic Video-Reel-Hero + scroll-getriebene
// Sektionen, aber KEIN 3D-Scroll-Cinema — Showpiece ist die Vorher/Nachher-Sektion.
// Datengetrieben aus einer Client-Config (Form: clients/_schema.json).
// Inhaltliche Quelle der Copy = zielgruppen.md §5: Hygiene = No-Go-Kriterium (leise),
// Vorher-Nachher = Beweis, Erstgespräch entschärft Filler-Angst, Diskretion mitschreiben.
//
// Schrift: Cormorant Garamond (Serif/Display) + Inter (Body) — boutique-beauty.
// Markenfarbe sparsam, abgeleitete Töne via color-mix. Personalisierung läuft
// ausschließlich über CSS-Variablen aus config.marke.farben — kein Tailwind.
//
// Feld-Mapping (Schema = LeadBook-Schnittstelle, NICHT umbenennen):
//   leistungen[] = Behandlungen: icon · titel · text · preis (z.B. „ab 79 €") · dauer · hot=Beliebt
//   team[]       = Kosmetiker:innen · bewertungen[] = Kundenstimmen
//   galerie[]    = Studio-Impressionen (optional; Fallback = pastellige Verläufe)
// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde): Trust-Punkte, Ablauf, Vorher/Nachher.
import { Image } from 'astro:assets';
import { clientImage } from '../_shared/clientImage';
import VerticalReel from '../../components/showcase/VerticalReel.astro';

interface Farben { primary: string; secondary?: string; accent?: string }
interface Behandlung { icon?: string; titel: string; text?: string; preis?: string; dauer?: string; hot?: boolean }
interface Config {
  slug: string;
  marke: { name: string; slogan?: string | null; logo?: string | null; farben: Farben };
  kontakt: { adresse?: string | null; stadt?: string | null; telefon: string; email: string; oeffnung?: string | null; instagram?: string | null };
  hero?: { ueberschrift?: string; text?: string; cta_text?: string; cta_ziel?: string } | null;
  leistungen?: Behandlung[];
  team?: { name: string; rolle: string; bild?: string | null; initialen?: string | null; bio?: string | null }[];
  bewertungen?: { name: string; sterne: number; text: string }[];
  galerie?: { bild: string; alt?: string }[];
}

const { config } = Astro.props as { config: Config };
const { slug } = config;
const { name, slogan, logo, farben } = config.marke;
const { adresse, telefon, email, oeffnung, instagram } = config.kontakt;
const stadtRaw = config.kontakt.stadt;
const behandlungen = config.leistungen ?? [];
const team = config.team ?? [];
const bewertungen = config.bewertungen ?? [];
const galerie = config.galerie ?? [];

// Default-Studio-Impressionen (web-optimiert, astro:assets) — greifen im Showcase
// bzw. wenn die Kunden-Config keine galerie[] mitbringt.
const galGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/kosmetik/clinic-*.webp', { eager: true });
const galDefaults = Object.keys(galGlob).sort().map((k) => galGlob[k].default);
const galBilder = (galerie.length > 0
  ? galerie.slice(0, 6).map((g, i) => ({
      img: clientImage(slug, g.bild) ?? galDefaults[i] ?? null,
      alt: g.alt ?? `Studio-Impression ${i + 1}`,
    }))
  : galDefaults.slice(0, 6).map((img, i) => ({ img, alt: `Studio-Impression ${i + 1}` })));

// Avatar-Palette (Fallback wenn kein Foto): zyklisch durch die Markenfarben
const palette = [farben.primary, farben.secondary ?? farben.primary, farben.accent ?? farben.primary];

const cssVars =
  `--c-primary:${farben.primary};` +
  `--c-secondary:${farben.secondary ?? farben.primary};` +
  `--c-accent:${farben.accent ?? farben.primary};`;

const ort = adresse && adresse.includes(',') ? adresse.split(',').slice(-1)[0].trim() : '';
const stadt = stadtRaw ?? ort;

// Showcase-Default greift NUR auf der öffentlichen Demo-Marke (Name-Gate).
// Echte Kunden behalten ihre Textmarke bzw. Initialen-Avatar.
const isShowcase = /aura\s*beauty\s*studio/i.test(name);

// Showcase-Logo (Demo-Asset) liegt neben den Showcase-Bildern unter src/assets/kosmetik/.
// Echte Kunden-Logos kommen via clientImage() aus src/assets/clients/<slug>/ (.gitignore'd).
const showcaseLogoGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/kosmetik/logo.webp', { eager: true });
const showcaseLogo = showcaseLogoGlob['/src/assets/kosmetik/logo.webp']?.default ?? null;
const logoImg = clientImage(slug, logo) ?? (isShowcase ? showcaseLogo : null);

// Team-Default-Portraits aus _shared/team — wiederverwendbar, branche-übergreifend.
const portraitGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/_shared/team/portrait-*.webp', { eager: true });
const portrait = (n: string) => portraitGlob[`/src/assets/_shared/team/portrait-${n}.webp`]?.default ?? null;
// Showcase-Defaults: alle 4 weiblich (Léa/Sarah/Mira/Anna sind weibliche Vornamen).
// 02=weisses T-Shirt → Léa (Inhaberin clean), 03=roter Rolli → Sarah (warm),
// 04=Regenbogen-Kleid → Mira (Brautstyling vibrant), 01=grauer Blazer → Anna (Beraterin).
const teamDefaults = [portrait('02'), portrait('03'), portrait('04'), portrait('01')];

// [Ergebnisse] Vorher/Nachher-Bilder aus _shared/kosmetik — Demo-Visualisierung,
// Kunde tauscht eigene Bildpaare über clientImage() später ein.
const vnGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/_shared/kosmetik/*.jpg', { eager: true });
const vnDefault = (k: string, side: 'vorher' | 'nachher') =>
  vnGlob[`/src/assets/_shared/kosmetik/${k}-${side}.jpg`]?.default ?? null;

// [Showcase] Insta Reel Strip — vertikale Reel-Tiles, autoplay-on-scroll.
// Mappt zu konkreten Behandlungen, eyebrow + serif-titel im Insta-Style.
const reels = [
  { key: 'pflege',        eyebrow: 'Gesicht',       titel: 'Reine Frische' },
  { key: 'wimpern',       eyebrow: 'Wimpern',       titel: 'Augen, die sprechen' },
  { key: 'hyaluron',      eyebrow: 'Hyaluron',      titel: 'Subtile Konturen' },
  { key: 'microneedling', eyebrow: 'Microneedling', titel: 'Glatte Haut, sichtbar' },
  { key: 'peeling',       eyebrow: 'Peeling',       titel: 'Der ehrliche Glow' },
];

// [Trust] Brand Marquee — Demo-Markenset für Kosmetikstudios.
// ⚠ Markenrechte: nur einsetzen, wenn das Studio diese Marken tatsächlich führt.
const brandGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/_shared/brands/*.{svg,png}', { eager: true });
const brandKeys = ['dolce-gabbana','mac','nars','charlotte-tilbury','hermes','dior','chanel','ysl','huda-beauty','estee-lauder','givenchy','tom-ford'];
const brandLabels: Record<string, string> = {
  'dolce-gabbana': 'Dolce & Gabbana', 'mac': 'MAC Cosmetics', 'nars': 'NARS',
  'charlotte-tilbury': 'Charlotte Tilbury', 'hermes': 'Hermès', 'dior': 'Dior',
  'chanel': 'Chanel', 'ysl': 'Yves Saint Laurent', 'huda-beauty': 'Huda Beauty',
  'estee-lauder': 'Estée Lauder', 'givenchy': 'Givenchy', 'tom-ford': 'Tom Ford',
};
const brands = brandKeys.flatMap((k) => {
  const img = (brandGlob[`/src/assets/_shared/brands/${k}.svg`]
            ?? brandGlob[`/src/assets/_shared/brands/${k}.png`])?.default;
  return img ? [{ key: k, img, alt: brandLabels[k] ?? k }] : [];
});

// Hero-H1-Block (universell: branchen-sub · name · stadt-tag) + 1-zeiliger Lead.
const heroBrancheSub = 'Kosmetikstudio';
const heroBrancheTag = 'Kosmetik';
const heroLead = config.hero?.text ?? slogan ?? 'Schönheit, die von innen leuchtet.';
const ctaText = config.hero?.cta_text ?? 'Termin vereinbaren';
const ctaZiel = config.hero?.cta_ziel ?? '#kontakt';
const telHref = `tel:${telefon.replace(/[^+\d]/g, '')}`;
// WhatsApp: rohe Ziffern, deutsche Vorwahl (0 → 49) wenn führend
const waDigits = telefon.replace(/[^\d]/g, '').replace(/^0/, '49');
const waHref = `https://wa.me/${waDigits}?text=${encodeURIComponent(`Hallo ${name}, ich interessiere mich für ein Erstgespräch.`)}`;

const bewAvg = bewertungen.length
  ? (bewertungen.reduce((s, b) => s + b.sterne, 0) / bewertungen.length)
  : 0;
const bewAvgStr = bewAvg.toFixed(1).replace('.', ',');

function initialen(t: { name: string; initialen?: string | null }) {
  if (t.initialen) return t.initialen;
  return t.name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
}

// Strich-Icons (Feather-Stil, currentColor) — kein Emoji. „sparkle" als Logo-Mark.
const I = {
  phone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
  clock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>',
  arrow: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>',
  check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>',
  star: '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.26 6.6.79-4.9 4.6 1.3 6.55L12 17.1 6.1 20.2l1.3-6.55-4.9-4.6 6.6-.79Z"/></svg>',
  menu: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>',
  // [Mark] Sparkle-Sigil — Vier-Punkt-Stern als Beauty-Logo-Anchor (kein Emoji)
  sparkle: '<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M32 6c0 12 6 18 18 18-12 0-18 6-18 18 0-12-6-18-18-18 12 0 18-6 18-18Z"/><path d="M52 38c0 6 3 9 9 9-6 0-9 3-9 9 0-6-3-9-9-9 6 0 9-3 9-9Z"/></svg>',
  instagram: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>',
  whatsapp: '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.15-1.75-.86-2.02-.96-.27-.1-.47-.15-.66.15-.2.3-.76.96-.93 1.16-.17.2-.34.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.66-1.6-.9-2.18-.24-.57-.48-.5-.66-.5l-.56-.01c-.2 0-.51.07-.78.37-.27.3-1.02 1-1.02 2.44 0 1.44 1.05 2.83 1.2 3.03.15.2 2.06 3.14 4.99 4.4.7.3 1.24.48 1.66.62.7.22 1.33.19 1.83.11.56-.08 1.75-.71 2-1.4.25-.69.25-1.28.17-1.4-.07-.13-.27-.2-.57-.35Zm-5.4 7.36c-1.65 0-3.27-.44-4.69-1.28l-.34-.2-3.48.91.93-3.39-.22-.36c-.92-1.47-1.41-3.16-1.41-4.9 0-5.07 4.13-9.2 9.21-9.2 2.46 0 4.77.96 6.51 2.7 1.74 1.74 2.69 4.05 2.69 6.51 0 5.08-4.13 9.21-9.2 9.21Zm7.83-17.05A11.04 11.04 0 0 0 12.11 1c-6.1 0-11.07 4.96-11.07 11.06 0 1.95.51 3.85 1.48 5.52L1 23l5.55-1.46a11.06 11.06 0 0 0 5.56 1.42h.01c6.1 0 11.07-4.96 11.07-11.06 0-2.96-1.15-5.74-3.24-7.83Z"/></svg>',
  shield: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>',
};

const navLinks = [
  { href: '#behandlungen', label: 'Behandlungen' },
  { href: '#ergebnisse', label: 'Ergebnisse' },
  { href: '#ablauf', label: 'Ablauf' },
  { href: '#team', label: 'Team' },
  { href: '#stimmen', label: 'Stimmen' },
  { href: '#kontakt', label: 'Kontakt' },
];

// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde personalisiert) —
// gespeist aus zielgruppen.md §5: Hygiene als ruhige Selbstverständlichkeit,
// Erstgespräch als Filler-Angst-Brecher, Diskretion mitschreiben.
const trust = [
  'Erstberatung kostenlos',
  'Sterile Einmal-Instrumente',
  'Separates Behandlungszimmer',
  'Geprüfte Kosmetiker:innen',
  'Keine Pakete-Pflicht',
  'Vegane Produktlinie',
];

// [Vertrauen] Assurance Bar — agentur-gepflegt, branche-spezifisch.
// Conversion-Hebel #1 laut zielgruppen.md §5: Erstgespräch vor Behandlung —
// senkt Filler-/Microneedling-Angst spürbar mehr als jeder Behandlungspreis.
const assureKicker = 'Erst sehen. Dann entscheiden.';
const assureTitel = 'Wir behandeln nie beim Erstbesuch.';
const assureText = 'Sie kommen. Wir schauen uns Ihre Haut an, hören zu, und sagen ehrlich was geht und was nicht. Sie entscheiden in Ruhe — keine Pakete, keine Suggestiv-Beratung, keine spritze, an die Sie sich am nächsten Tag nicht erinnern.';
const assure = [
  { t: 'Erstgespräch kostenlos', d: '30 Minuten Hautanalyse und ehrliche Einschätzung — auch wenn das Ergebnis ist: „bei Ihnen reicht eine Pflege-Routine zu Hause".' },
  { t: 'Diskretion ohne Schnörkel', d: 'Separates Behandlungszimmer, getrennter Wartebereich, kein Foto-Material ohne Ihre ausdrückliche Freigabe.' },
  { t: 'Hygiene als Selbstverständlichkeit', d: 'Sterile Einmal-Instrumente bei jedem Treatment, sichtbare Reinigung zwischen Kund:innen — keine Abkürzungen.' },
];

// [Vorher/Nachher] Result Cards — das Showpiece (statt 3D-Cinema bei Flavor A).
// Conversion-Hebel #2 laut zielgruppen.md §5: Vorher/Nachher prominent, aber ehrlich.
// Wir zeigen *konkrete* Aussagen (Behandlungsanzahl, Zeitraum) — nicht „perfekt".
const ergebnisse = [
  { key: 'microneedling', behandlung: 'Microneedling', sitzungen: '3 Sitzungen, 6 Wochen', vorher: 'Unebene Hauttextur, sichtbare Poren, matter Teint', nachher: 'Spürbar glattere Oberfläche, kleinere Poren, frischer Look — natürlich, nicht maskenhaft' },
  { key: 'hyaluron', behandlung: 'Hyaluron-Filler', sitzungen: 'Eine Sitzung, Kontrolle nach 14 Tagen', vorher: 'Schatten und Volumenverlust im Wangenbereich, müder Ausdruck', nachher: 'Sanftere Konturen ohne „aufgespritzt"-Effekt — Sie sehen aus wie Sie, ausgeschlafen' },
  { key: 'peeling', behandlung: 'Intensiv-Peeling', sitzungen: '4 Sitzungen, je 3 Wochen Abstand', vorher: 'Pigmentflecken, Akne-Narben, ungleichmäßiger Teint', nachher: 'Gleichmäßigerer, hellerer Teint, deutlich reduzierte Flecken — sichtbar ohne Filter' },
];
const ergebnisseMitBild = ergebnisse.map((e) => ({
  ...e,
  imgVorher: clientImage(slug, `${e.key}-vorher.jpg`) ?? vnDefault(e.key, 'vorher'),
  imgNachher: clientImage(slug, `${e.key}-nachher.jpg`) ?? vnDefault(e.key, 'nachher'),
}));

// [Ablauf] So läuft Ihre Behandlung ab — gespeist aus zielgruppen.md §5.3
// (Punkt 4: Erstgespräch vor Behandlung sichtbar einbauen — qualifiziert + senkt Angst).
const ablauf = [
  { nr: '01', titel: 'Erstgespräch', text: 'Sie kommen, wir nehmen uns 30 Minuten. Wir hören zu, was Sie stört — und was Sie sich wirklich erhoffen.' },
  { nr: '02', titel: 'Hautanalyse', text: 'Lupe, Tageslicht, ggf. Hautmessung. Wir zeigen Ihnen, was wir sehen — und was davon mit Behandlung sinnvoll ist.' },
  { nr: '03', titel: 'Behandlungsplan', text: 'Ehrlicher Plan mit Anzahl Sitzungen, Kosten, realistischem Ergebnis. Sie nehmen ihn mit nach Hause und entscheiden in Ruhe.' },
  { nr: '04', titel: 'Behandlung & Pflege', text: 'Erst dann starten wir — mit klarer Nachsorge-Empfehlung, damit das Ergebnis hält.' },
];

// [Scorecard] Self-Check — interaktiver Lead-Magnet (Priestley/ScoreApp).
// Konzept „which type are you?": qualifiziert die Besucherin in 3 Hauttypen-Tiers
// (Maintenance · gezielte Behandlung · Erstanalyse empfohlen) und gibt jeder
// einen sinnvollen nächsten Schritt. Cinderella-Frage: Behandlungs-Erfahrung.
const sc = {
  kicker: 'Kostenloser Haut-Check',
  titel: 'Welche Behandlung passt zu Ihrer Haut?',
  intro: 'Sechs Fragen, kein Fachwissen nötig, in 2 Minuten. Sie bekommen eine ehrliche Einschätzung — und einen konkreten ersten Schritt, ohne sich gleich festzulegen.',
  meta: ['6 Fragen', 'ca. 2 Minuten', 'Sofort-Empfehlung'],
  startLabel: 'Los geht\'s',
  note: 'Entwickelt mit unseren Kosmetiker:innen — ersetzt keine Hautanalyse vor Ort, gibt Ihnen aber eine erste Richtung.',
  fragen: [
    { q: 'Was beschäftigt Sie an Ihrer Haut gerade am meisten?', a: [ { t: 'Erste Falten oder Volumenverlust', p: 3 }, { t: 'Unreinheiten oder Pigmentflecken', p: 2 }, { t: 'Nichts Akutes — ich möchte gepflegt bleiben', p: 1 } ] },
    { q: 'Wie würden Sie Ihren Hauttyp beschreiben?', a: [ { t: 'Trocken oder spannt nach dem Waschen', p: 2 }, { t: 'Mischhaut / glänzt in der T-Zone', p: 2 }, { t: 'Sensibel, reagiert schnell auf Pflege', p: 3 } ] },
    { q: 'Wie oft pflegen Sie Ihre Haut gezielt?', a: [ { t: 'Tägliche Routine, ich kenne meine Haut gut', p: 1 }, { t: 'Wenn ich dran denke', p: 2 }, { t: 'Eigentlich gar nicht — ich fange jetzt an', p: 3 } ] },
    { q: 'Hatten Sie bereits eine professionelle Behandlung?', a: [ { t: 'Ja, regelmäßig (Maintenance)', p: 1 }, { t: 'Vor längerer Zeit, ist her', p: 2 }, { t: 'Nein, wäre das erste Mal', p: 3 } ] },
    { q: 'Was ist Ihnen bei einer Behandlung am wichtigsten?', a: [ { t: 'Sichtbares Ergebnis nach Plan', p: 3 }, { t: 'Natürlich aussehen, nichts erkennbar Gemachtes', p: 2 }, { t: 'Entspannung und Wohlfühlen', p: 1 } ] },
    { q: 'Wann möchten Sie am liebsten starten?', a: [ { t: 'So bald wie möglich', p: 3 }, { t: 'In den nächsten Wochen', p: 2 }, { t: 'Ich informiere mich erst mal in Ruhe', p: 1 } ] },
  ],
  leadTitel: 'Wohin schicken wir Ihre Empfehlung?',
  leadSub: 'Ihr Ergebnis sehen Sie sofort. Kein Spam, versprochen — wir melden uns nur, wenn Sie es wünschen.',
  tiers: [
    { min: 0,  label: 'Maintenance-Typ — gepflegt halten', msg: 'Sie kennen Ihre Haut und tun ihr gutes. Ein Gesichtsbehandlung im Quartal oder ein gezieltes Peeling als Routine reichen meistens aus. Eine kurze Beratung zeigt, wo eventuell noch ein Hebel ist — ohne Verkaufsdruck.' },
    { min: 50, label: 'Gezieltes Anliegen — Behandlungsplan sinnvoll', msg: 'Ihre Antworten zeigen ein konkretes Thema, das sich mit 2–4 Sitzungen sehr gut angehen lässt (Microneedling, Peeling oder eine kombinierte Routine). Erstgespräch buchen — wir prüfen ehrlich, ob unser Vorgehen zu Ihnen passt.' },
    { min: 80, label: 'Erstanalyse empfohlen — wir starten ruhig', msg: 'Ihre Haut hat aktuell mehrere Themen, oder Sie sind ganz neu. Genau dafür ist das kostenlose Erstgespräch da: Hautanalyse, ehrliche Einschätzung, kein Druck. Wir empfehlen nur, was Sinn ergibt — manchmal ist das auch erstmal nur die Pflege-Routine zu Hause.' },
  ],
};
---
<!doctype html>
<html lang="de" style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{name}{slogan ? ` — ${slogan}` : ''}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      /* Markenfarbe sparsam — abgeleitete Töne via color-mix */
      --c-primary-dark: color-mix(in srgb, var(--c-primary) 72%, black);
      --c-wash:         color-mix(in srgb, var(--c-primary) 5%, white);
      --c-soft:         color-mix(in srgb, var(--c-primary) 11%, white);
      --c-line-brand:   color-mix(in srgb, var(--c-primary) 24%, transparent);
      --c-glow:         color-mix(in srgb, var(--c-primary) 26%, transparent);

      /* Neutrale Design-Farben — fix, NICHT aus der Config */
      --ink:    #1a1626;
      --body:   #4a4456;
      --muted:  #6b6577;
      --faint:  #9b96a3;
      --line:   #ebe6ee;
      --line-2: #d9d3df;
      --surface:#ffffff;
      --paper:  #faf8f5;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: clip; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      color: var(--body); background: var(--paper);
      -webkit-font-smoothing: antialiased; line-height: 1.62;
      overflow-x: clip; overscroll-behavior-x: none;
    }
    h1, h2, h3 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      color: var(--ink); line-height: 1.14; letter-spacing: -0.01em;
      font-weight: 600;
    }
    a { color: inherit; }
    img { max-width: 100%; display: block; }

    .wrap { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }
    .ico { display: inline-flex; }
    .ico svg { width: 1.15em; height: 1.15em; display: block; }

    .eyebrow {
      display: inline-block; font-family: 'Inter', sans-serif;
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--c-primary-dark);
    }
    .lead { color: var(--muted); font-size: 1.06rem; line-height: 1.72; }

    /* Buttons — Touch-Target ≥ 48px */
    .btn {
      display: inline-flex; align-items: center; gap: 0.55rem;
      padding: 0.85rem 1.6rem; border-radius: 100px;
      font-family: 'Inter', sans-serif;
      font-size: 0.92rem; font-weight: 600; text-decoration: none;
      min-height: 48px; cursor: pointer; border: 1.5px solid transparent;
      letter-spacing: 0.01em;
      transition: background 0.18s, border-color 0.18s, color 0.18s, transform 0.18s;
    }
    .btn-primary { background: var(--c-primary); color: #fff; }
    .btn-primary:hover { background: var(--c-primary-dark); transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--ink); border-color: var(--line-2); }
    .btn-ghost:hover { border-color: var(--ink); }
    .btn .ico svg { width: 1.05em; height: 1.05em; }

    /* ─────────── [Nav] Studio Bar ─────────── */
    .demo-banner {
      background: var(--ink); color: #c4bdcf;
      text-align: center; padding: 0.6rem 1.5rem;
      font-size: 0.78rem; line-height: 1.5;
    }
    .demo-banner a { color: #fff; text-decoration: none; font-weight: 600; }
    .demo-banner .dot { color: color-mix(in srgb, var(--c-primary) 60%, white); }
    .demo-banner .cta {
      display: inline-block; margin-left: 0.6rem;
      background: var(--c-primary); color: #fff;
      padding: 0.2rem 0.7rem; border-radius: 100px; font-weight: 600;
    }

    .nav {
      position: sticky; top: 0; z-index: 50;
      background: color-mix(in srgb, var(--paper) 92%, transparent);
      -webkit-backdrop-filter: blur(9px); backdrop-filter: blur(9px);
      border-bottom: 1px solid var(--line);
    }
    .nav-inner {
      padding: 0.85rem clamp(1.25rem, 4vw, 3rem);
      display: flex; align-items: center; gap: 1.5rem; flex-wrap: nowrap;
    }
    .brand {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem; font-weight: 600; color: var(--ink);
      text-decoration: none; letter-spacing: 0.01em;
      white-space: nowrap; flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.5rem;
    }
    .brand .mark { color: var(--c-primary); display: inline-flex; }
    .brand .mark svg { width: 1.25rem; height: 1.25rem; }
    .brand span { color: var(--c-primary); font-style: italic; }
    .brand img { height: 52px; width: auto; display: block; }
    .nav-links {
      display: flex; align-items: center; gap: 1.6rem; list-style: none;
      margin-left: auto;
    }
    .nav-links a {
      color: var(--body); text-decoration: none; white-space: nowrap;
      font-size: 0.9rem; font-weight: 500; padding: 0.4rem 0;
    }
    .nav-links a:hover { color: var(--c-primary); }
    .nav-actions { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
    .nav-call {
      display: inline-flex; align-items: center; gap: 0.45rem;
      color: var(--ink); text-decoration: none; font-weight: 600;
      font-size: 0.9rem; min-height: 44px; white-space: nowrap;
    }
    .nav-call:hover { color: var(--c-primary); }
    .nav-cta {
      background: var(--c-primary); color: #fff; text-decoration: none;
      padding: 0 1.2rem; border-radius: 100px; white-space: nowrap;
      font-size: 0.88rem; font-weight: 600; min-height: 44px;
      display: inline-flex; align-items: center;
    }
    .nav-cta:hover { background: var(--c-primary-dark); }
    .menu { display: none; }
    .menu > summary { list-style: none; }
    .menu > summary::-webkit-details-marker { display: none; }
    .burger {
      width: 46px; height: 46px; border: 1px solid var(--line-2);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      color: var(--ink); cursor: pointer;
    }
    .menu-panel { display: none; }

    /* ─────────── [Hero] Studio Open — Vollbild-Video-Reel ─────────── */
    .cine {
      position: relative; min-height: 92vh; min-height: 92svh;
      display: flex; align-items: flex-end;
      overflow: hidden; background: var(--ink); isolation: isolate;
    }
    .cine-bg { position: absolute; inset: 0; z-index: 0; }
    .cine-poster, .cine-vid {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; display: block;
    }
    .cine-poster { z-index: 0; }
    .cine-vid {
      z-index: 1; opacity: 0;
      transition: opacity 1.1s ease; will-change: opacity;
    }
    .cine-vid.on { opacity: 1; }
    .cine-bg::before {
      content: ''; position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background: radial-gradient(ellipse 58% 58% at 82% 14%,
        var(--c-glow) 0%, transparent 60%);
    }
    .cine-bg::after {
      content: ''; position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background:
        linear-gradient(to top, rgba(15,10,22,0.86) 0%, rgba(15,10,22,0.28) 46%, rgba(15,10,22,0.14) 100%),
        linear-gradient(to right, rgba(15,10,22,0.55) 0%, rgba(15,10,22,0.10) 60%, transparent 100%);
    }
    .cine-inner {
      position: relative; z-index: 3; width: 100%;
      max-width: 1140px; margin: 0 auto;
      padding: clamp(3rem, 8vw, 6rem) 1.5rem clamp(3.5rem, 7vw, 5.5rem);
    }
    .cine-stage { max-width: 40rem; }
    .cine .eyebrow {
      color: #fff; background: color-mix(in srgb, var(--c-primary) 55%, transparent);
      padding: 0.36rem 0.9rem; border-radius: 100px;
      -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    }
    /* [Hero] Brand H1 — universeller 3-zeiliger Block: sub · name · tag */
    .cine h1 { margin: 0.6rem 0 1.1rem; display: flex; flex-direction: column; gap: 0.35rem; max-width: 18ch; }
    .cine h1 .h1-sub {
      font-family: var(--font-display); font-style: italic;
      font-size: clamp(1rem, 1.5vw, 1.25rem); font-weight: 400;
      letter-spacing: 0.01em; color: rgba(255,255,255,0.82); line-height: 1.2;
    }
    .cine h1 .h1-name {
      color: #fff; font-size: clamp(2.6rem, 6.6vw, 5rem);
      font-weight: 600; letter-spacing: -0.01em; line-height: 1.04;
    }
    .cine h1 .h1-tag {
      align-self: flex-start; font-family: var(--font-body);
      font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: rgba(255,255,255,0.7); margin-top: 0.45rem;
    }
    .cine-lead {
      color: rgba(255,255,255,0.84); line-height: 1.7;
      font-size: clamp(1rem, 1.5vw, 1.15rem); max-width: 34rem;
    }
    /* [Hero] Brand Mark — Logo linksbündig über der Headline (auf Video-Reel). */
    .cine-brand { display: inline-flex; align-items: center; margin-bottom: clamp(0.75rem, 1.6vw, 1.25rem); }
    .cine-brand img {
      height: clamp(44px, 5.5vw, 68px); width: auto; max-width: min(240px, 62vw);
      filter: drop-shadow(0 2px 18px rgba(0,0,0,0.5));
    }
    @media (max-width: 480px) {
      .cine-brand img { height: 42px; max-width: 180px; }
    }
    .cine-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2.1rem; }
    .btn-glass {
      background: rgba(255,255,255,0.10); color: #fff;
      border-color: rgba(255,255,255,0.34);
      -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    }
    .btn-glass:hover { background: rgba(255,255,255,0.18); border-color: #fff; }
    .cine-rating {
      display: inline-flex; align-items: center; gap: 0.6rem;
      margin-top: 1.6rem; font-size: 0.92rem; color: rgba(255,255,255,0.78);
    }
    .cine-rating .stars { display: inline-flex; gap: 1px; color: #fff; }
    .cine-rating .stars .ico svg { width: 1rem; height: 1rem; }
    .cine-rating b { color: #fff; font-weight: 700; }
    .cine-scroll {
      position: absolute; left: 50%; bottom: 1.3rem; transform: translateX(-50%);
      z-index: 3; display: flex; flex-direction: column; align-items: center;
      gap: 0.45rem; text-decoration: none;
      color: rgba(255,255,255,0.72); font-size: 0.62rem;
      letter-spacing: 0.22em; text-transform: uppercase;
    }
    .cine-scroll i {
      display: block; width: 1px; height: 34px;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.85));
      animation: cineScroll 2s ease-in-out infinite;
    }
    @keyframes cineScroll {
      0%, 100% { opacity: 0.3; transform: scaleY(1); }
      50%      { opacity: 0.9; transform: scaleY(1.18); }
    }
    @media (prefers-reduced-motion: reduce) {
      .cine-vid { transition: none; }
      .cine-scroll i { animation: none; }
    }

    /* ─────────── [Vertrauen] Assurance Bar ─────────── */
    .assure { background: var(--c-wash); border-top: 1px solid var(--line); }
    .assure-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: center; }
    .assure-lead h2 { font-size: clamp(1.8rem, 3.4vw, 2.6rem); line-height: 1.16; color: var(--ink); margin: 0.5rem 0 0.8rem; }
    .assure-lead p { color: var(--body); font-size: 1rem; line-height: 1.68; max-width: 40ch; }
    .assure-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.7rem; }
    .assure-points { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.85rem; }
    .assure-points li { display: flex; gap: 0.85rem; align-items: flex-start; background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 1.05rem 1.2rem; }
    .assure-points .ico { color: var(--c-primary); flex: none; margin-top: 0.05rem; }
    .assure-points .ico svg { width: 1.15rem; height: 1.15rem; }
    .assure-points b { display: block; font-family: 'Inter', sans-serif; color: var(--ink); font-size: 0.98rem; font-weight: 600; margin-bottom: 0.2rem; }
    .assure-points .ap-txt { color: var(--body); font-size: 0.9rem; line-height: 1.55; }
    @media (max-width: 820px) {
      .assure-grid { grid-template-columns: 1fr; gap: 1.9rem; }
      .assure-lead p { max-width: none; }
    }

    /* ─────────── [Trust] Endless Marquee ─────────── */
    .trust {
      border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
      background: var(--surface); overflow: hidden;
    }
    .trust-mask {
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
              mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    }
    .trust-track {
      display: flex; width: max-content;
      animation: trustScroll 34s linear infinite;
    }
    .trust:hover .trust-track { animation-play-state: paused; }
    .trust-item {
      display: flex; align-items: center; gap: 0.6rem; flex: none;
      padding: 1.35rem 0; margin-right: 3rem; white-space: nowrap;
      font-size: 0.95rem; font-weight: 600; color: var(--body);
    }
    .trust-item .ico { color: var(--c-primary); }
    .trust-item .ico svg { width: 1.05rem; height: 1.05rem; }
    @keyframes trustScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .trust-mask { -webkit-mask-image: none; mask-image: none; }
      .trust-track {
        animation: none; width: auto;
        flex-wrap: wrap; justify-content: center;
        gap: 0.5rem 2.5rem; padding: 1.1rem 1.5rem;
      }
      .trust-item { margin-right: 0; padding: 0; }
      .trust-item[aria-hidden="true"] { display: none; }
    }

    /* ─────────── [Trust] Brand Marquee — Endless-Scroll Premium-Marken ───────────
       Doppelter Track für seamless Loop, CSS-Maske als Edge-Fade,
       paused-on-hover, Logos monochromiert + Opacity-Lift bei Hover. */
    .bm {
      padding: 3rem 0 3.25rem;
      background: var(--c-wash);
      border-bottom: 1px solid var(--line);
      overflow: hidden;
    }
    .bm-head {
      text-align: center;
      font-family: 'Inter', sans-serif;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: color-mix(in srgb, var(--c-primary-dark) 70%, transparent);
      margin: 0 0 1.85rem;
    }
    .bm-mask {
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
              mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    }
    .bm-track {
      display: flex; width: max-content;
      animation: bmScroll 50s linear infinite;
      align-items: center;
    }
    .bm:hover .bm-track { animation-play-state: paused; }
    .bm-item {
      flex: none;
      padding: 0 2.6rem;
      display: flex; align-items: center; justify-content: center;
      height: 54px;
    }
    .bm-logo {
      max-height: 100%;
      width: auto;
      max-width: 160px;
      object-fit: contain;
      opacity: 0.6;
      filter: grayscale(100%);
      transition: opacity 0.3s ease, filter 0.3s ease;
    }
    .bm-item:hover .bm-logo { opacity: 1; filter: grayscale(0); }
    @keyframes bmScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (max-width: 767px) {
      .bm { padding: 2.4rem 0 2.6rem; }
      .bm-head { font-size: 0.65rem; margin-bottom: 1.4rem; }
      .bm-item { padding: 0 1.85rem; height: 42px; }
      .bm-logo { max-width: 120px; opacity: 0.7; }
      .bm-track { animation-duration: 38s; }
    }
    @media (prefers-reduced-motion: reduce) {
      .bm-mask { -webkit-mask-image: none; mask-image: none; }
      .bm-track {
        animation: none; width: auto;
        flex-wrap: wrap; justify-content: center;
        gap: 1.25rem 2.25rem; padding: 0 1.5rem;
      }
      .bm-item { padding: 0; }
      .bm-item[aria-hidden="true"] { display: none; }
    }

    /* ─────────── [Showcase] Insta Reel Strip — vertikale Reel-Tiles ───────────
       Horizontaler scroll-snap (touch-native), Lazy-Load + autoplay-on-scroll
       per IntersectionObserver (siehe Controller-Script unten). Mobile-First. */
    .rs-sec {
      padding: 4rem 0 4.5rem;
      background: var(--ink); color: var(--paper);
      position: relative; isolation: isolate; overflow: hidden;
    }
    .rs-sec::before {
      content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse 60% 50% at 30% 20%, var(--c-glow) 0%, transparent 65%);
    }
    .rs-sec > * { position: relative; z-index: 1; }
    .rs-head { text-align: center; margin: 0 auto 2.4rem; max-width: 40rem; padding: 0 1.5rem; }
    .rs-head .eyebrow { color: color-mix(in srgb, var(--c-primary) 50%, #fff); }
    .rs-head h2 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); margin: 0.4rem 0 0.7rem; }
    .rs-head h2 em { color: color-mix(in srgb, var(--c-accent) 80%, #fff); font-style: italic; }
    .rs-head p { color: rgba(255,255,255,0.7); font-family: 'Inter', sans-serif; font-size: 0.95rem; line-height: 1.65; max-width: 32rem; margin: 0 auto; }

    .rs-strip {
      display: flex;
      gap: 0.6rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0.5rem 1.25rem 1rem;
      scrollbar-width: none;
      scroll-padding-inline: 1.25rem;
    }
    .rs-strip::-webkit-scrollbar { display: none; }

    .rs-tile {
      flex: 0 0 auto;
      width: 260px; aspect-ratio: 9 / 16;
      border-radius: 20px; overflow: hidden;
      position: relative;
      scroll-snap-align: start;
      background: #1a0e14;
      box-shadow: 0 20px 50px -18px rgba(0,0,0,0.6);
      transition: transform 0.3s ease;
    }
    .rs-tile:hover { transform: translateY(-3px); }
    .rs-tile .rs-poster,
    .rs-tile video {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
    }
    .rs-tile .rs-poster {
      transition: opacity 0.5s ease;
      z-index: 1;
    }
    .rs-tile video { z-index: 0; opacity: 0; transition: opacity 0.5s ease; }
    .rs-tile.is-playing video { opacity: 1; }
    .rs-tile.is-playing .rs-poster { opacity: 0; }
    .rs-tile .rs-overlay {
      position: absolute; left: 0; right: 0; bottom: 0;
      padding: 1.4rem 1.15rem 1.15rem;
      background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.55) 50%, rgba(0,0,0,0.85) 100%);
      z-index: 2;
      color: #fff;
    }
    .rs-tile .rs-eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: rgba(255,255,255,0.78);
      margin-bottom: 0.35rem;
    }
    .rs-tile .rs-titel {
      font-size: 1.18rem; font-weight: 500;
      font-style: italic;
      letter-spacing: -0.005em;
      line-height: 1.2;
    }

    @media (min-width: 768px) {
      .rs-sec { padding: 5rem 0 5.5rem; }
      .rs-strip {
        gap: 0.75rem;
        padding: 0.5rem clamp(1.5rem, 5vw, 4rem) 1rem;
        scroll-padding-inline: clamp(1.5rem, 5vw, 4rem);
      }
      .rs-tile { width: 300px; }
      .rs-tile .rs-overlay { padding: 1.6rem 1.4rem 1.35rem; }
      .rs-tile .rs-titel { font-size: 1.32rem; }
    }
    @media (min-width: 1280px) {
      .rs-tile { width: 320px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .rs-tile.is-playing video { opacity: 0; } /* keep posters */
      .rs-tile.is-playing .rs-poster { opacity: 1; }
    }

    /* ─────────── Section base ─────────── */
    section { padding: 5.5rem 0; }
    section { scroll-margin-top: 80px; }
    .sec-head { max-width: 40rem; margin-bottom: 3.25rem; }
    .sec-head h2 {
      font-size: clamp(2rem, 3.8vw, 3rem); font-weight: 600;
      margin: 0.85rem 0 0.85rem; line-height: 1.14;
    }
    .sec-head h2 em { font-style: italic; color: var(--c-primary); font-weight: 400; }
    .sec-head p { color: var(--muted); font-size: 1.02rem; line-height: 1.68; font-family: 'Inter', sans-serif; }

    .reveal {
      opacity: 0; transform: translateY(22px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* ─────────── [Leistungen] Section wrapper — Inhalt = VerticalReel-Komponente ─────────── */
    .ang-sec { background: var(--surface); border-top: 1px solid var(--line); }

    /* ─────────── [Ergebnisse] Vorher/Nachher — das Showpiece (statt 3D) ───────────
       Dunkler Hintergrund, große Karten, klare Vorher/Nachher-Spaltung.
       Conversion-Hebel #2 aus zielgruppen.md §5: Vorher/Nachher prominent, aber ehrlich
       — wir zeigen konkrete Versprechen (Sitzungen, Zeitraum), keine inszenierten Bilder. */
    .vn-sec { background: var(--ink); color: var(--paper); }
    .vn-sec::before {
      content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse 58% 56% at 75% 30%, var(--c-glow) 0%, transparent 62%);
    }
    .vn-sec { position: relative; isolation: isolate; }
    .vn-sec .wrap { position: relative; z-index: 1; }
    .vn-sec .sec-head { max-width: none; text-align: center; margin: 0 auto 3.5rem; }
    .vn-sec .sec-head h2 { color: #fff; font-size: clamp(2.2rem, 4.2vw, 3.4rem); }
    .vn-sec .sec-head h2 em { color: color-mix(in srgb, var(--c-accent) 80%, #fff); }
    .vn-sec .sec-head .eyebrow { color: color-mix(in srgb, var(--c-primary) 50%, #fff); }
    .vn-sec .sec-head p { color: rgba(255,255,255,0.7); max-width: 40rem; margin: 0.85rem auto 0; }

    /* [Ergebnisse] Cinema Split-Reel — 3D-Perspektiv-Karussell mit drag-baren Splits.
       Mittlere Karte groß, Nachbarn skaliert + rotateY + blur. Auto-Rotate, Pause auf Interaktion. */
    .vn-reel-wrap { position: relative; }
    .vn-reel {
      position: relative; width: 100%; height: 560px;
      display: flex; align-items: center; justify-content: center;
      perspective: 1400px;
      user-select: none; -webkit-user-select: none;
      touch-action: pan-y;
    }
    .vn-stage { position: relative; width: 100%; height: 100%; transform-style: preserve-3d; }
    .vn-slide {
      position: absolute; left: 50%; top: 50%;
      width: 340px; height: 510px;
      margin: -255px 0 0 -170px;
      border-radius: 24px; overflow: hidden;
      box-shadow: 0 32px 80px -20px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.08);
      transition: transform 0.65s cubic-bezier(0.22,1,0.36,1), opacity 0.5s ease, filter 0.5s ease;
      background: #1a0e14;
      pointer-events: none;
      will-change: transform;
    }
    .vn-slide[data-pos="0"]  { transform: translate3d(0,0,0) rotateY(0) scale(1); z-index: 30; opacity: 1; filter: blur(0); pointer-events: auto; }
    .vn-slide[data-pos="-1"] { transform: translate3d(-62%, 0, -140px) rotateY(22deg) scale(0.82); z-index: 20; opacity: 0.5; filter: blur(2.5px); }
    .vn-slide[data-pos="1"]  { transform: translate3d(62%, 0, -140px) rotateY(-22deg) scale(0.82); z-index: 20; opacity: 0.5; filter: blur(2.5px); }
    .vn-slide[data-pos="-2"] { transform: translate3d(-95%, 0, -260px) rotateY(30deg) scale(0.62); z-index: 10; opacity: 0; filter: blur(5px); }
    .vn-slide[data-pos="2"]  { transform: translate3d(95%, 0, -260px) rotateY(-30deg) scale(0.62); z-index: 10; opacity: 0; filter: blur(5px); }
    .vn-slide[data-pos="hidden"] { opacity: 0; }

    .vn-split { position: relative; width: 100%; height: 100%; overflow: hidden; --split: 50%; }
    .vn-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .vn-veil {
      position: absolute; inset: 0;
      clip-path: inset(0 calc(100% - var(--split)) 0 0);
      -webkit-clip-path: inset(0 calc(100% - var(--split)) 0 0);
      filter: saturate(0.78) brightness(0.92) contrast(0.95);
    }
    .vn-bg-img { width: 100%; height: 100%; }

    .vn-tag {
      position: absolute; top: 18px;
      font-family: 'Inter', sans-serif; font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      padding: 0.34rem 0.72rem; border-radius: 100px;
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      z-index: 2; pointer-events: none;
    }
    .vn-tag--vorher  { left: 18px; background: rgba(20,10,15,0.55); color: #f0c1cf; border: 1px solid rgba(231,163,184,0.4); }
    .vn-tag--nachher { right: 18px; background: rgba(10,20,18,0.55); color: #aef1dd; border: 1px solid rgba(130,216,192,0.4); }

    .vn-meta-bar {
      position: absolute; left: 0; right: 0; bottom: 0;
      padding: 1.6rem 1.4rem 1.35rem;
      color: #fff; z-index: 2; pointer-events: none;
      background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.55) 45%, rgba(0,0,0,0.78) 100%);
    }
    .vn-meta-bar h3 { font-size: 1.32rem; font-weight: 600; margin: 0 0 0.18rem; color: #fff; line-height: 1.2; }
    .vn-meta-bar .vn-sit { font-family: 'Inter', sans-serif; font-size: 0.72rem; color: rgba(255,255,255,0.78); letter-spacing: 0.02em; }

    .vn-handle {
      position: absolute; top: 0; bottom: 0;
      width: 3px; left: var(--split);
      transform: translateX(-50%);
      background: rgba(255,255,255,0.92);
      box-shadow: 0 0 22px rgba(255,255,255,0.55);
      cursor: ew-resize;
      z-index: 3;
      border: 0; padding: 0;
      touch-action: none;
    }
    .vn-handle::after {
      content: ''; position: absolute; left: 50%; top: 50%;
      width: 44px; height: 44px; margin: -22px 0 0 -22px;
      border-radius: 50%;
      background: rgba(255,255,255,0.96);
      box-shadow: 0 6px 24px rgba(0,0,0,0.4), 0 0 0 1px rgba(0,0,0,0.06);
    }
    .vn-handle-grip {
      position: absolute; left: 50%; top: 50%;
      width: 30px; height: 30px; margin: -15px 0 0 -15px;
      z-index: 1;
      display: flex; align-items: center; justify-content: center;
      gap: 2px;
      color: var(--c-primary-dark);
      pointer-events: none;
    }
    .vn-handle-grip svg { width: 18px; height: 18px; }

    .vn-nav {
      position: absolute; top: 50%;
      width: 48px; height: 48px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.2);
      background: rgba(20,10,15,0.55);
      backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      z-index: 40;
      transition: background 0.2s ease, transform 0.2s ease;
      padding: 0;
    }
    .vn-nav svg { width: 22px; height: 22px; }
    .vn-nav:hover { background: rgba(40,20,25,0.78); }
    .vn-nav:focus-visible { outline: 2px solid rgba(255,255,255,0.6); outline-offset: 3px; }
    .vn-nav--prev { left: clamp(0.25rem, 2vw, 1.5rem); transform: translateY(-50%); }
    .vn-nav--next { right: clamp(0.25rem, 2vw, 1.5rem); transform: translateY(-50%); }
    .vn-nav--prev:hover { transform: translateY(-50%) scale(1.06); }
    .vn-nav--next:hover { transform: translateY(-50%) scale(1.06); }

    .vn-dots {
      display: flex; gap: 0.65rem; justify-content: center;
      margin-top: 1.6rem;
    }
    .vn-dot {
      width: 9px; height: 9px; border-radius: 50%;
      background: rgba(255,255,255,0.22);
      border: 0; padding: 0; cursor: pointer;
      transition: background 0.2s ease, transform 0.2s ease;
    }
    .vn-dot.is-active { background: #fff; transform: scale(1.3); }
    .vn-dot:focus-visible { outline: 2px solid rgba(255,255,255,0.6); outline-offset: 3px; }

    @media (max-width: 767px) {
      .vn-reel { height: 480px; }
      .vn-slide { width: 270px; height: 410px; margin: -205px 0 0 -135px; border-radius: 20px; }
      .vn-slide[data-pos="-1"] { transform: translate3d(-52%, 0, -110px) rotateY(20deg) scale(0.72); opacity: 0.3; }
      .vn-slide[data-pos="1"]  { transform: translate3d(52%, 0, -110px) rotateY(-20deg) scale(0.72); opacity: 0.3; }
      .vn-meta-bar { padding: 1.4rem 1.15rem 1.15rem; }
      .vn-meta-bar h3 { font-size: 1.18rem; }
      .vn-nav { width: 44px; height: 44px; }
      .vn-tag { font-size: 0.58rem; padding: 0.3rem 0.62rem; top: 14px; }
      .vn-tag--vorher  { left: 14px; }
      .vn-tag--nachher { right: 14px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .vn-slide { transition: opacity 0.3s ease; }
    }

    .vn-cta-row { text-align: center; margin-top: 2.75rem; }
    .vn-cta-row .btn-primary { background: #fff; color: var(--c-primary-dark); }
    .vn-cta-row .btn-primary:hover { background: var(--c-accent); color: #fff; }
    .vn-disclaimer {
      font-family: 'Inter', sans-serif; font-size: 0.74rem;
      color: rgba(255,255,255,0.5); text-align: center;
      margin-top: 1rem; line-height: 1.55;
    }

    /* ─────────── [Ablauf] Step Sequence ─────────── */
    .ablauf-sec { background: var(--surface); border-top: 1px solid var(--line); }
    .ablauf-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem 1.25rem;
    }
    .ablauf-step {
      position: relative; padding: 1.6rem 1.4rem 1.6rem 1.7rem;
      background: var(--surface); border: 1px solid var(--line); border-radius: 14px;
    }
    .ablauf-step::before {
      content: ''; position: absolute; left: 0; top: 1.6rem; bottom: 1.6rem;
      width: 3px; background: var(--c-line-brand); border-radius: 3px;
    }
    .ablauf-nr {
      font-family: 'Inter', sans-serif;
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--c-primary);
      margin-bottom: 0.45rem;
    }
    .ablauf-step h3 { font-size: 1.3rem; font-weight: 600; margin-bottom: 0.4rem; }
    .ablauf-step p { font-family: 'Inter', sans-serif; color: var(--body); font-size: 0.94rem; line-height: 1.62; }

    /* ─────────── [Team] Portrait Strip — Elaris-Style Präsentation ───────────
       Tall Portrait-Fotos in horizontalem Scroll-Snap-Strip, Name (Serif) + Rolle (Caps Eyebrow)
       + Bio darunter. Kein Avatar-Rund, kein Initialen-Fallback — Foto oder Mono-Plate. */
    .tm-sec { background: var(--c-wash); border-top: 1px solid var(--line); padding: 5.5rem 0 4.5rem; }
    .tm-strip {
      display: flex;
      gap: 0.5rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0.5rem clamp(1.25rem, 5vw, 3rem) 1rem;
      scrollbar-width: none;
      scroll-padding-inline: clamp(1.25rem, 5vw, 3rem);
      margin: 0 calc(-1 * clamp(1.25rem, 5vw, 3rem));
    }
    .tm-strip::-webkit-scrollbar { display: none; }

    .tm-card {
      flex: 0 0 auto;
      width: 250px;
      scroll-snap-align: start;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 0;
      display: flex; flex-direction: column;
    }
    .tm-photo {
      width: 100%; aspect-ratio: 4 / 5;
      background: linear-gradient(135deg, color-mix(in srgb, var(--c-primary) 25%, var(--c-wash)) 0%, color-mix(in srgb, var(--c-accent) 15%, var(--c-wash)) 100%);
      overflow: hidden;
      position: relative;
    }
    .tm-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .tm-init {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 4rem; color: rgba(255,255,255,0.85);
      letter-spacing: 0.04em;
    }
    .tm-body {
      padding: 1.4rem 1.25rem 1.6rem;
      flex: 1;
      display: flex; flex-direction: column;
    }
    .tm-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.55rem; font-weight: 500;
      color: var(--ink);
      line-height: 1.15; margin: 0 0 0.5rem;
    }
    .tm-role {
      font-family: 'Inter', sans-serif;
      font-size: 0.66rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--c-primary-dark);
      margin: 0 0 0.85rem;
    }
    .tm-bio {
      font-family: 'Inter', sans-serif;
      font-size: 0.86rem; line-height: 1.6;
      color: var(--body);
      margin: 0;
    }

    @media (min-width: 768px) {
      .tm-card { width: 290px; }
      .tm-name { font-size: 1.75rem; }
    }
    @media (min-width: 1280px) {
      .tm-card { width: 320px; }
    }

    /* ─────────── [Stimmen] Quote Wall ─────────── */
    .stimmen-sec { background: var(--surface); border-top: 1px solid var(--line); }
    .bew-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.25rem;
    }
    .bew-card {
      border: 1px solid var(--line); border-left: 3px solid var(--c-primary);
      border-radius: 0 14px 14px 0; padding: 1.85rem; background: var(--paper);
    }
    .bew-stars { display: inline-flex; gap: 2px; color: var(--c-primary); margin-bottom: 1rem; }
    .bew-stars .ico svg { width: 1rem; height: 1rem; }
    .bew-card p {
      font-family: 'Cormorant Garamond', serif;
      color: var(--ink); font-size: 1.15rem; line-height: 1.55; margin-bottom: 1.1rem; font-style: italic;
    }
    .bew-name { font-family: 'Inter', sans-serif; font-size: 0.84rem; font-weight: 600; color: var(--c-primary); letter-spacing: 0.02em; }

    /* ─────────── [Scorecard] Self-Check ─────────── */
    .sc { background: var(--c-wash); border-top: 1px solid var(--line); }
    .sc-card { max-width: 620px; margin: 0 auto; background: var(--surface); border: 1px solid var(--line); border-radius: 18px; padding: clamp(1.5rem, 4vw, 2.75rem); position: relative; overflow: hidden; }
    .sc-progress { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--line); }
    .sc-progress > i { display: block; height: 100%; width: 0; background: var(--c-primary); transition: width 0.4s ease; }
    .sc-step { animation: scIn 0.32s ease; }
    @keyframes scIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .sc-step h2 { font-size: clamp(1.7rem, 3.4vw, 2.4rem); color: var(--ink); line-height: 1.18; margin: 0.4rem 0 0.7rem; }
    .sc-step h3 { font-size: clamp(1.25rem, 2.6vw, 1.6rem); color: var(--ink); line-height: 1.25; margin: 0.5rem 0 1.3rem; }
    .sc-intro { font-family: 'Inter', sans-serif; color: var(--body); line-height: 1.6; }
    .sc-meta { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem 0.7rem; margin: 1.1rem 0 1.6rem; padding: 0; }
    .sc-meta li { font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 600; color: var(--c-primary); background: var(--c-wash); border: 1px solid var(--line); border-radius: 100px; padding: 0.4rem 0.9rem; }
    .sc-start, .sc-reveal, .sc-cta { width: 100%; justify-content: center; }
    .sc-note { font-family: 'Inter', sans-serif; font-size: 0.78rem; color: var(--body); opacity: 0.78; margin-top: 1rem; }
    .sc-count { font-family: 'Inter', sans-serif; font-size: 0.76rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--c-primary); }
    .sc-qhead { margin-bottom: 0.5rem; }
    .sc-opts { display: grid; gap: 0.7rem; }
    .sc-opt { font-family: 'Inter', sans-serif; text-align: left; font-size: 0.98rem; font-weight: 600; color: var(--ink); background: var(--surface); border: 1.5px solid var(--line); border-radius: 12px; padding: 1rem 1.15rem; min-height: 52px; cursor: pointer; transition: border-color 0.15s, background 0.15s, transform 0.12s; }
    .sc-opt:hover { border-color: var(--c-primary); transform: translateY(-1px); }
    .sc-opt.is-sel { border-color: var(--c-primary); background: var(--c-wash); }
    .sc-back, .sc-restart { display: inline-block; margin-top: 1.3rem; background: none; border: none; color: var(--body); font: inherit; font-size: 0.85rem; cursor: pointer; text-decoration: underline; padding: 0.5rem 0.25rem; min-height: 44px; }
    .sc-field { margin-bottom: 1rem; }
    .sc-field label { font-family: 'Inter', sans-serif; display: block; font-size: 0.8rem; font-weight: 600; color: var(--body); margin-bottom: 0.35rem; }
    .sc-in { width: 100%; font-family: 'Inter', sans-serif; font-size: 1rem; color: var(--ink); background: var(--surface); border: 1.5px solid var(--line); border-radius: 10px; padding: 0.85rem 1rem; min-height: 48px; }
    .sc-in:focus { outline: none; border-color: var(--c-primary); }
    .sc-err { color: #c0392b; font-size: 0.85rem; margin: 0.2rem 0 1rem; }
    .sc-score { display: flex; align-items: baseline; gap: 0.5rem; margin: 0.6rem 0 0.5rem; }
    .sc-score b { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.8rem, 8vw, 4rem); color: var(--c-primary); line-height: 1; }
    .sc-score span { color: var(--body); font-size: 0.95rem; }
    .sc-tierbadge { display: inline-block; font-family: 'Inter', sans-serif; font-weight: 700; color: var(--ink); background: var(--c-wash); border: 1px solid var(--line); border-radius: 100px; padding: 0.45rem 1rem; margin-bottom: 1rem; }
    .sc-tiermsg { font-family: 'Inter', sans-serif; color: var(--body); line-height: 1.6; margin-bottom: 1.7rem; }
    @media (max-width: 520px) { .sc-card { border-radius: 14px; } }

    /* ─────────── [Kontakt] Split Form ─────────── */
    .kontakt-sec { background: var(--c-wash); border-top: 1px solid var(--line); }
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
    .kontakt-info h2 { font-size: clamp(2rem, 3.6vw, 2.8rem); font-weight: 600; margin-bottom: 1rem; }
    .kontakt-info h2 em { font-style: italic; color: var(--c-primary); font-weight: 400; }
    .kontakt-info > p { font-family: 'Inter', sans-serif; color: var(--muted); font-size: 1rem; line-height: 1.7; margin-bottom: 2rem; }
    .kontakt-list { display: flex; flex-direction: column; gap: 0.4rem; }
    .kontakt-list a, .kontakt-list div {
      display: flex; align-items: center; gap: 0.85rem;
      padding: 0.7rem 0; color: var(--body); text-decoration: none;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem; border-bottom: 1px solid var(--line);
    }
    .kontakt-list .ico { color: var(--c-primary); }
    .kontakt-list a:hover { color: var(--c-primary); }

    .form-card {
      background: var(--surface); border: 1px solid var(--line);
      border-radius: 18px; padding: 2rem;
    }
    .form-card h3 { font-size: 1.45rem; font-weight: 600; margin-bottom: 1.4rem; }
    .field { margin-bottom: 1rem; }
    .field label {
      font-family: 'Inter', sans-serif;
      display: block; font-size: 0.8rem; font-weight: 600;
      color: var(--ink); margin-bottom: 0.4rem;
    }
    .field input, .field select, .field textarea {
      width: 100%; padding: 0.75rem 0.9rem; min-height: 46px;
      background: var(--surface); border: 1px solid var(--line-2);
      border-radius: 10px; color: var(--ink); font-size: 0.95rem;
      font-family: 'Inter', sans-serif;
    }
    .field textarea { min-height: 92px; resize: vertical; }
    .field input:focus, .field select:focus, .field textarea:focus {
      outline: none; border-color: var(--c-primary);
      box-shadow: 0 0 0 3px var(--c-line-brand);
    }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
    .form-card .btn { width: 100%; justify-content: center; margin-top: 0.5rem; }
    .form-note { font-family: 'Inter', sans-serif; font-size: 0.78rem; color: var(--faint); margin-top: 0.9rem; text-align: center; }

    /* ─────────── [Footer] Minimal ─────────── */
    footer { background: var(--surface); border-top: 1px solid var(--line); padding: 2.5rem 0; }
    .foot-inner {
      display: flex; flex-wrap: wrap; justify-content: space-between;
      align-items: center; gap: 1rem; font-family: 'Inter', sans-serif;
      font-size: 0.85rem; color: var(--muted);
    }
    .foot-inner a { color: var(--muted); text-decoration: none; }
    .foot-inner a:hover { color: var(--c-primary); }
    .foot-links { display: flex; gap: 1.5rem; }
    .foot-credit { width: 100%; font-size: 0.78rem; color: var(--faint);
      border-top: 1px solid var(--line); padding-top: 1.25rem; margin-top: 0.5rem; }
    .foot-credit a { color: var(--c-primary); font-weight: 500; }

    /* ─────────── [Sticky] Mobile CTA Bar — fix unten, Anrufen + WhatsApp ───────────
       Sichtbar erst NACHDEM Hero raus-gescrollt ist (Visibility-Toggle per JS).
       Auf Desktop komplett display:none. Safe-Area-Inset für iPhone-Notch-Geräte. */
    .sticky-cta {
      position: fixed; left: 0; right: 0; bottom: 0;
      z-index: 60;
      display: none;
      gap: 0.55rem;
      padding: 0.55rem 0.6rem calc(0.55rem + env(safe-area-inset-bottom, 0px));
      background: var(--surface);
      border-top: 1px solid var(--line);
      box-shadow: 0 -8px 24px rgba(15,10,22,0.10);
      transform: translateY(110%);
      transition: transform 0.32s cubic-bezier(.22,.61,.36,1);
    }
    .sticky-cta[data-visible="true"] { transform: translateY(0); }
    .sticky-cta-btn {
      flex: 1;
      min-height: 52px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 0.55rem;
      border-radius: 14px;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem; font-weight: 600;
      letter-spacing: 0.01em;
      text-decoration: none;
      color: #fff;
      transition: filter 0.18s ease, transform 0.12s ease;
    }
    .sticky-cta-btn:active { transform: scale(0.97); }
    .sticky-cta-btn .ico svg { width: 1.15rem; height: 1.15rem; }
    .sticky-cta-call { background: var(--c-primary); }
    .sticky-cta-call:hover { background: var(--c-primary-dark); }
    .sticky-cta-wa { background: #25D366; }
    .sticky-cta-wa:hover { filter: brightness(0.95); }
    @media (max-width: 767px) {
      .sticky-cta { display: flex; }
      body { padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px)); }
    }
    @media (prefers-reduced-motion: reduce) {
      .sticky-cta { transition: none; }
    }

    /* ─────────── Mobile First ─────────── */
    @media (max-width: 1080px) {
      .nav-call { display: none; }
      .nav-links { gap: 1.3rem; }
    }
    @media (max-width: 900px) {
      .nav-links, .nav-actions { display: none; }
      .menu { display: block; position: relative; margin-left: auto; }
      .menu[open] .menu-panel {
        display: flex; flex-direction: column;
        position: absolute; right: 0; top: calc(100% + 0.7rem);
        background: var(--surface); border: 1px solid var(--line);
        border-radius: 14px; padding: 0.5rem; min-width: 220px;
        box-shadow: 0 16px 38px rgba(15,10,22,0.14);
      }
      .menu-panel a {
        padding: 0.85rem 1rem; text-decoration: none; color: var(--ink);
        font-family: 'Inter', sans-serif;
        font-weight: 500; font-size: 0.95rem; border-radius: 10px;
      }
      .menu-panel a:hover { background: var(--paper); }
      .menu-panel .btn-primary { margin-top: 0.35rem; }
      section { padding: 4rem 0; }
    }
    @media (max-width: 880px) {
      .kontakt-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .cine { min-height: 86svh; }
      .cine-scroll { display: none; }
      .field-row { grid-template-columns: 1fr; }
      .foot-inner { flex-direction: column; align-items: flex-start; }
      .bew-grid { grid-template-columns: 1fr; }
      .vn-grid { grid-template-columns: 1fr; }
      .demo-banner .cta { display: inline-block; padding: 0.45rem 0.9rem; }
      .foot-links a { padding: 0.55rem 0; }
    }
    @media (max-width: 480px) {
      .vn-body { grid-template-columns: 1fr; gap: 0.7rem; }
    }

    /* ─────────── Mobile feintuning (≤ 600px) ─────────── */
    @media (max-width: 600px) {
      /* Demo-Banner: tighter padding, kleinerer CTA daneben */
      .demo-banner { font-size: 0.72rem; padding: 0.55rem 0.9rem; line-height: 1.4; }
      .demo-banner .cta { margin-left: 0.4rem; padding: 0.22rem 0.6rem; font-size: 0.72rem; }

      /* Hero: Buttons jeweils volle Breite, Stack statt nebeneinander */
      .cine-inner { padding: clamp(2.5rem, 6vw, 4.5rem) 1.25rem clamp(3rem, 6vw, 4.5rem); }
      .cine-actions { gap: 0.6rem; margin-top: 1.6rem; flex-direction: column; align-items: stretch; }
      .cine-actions .btn { width: 100%; justify-content: center; }
      .cine h1 .h1-name { font-size: clamp(2.2rem, 8.5vw, 3rem); }
      .cine-rating { font-size: 0.85rem; margin-top: 1.2rem; }

      /* Sektionen näher zusammen */
      section { padding: 3.25rem 0; }
      .sec-head { margin-bottom: 2.25rem; }
      .sec-head h2 { font-size: clamp(1.7rem, 6vw, 2.2rem); }

      /* Assurance Bar: tighter Karten */
      .assure-points li { padding: 0.9rem 1rem; }
      .assure-actions .btn { width: 100%; justify-content: center; }
      .assure-actions { flex-direction: column; }

      /* VN-Reel: kleinere Slides + Nav näher dran */
      .vn-sec .sec-head { margin-bottom: 2.5rem; }
      .vn-reel { height: 440px; }
      .vn-slide { width: 248px; height: 372px; margin: -186px 0 0 -124px; }
      .vn-slide[data-pos="-1"] { transform: translate3d(-46%, 0, -100px) rotateY(18deg) scale(0.7); opacity: 0.25; }
      .vn-slide[data-pos="1"]  { transform: translate3d(46%, 0, -100px) rotateY(-18deg) scale(0.7); opacity: 0.25; }
      .vn-nav { width: 40px; height: 40px; }
      .vn-nav svg { width: 18px; height: 18px; }
      .vn-meta-bar h3 { font-size: 1.08rem; }
      .vn-cta-row .btn { width: 100%; justify-content: center; }

      /* Team-Strip: schmalere Karten passen besser auf 375px */
      .tm-sec { padding: 3.5rem 0 3rem; }
      .tm-card { width: 220px; }
      .tm-name { font-size: 1.4rem; }
      .tm-body { padding: 1.1rem 1rem 1.3rem; }

      /* Stimmen-Karten: weniger Padding */
      .bew-card { padding: 1.4rem 1.35rem; }
      .bew-card p { font-size: 1.05rem; }

      /* Kontakt-Form: tighter Karte */
      .form-card { padding: 1.5rem 1.25rem; }
      .kontakt-list a, .kontakt-list div { padding: 0.6rem 0; font-size: 0.92rem; }

      /* Brand Marquee: kleinere Logos */
      .bm { padding: 2rem 0 2.2rem; }

      /* Footer: tighter */
      footer { padding: 2rem 0; }
    }

    /* Ganz kleine Phones (≤ 380px): Hero-Buttons + Logo noch kompakter */
    @media (max-width: 380px) {
      .cine h1 .h1-name { font-size: clamp(2rem, 9vw, 2.6rem); }
      .demo-banner { font-size: 0.68rem; }
      .nav-inner { padding: 0.7rem 1rem; gap: 0.75rem; }
      .brand img { height: 44px; }
      .burger { width: 42px; height: 42px; }
    }
  </style>
</head>
<body>

<!-- [Nav] Studio Bar -->
<div class="demo-banner">
  <span class="dot">●</span> Musterseite von <a href="/">Blue Ocean Marketing</a> — in 48 h mit Ihrem Logo &amp; Ihren Farben.
  <a class="cta" href="https://blue-ocean.marketing/kontakt/" target="_blank" rel="noopener">Demo anfragen</a>
</div>

<nav class="nav">
  <div class="nav-inner">
    <a href="#" class="brand">
      {logoImg
        ? <Image src={logoImg} alt={name} height={52} width={Math.round(52 * (logoImg.width / logoImg.height))} />
        : <Fragment><span class="mark" set:html={I.sparkle} />{name.split(' ')[0]}{' '}<span>{name.split(' ').slice(1).join(' ')}</span></Fragment>}
    </a>

    <ul class="nav-links">
      {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>

    <div class="nav-actions">
      <a href={telHref} class="nav-call"><span class="ico" set:html={I.phone} />{telefon}</a>
      <a href={ctaZiel} class="nav-cta">{ctaText}</a>
    </div>

    <details class="menu">
      <summary><span class="burger" aria-label="Menü öffnen"><span class="ico" set:html={I.menu} /></span></summary>
      <div class="menu-panel">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
        <a href={telHref}>{telefon}</a>
        <a href={ctaZiel} class="btn btn-primary">{ctaText}</a>
      </div>
    </details>
  </div>
</nav>

<!-- [Hero] Studio Open — Vollbild-Video-Reel -->
<header class="cine">
  <div class="cine-bg">
    <picture>
      <source media="(max-width: 767px)" srcset="/videos/kosmetik/poster-mobile.webp" />
      <img class="cine-poster" src="/videos/kosmetik/poster-desktop.webp" alt="" fetchpriority="high" />
    </picture>
    <video class="cine-vid" data-reel="d" data-src="/videos/kosmetik/reel-1.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="d" data-src="/videos/kosmetik/reel-2.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="d" data-src="/videos/kosmetik/reel-3.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="d" data-src="/videos/kosmetik/reel-4.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="m" data-src="/videos/kosmetik/mobile.mp4" muted playsinline preload="none" aria-hidden="true"></video>
  </div>

  <div class="cine-inner">
    <div class="cine-stage">
      <h1>
        <span class="h1-sub">{heroBrancheSub}</span>
        <span class="h1-name">{name}</span>
        <span class="h1-tag">— {heroBrancheTag.toUpperCase()}{stadt ? ` · ${stadt.toUpperCase()}` : ''} —</span>
      </h1>
      <p class="cine-lead">{heroLead}</p>

      <div class="cine-actions">
        <a href={ctaZiel} class="btn btn-primary">{ctaText}<span class="ico" set:html={I.arrow} /></a>
        <a href={telHref} class="btn btn-glass"><span class="ico" set:html={I.phone} />Anrufen</a>
      </div>

      {bewertungen.length > 0 && (
        <div class="cine-rating">
          <span class="stars">{Array.from({ length: 5 }).map(() => <span class="ico" set:html={I.star} />)}</span>
          <span><b>{bewAvgStr}</b> aus {bewertungen.length} Kundinnenstimme{bewertungen.length === 1 ? '' : 'n'}</span>
        </div>
      )}
    </div>
  </div>

  <a href="#vertrauen" class="cine-scroll" aria-label="Weiter — Erstgespräch und Diskretion">
    <span>Scroll</span><i></i>
  </a>
</header>

<!-- [Trust] Endless Marquee — direkt unter dem Hero: Quick-Trust-Hooks vor der Assurance Bar -->
<div class="trust">
  <div class="trust-mask">
    <div class="trust-track">
      {trust.map((t) => (
        <div class="trust-item"><span class="ico" set:html={I.check} />{t}</div>
      ))}
      {trust.map((t) => (
        <div class="trust-item" aria-hidden="true"><span class="ico" set:html={I.check} />{t}</div>
      ))}
    </div>
  </div>
</div>

<!-- [Vertrauen] Assurance Bar — die Filler-/Treatment-Angst zuerst entschärfen: Erstgespräch + Diskretion -->
<section id="vertrauen" class="assure">
  <div class="wrap assure-grid">
    <div class="assure-lead">
      <span class="eyebrow">{assureKicker}</span>
      <h2>{assureTitel}</h2>
      <p>{assureText}</p>
      <div class="assure-actions">
        <a href={ctaZiel} class="btn btn-primary">{ctaText}<span class="ico" set:html={I.arrow} /></a>
        <a href="#behandlungen" class="btn btn-ghost">Behandlungen ansehen</a>
      </div>
    </div>
    <ul class="assure-points">
      {assure.map((a) => (
        <li>
          <span class="ico" set:html={I.check} />
          <span class="ap-txt"><b>{a.t}</b>{a.d}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- [Trust] Brand Marquee — Premium-Marken die wir führen. Endless-Loop, paused-on-hover.
     ⚠ Markenrechte: nur einsetzen wenn das Studio die Marken tatsächlich führt. -->
{brands.length > 0 && (
  <div class="bm" aria-label="Marken die wir führen">
    <div class="wrap"><div class="bm-head">Marken, mit denen wir arbeiten</div></div>
    <div class="bm-mask">
      <div class="bm-track">
        {brands.map((b) => (
          <div class="bm-item"><img class="bm-logo" src={b.img.src} alt={b.alt} loading="lazy" /></div>
        ))}
        {brands.map((b) => (
          <div class="bm-item" aria-hidden="true"><img class="bm-logo" src={b.img.src} alt="" loading="lazy" /></div>
        ))}
      </div>
    </div>
  </div>
)}

<!-- [Showcase] Insta Reel Strip — vertikale Reel-Tiles mit Lazy-Autoplay.
     Scroll-Snap, mobile-first, Posters bis Tile sichtbar im Viewport. -->
<section class="rs-sec" aria-label="Behandlungen in Action">
  <div class="rs-head reveal">
    <span class="eyebrow">Reels aus dem Studio</span>
    <h2>Behandlungen in <em>Bewegung</em></h2>
    <p>Echte Momente, kein Stock. Tippen oder scrollen — jedes Reel zeigt einen kurzen Ausschnitt unserer Arbeit.</p>
  </div>
  <div class="rs-strip" data-rs-strip role="list">
    {reels.map((r) => (
      <article class="rs-tile" data-rs-tile role="listitem">
        <img class="rs-poster" src={`/videos/kosmetik/portrait-${r.key}.webp`} alt={`${r.eyebrow} — ${r.titel}`} loading="lazy" />
        <video
          data-rs-src={`/videos/kosmetik/portrait-${r.key}.mp4`}
          poster={`/videos/kosmetik/portrait-${r.key}.webp`}
          muted playsinline loop preload="none"
          aria-hidden="true"></video>
        <div class="rs-overlay">
          <div class="rs-eyebrow">{r.eyebrow}</div>
          <div class="rs-titel">{r.titel}</div>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- [Leistungen] Vertical Reel — Behandlungen als auto-cycling Carousel
     (Komponente: src/components/showcase/VerticalReel.astro). -->
<section id="behandlungen" class="ang-sec">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Was wir anbieten</span>
      <h2>Unsere <em>Behandlungen</em></h2>
      <p>Von sanfter Pflege bis zur gezielten Anti-Aging-Therapie. Transparente Preise, ehrliche Beratung — keine Pakete-Pflicht.</p>
    </div>
    <div class="reveal">
      <VerticalReel items={behandlungen} bilder={galDefaults} />
    </div>
  </div>
</section>

<!-- [Ergebnisse] Vorher/Nachher — das Showpiece (Flavor A-light ersatz fürs 3D-Cinema).
     Statt einer scroll-gekoppelten Sequenz: starke Karten auf dunklem Grund,
     konkrete Versprechen (Sitzungen, Zeitraum). Ehrlich, nicht inszeniert. -->
<section id="ergebnisse" class="vn-sec">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Echte Ergebnisse</span>
      <h2>Vorher · <em>Nachher</em></h2>
      <p>Keine Filter, keine Schönfärberei. Das, was unsere Behandlungen wirklich bewirken — in der Anzahl Sitzungen, die wir Ihnen vorher ehrlich nennen.</p>
    </div>

    <!-- [Ergebnisse] Cinema Split-Reel — 3D-Perspektive + drag-barer Vorher/Nachher-Split -->
    <div class="vn-reel-wrap reveal">
      <div class="vn-reel" data-vn-reel>
        <div class="vn-stage">
          {ergebnisseMitBild.map((e, i) => (
            <article class="vn-slide" data-pos={i === 1 ? '0' : (i === 0 ? '-1' : '1')} aria-roledescription="slide" aria-label={`${e.behandlung} — Vorher/Nachher`}>
              <div class="vn-split">
                {e.imgNachher ? (
                  <Image src={e.imgNachher} alt={`Nachher: ${e.behandlung}`} width={680} height={1020} class="vn-bg vn-bg-img" loading="lazy" />
                ) : (
                  <div class="vn-bg" style="background: linear-gradient(135deg, #4a2a35 0%, #2a1820 100%);"></div>
                )}
                <div class="vn-veil">
                  {e.imgVorher ? (
                    <Image src={e.imgVorher} alt={`Vorher: ${e.behandlung}`} width={680} height={1020} class="vn-bg vn-bg-img" loading="lazy" />
                  ) : (
                    <div class="vn-bg" style="background: linear-gradient(135deg, #2a1820 0%, #1a0e14 100%);"></div>
                  )}
                </div>
                <span class="vn-tag vn-tag--vorher">Vorher</span>
                <span class="vn-tag vn-tag--nachher">Nachher</span>
                <button class="vn-handle" type="button" aria-label="Vorher/Nachher-Trennlinie verschieben">
                  <span class="vn-handle-grip">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline><polyline points="9 18 3 12 9 6" style="opacity:0"></polyline></svg>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </span>
                </button>
                <div class="vn-meta-bar">
                  <h3>{e.behandlung}</h3>
                  <div class="vn-sit">{e.sitzungen}</div>
                </div>
              </div>
            </article>
          ))}
        </div>
        <button class="vn-nav vn-nav--prev" type="button" aria-label="Vorheriges Ergebnis">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="vn-nav vn-nav--next" type="button" aria-label="Nächstes Ergebnis">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
      <div class="vn-dots" data-vn-dots>
        {ergebnisseMitBild.map((_, i) => (
          <button class="vn-dot" type="button" aria-label={`Zu Ergebnis ${i + 1}`} data-vn-dot={i}></button>
        ))}
      </div>
    </div>

    <div class="vn-cta-row">
      <a href={ctaZiel} class="btn btn-primary">{ctaText}<span class="ico" set:html={I.arrow} /></a>
    </div>
    <p class="vn-disclaimer">Beispielhafte Beschreibungen — individuelle Ergebnisse hängen von Hauttyp, Vorgeschichte und Pflegeroutine ab. Genau das klären wir im kostenlosen Erstgespräch.</p>
  </div>
</section>

<!-- [Ablauf] Treatment Path — vier Schritte, klar erklärt -->
<section id="ablauf" class="ablauf-sec">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">So läuft es ab</span>
      <h2>Vier Schritte, <em>klar erklärt</em></h2>
      <p>Damit Sie wissen, was Sie erwartet — und damit wir herausfinden, ob unser Vorgehen wirklich zu Ihnen passt.</p>
    </div>
    <div class="ablauf-grid reveal">
      {ablauf.map((s) => (
        <div class="ablauf-step">
          <div class="ablauf-nr">Schritt {s.nr}</div>
          <h3>{s.titel}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- [Team] Portrait Strip — die Hände, die Sie berühren. Mehr Präsenz pro Person:
     tall Portrait, Serif-Name, Rolle als Eyebrow, kurze Bio. Scroll-snap horizontal. -->
{team.length > 0 && (
  <section id="team" class="tm-sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Team &amp; Kosmetiker:innen</span>
        <h2>Die Hände, die <em>Sie</em> berühren</h2>
        <p>Wer Ihre Haut anfasst, soll für Sie ein Gesicht haben — mit Spezialgebiet und Haltung, nicht nur mit Zertifikat.</p>
      </div>
      <div class="tm-strip reveal" role="list">
        {team.map((t, i) => {
          const bild = clientImage(slug, t.bild) ?? (isShowcase ? teamDefaults[i] ?? null : null);
          const farbe = palette[i % palette.length];
          return (
            <article class="tm-card" role="listitem">
              <div class="tm-photo" style={bild ? '' : `background: linear-gradient(135deg, ${farbe} 0%, color-mix(in srgb, ${farbe} 60%, #000) 100%);`}>
                {bild
                  ? <Image src={bild} alt={t.name} width={640} height={800} loading="lazy" />
                  : <span class="tm-init">{initialen(t)}</span>}
              </div>
              <div class="tm-body">
                <h3 class="tm-name">{t.name}</h3>
                <div class="tm-role">{t.rolle}</div>
                {t.bio && <p class="tm-bio">{t.bio}</p>}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
)}

<!-- [Stimmen] Quote Wall -->
{bewertungen.length > 0 && (
  <section id="stimmen" class="stimmen-sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Kundinnenstimmen</span>
        <h2>Das sagen <em>unsere Kund:innen</em></h2>
        <p>Durchschnittlich {bewAvgStr} von 5 Sternen aus {bewertungen.length} Bewertung{bewertungen.length === 1 ? '' : 'en'}.</p>
      </div>
      <div class="bew-grid reveal">
        {bewertungen.map((b) => (
          <div class="bew-card">
            <div class="bew-stars">{Array.from({ length: b.sterne }).map(() => <span class="ico" set:html={I.star} />)}</div>
            <p>„{b.text}"</p>
            <div class="bew-name">— {b.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- [Scorecard] Self-Check — interaktiver Lead-Magnet (Priestley/ScoreApp) -->
<section id="check" class="sc">
  <div class="wrap">
    <div class="sc-card" data-sc>
      <div class="sc-progress" aria-hidden="true"><i></i></div>

      <div class="sc-step" data-step="intro">
        <span class="eyebrow">{sc.kicker}</span>
        <h2>{sc.titel}</h2>
        <p class="sc-intro">{sc.intro}</p>
        <ul class="sc-meta">{sc.meta.map((m) => <li>{m}</li>)}</ul>
        <button type="button" class="btn btn-primary sc-start">{sc.startLabel}<span class="ico" set:html={I.arrow} /></button>
        <p class="sc-note">{sc.note}</p>
      </div>

      {sc.fragen.map((f, i) => (
        <div class="sc-step sc-q" data-step={`q${i}`} hidden>
          <div class="sc-qhead"><span class="sc-count">Frage {i + 1} / {sc.fragen.length}</span></div>
          <h3>{f.q}</h3>
          <div class="sc-opts">
            {f.a.map((o) => (
              <button type="button" class="sc-opt" data-points={o.p}>{o.t}</button>
            ))}
          </div>
          <button type="button" class="sc-back" data-back>← Zurück</button>
        </div>
      ))}

      <div class="sc-step sc-form" data-step="lead" hidden>
        <span class="eyebrow">Fast geschafft</span>
        <h3>{sc.leadTitel}</h3>
        <p class="sc-intro">{sc.leadSub}</p>
        <div class="sc-field"><label for="sc-name">Name</label><input id="sc-name" class="sc-in" type="text" data-req="name" autocomplete="name" /></div>
        <div class="sc-field"><label for="sc-mail">E-Mail</label><input id="sc-mail" class="sc-in" type="email" data-req="email" autocomplete="email" /></div>
        <div class="sc-field"><label for="sc-tel">Telefon (optional)</label><input id="sc-tel" class="sc-in" type="tel" autocomplete="tel" /></div>
        <p class="sc-err" data-err hidden>Bitte Namen und eine gültige E-Mail-Adresse angeben.</p>
        <button type="button" class="btn btn-primary sc-reveal">Mein Ergebnis ansehen<span class="ico" set:html={I.arrow} /></button>
        <p class="sc-note">Demo-Formular — Eingaben werden nicht übertragen oder gespeichert.</p>
      </div>

      <div class="sc-step sc-result" data-step="result" hidden>
        <span class="eyebrow">Ihre Empfehlung</span>
        <div class="sc-score"><b data-score>0</b><span>von 100 Punkten</span></div>
        <div class="sc-tierbadge" data-tierlabel>—</div>
        <p class="sc-tiermsg" data-tiermsg></p>
        <a href={ctaZiel} class="btn btn-primary sc-cta">{ctaText}<span class="ico" set:html={I.arrow} /></a>
        <button type="button" class="sc-restart" data-restart>Check neu starten</button>
        <div class="sc-tiers" hidden>
          {sc.tiers.map((t) => (
            <div class="sc-tier" data-min={t.min} data-label={t.label}>{t.msg}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- [Kontakt] Split Form -->
<section id="kontakt" class="kontakt-sec">
  <div class="wrap kontakt-grid">
    <div class="kontakt-info">
      <span class="eyebrow">Kontakt</span>
      <h2>Termin oder <em>Erstgespräch?</em></h2>
      <p>Schreiben Sie uns oder rufen Sie an — wir melden uns innerhalb eines Werktages. Das Erstgespräch ist kostenlos und unverbindlich. Wenn Sie sensible Anliegen haben, einfach hinschreiben — wir behandeln das diskret.</p>
      <div class="kontakt-list">
        <a href={telHref}><span class="ico" set:html={I.phone} />{telefon}</a>
        <a href={`mailto:${email}`}><span class="ico" set:html={I.mail} />{email}</a>
        {adresse && <div><span class="ico" set:html={I.pin} />{adresse}</div>}
