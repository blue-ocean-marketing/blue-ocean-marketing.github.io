---
// [Template] Golf — „Fairway Clean" (Nav · Hero · Cinema · Trust · Angebot · Platz · Team · Stimmen · Kontakt)
// Datengetrieben aus einer Client-Config (Form: clients/_schema.json).
// Design-Prinzip: viel Weißraum, EIN ruhiges Fairway-Grün als Akzent, Haarlinien statt
// Karten-Schatten, eine Schrift (Space Grotesk), Strich-Icons (kein Emoji).
// Seriös & modern, bewusst KEIN Luxus-Pathos — schlicht, aber mit kreativem 3D-Rückgrat.
//
// 3D (gleiches Muster wie ZahnarztTemplate): selbst-gehostete glTF via <model-viewer>
// aus public/models/golf/. Fehlt eine Datei → Punkt-/Strich-Icon-Fallback, kein Crash.
//   • [Story] Fairway Cinema: EINE gepinnte, scroll-gekoppelte Sequenz mit
//     Seitenwechsel — NUR der Ball (kein Schläger). Ball parkt rechts (Hero)
//     → ROLLT quer nach links (wie frisch geschlagen; Spin an den Weg
//     gekoppelt + Bodenschatten), Text springt auf die freie Gegenseite →
//     Ball ROLLT zurück nach rechts, ruht kurz (Infos), und ROLLT am Ende
//     einfach rechts raus & verschwindet (CTA bleibt als Schlussbild).
//     Ball & Text immer auf Gegenseiten → kein Überlappen.
//     Choreografie-Wahrheit = BANDS-Tabelle im Controller-JS.
//     Mobil/Reduced-Motion → entpinnt, gestapelt, Kamera ruhig (lesbar).
// Sketchfab-Standard-Lizenz (kommerziell ok) → Urheber-Credit im Footer trotzdem gesetzt.
//
// Feld-Mapping (Schema = LeadBook-Schnittstelle, NICHT umbenennen — hier nur anders gerendert):
//   leistungen[] = Angebot: icon · titel · text · preis (z.B. „ab 1.290 €/Jahr") · hot=Beliebt
//   team[]       = PROs & Clubteam · bewertungen[] = Mitgliederstimmen
//   galerie[]    = Platz-Impressionen (optional; Fallback = ruhige Grün-Verläufe)
// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde): Trust-Punkte, Platz-Kennzahlen, Cinema-Szenen.
import { existsSync } from 'node:fs';
import { Image } from 'astro:assets';
import { clientImage } from '../_shared/clientImage';
import VerticalReel from '../../components/showcase/VerticalReel.astro';
import logoDefault from '../../assets/golf/logo.png';
import teamProDefault from '../../assets/golf/team-pro.webp';

interface Farben { primary: string; secondary?: string; accent?: string }
interface Angebot { icon?: string; titel: string; text?: string; preis?: string; dauer?: string; hot?: boolean }
interface Config {
  slug: string;
  marke: { name: string; slogan?: string | null; logo?: string | null; farben: Farben };
  kontakt: { adresse?: string | null; stadt?: string | null; telefon: string; email: string; oeffnung?: string | null; instagram?: string | null };
  hero?: { ueberschrift?: string; text?: string; cta_text?: string; cta_ziel?: string } | null;
  leistungen?: Angebot[];
  team?: { name: string; rolle: string; bild?: string | null; initialen?: string | null }[];
  bewertungen?: { name: string; sterne: number; text: string }[];
  galerie?: { bild: string; alt?: string }[];
}

const { config } = Astro.props as { config: Config };
const { slug } = config;
const { name, slogan, logo, farben } = config.marke;
const { adresse, telefon, email, oeffnung, instagram } = config.kontakt;
const stadtRaw = config.kontakt.stadt;
const angebot = config.leistungen ?? [];
const team = config.team ?? [];
const bewertungen = config.bewertungen ?? [];
const galerie = config.galerie ?? [];

// Default-Platzfotos (web-optimiert, astro:assets) — greifen im Showcase bzw.
// wenn die Kunden-Config keine galerie[] mitbringt. Echte Kunden überschreiben
// pro Bild via clientImage(); fehlt eins, springt das Default-Foto ein.
const galGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/golf/course-*.webp', { eager: true });
const galDefaults = Object.keys(galGlob).sort().map((k) => galGlob[k].default);
const galBilder = (galerie.length > 0
  ? galerie.slice(0, 6).map((g, i) => ({
      img: clientImage(slug, g.bild) ?? galDefaults[i] ?? null,
      alt: g.alt ?? `Platz-Impression ${i + 1}`,
    }))
  : galDefaults.slice(0, 6).map((img, i) => ({ img, alt: `Platz-Impression ${i + 1}` })));

// Avatar-Palette: zyklisch durch die Markenfarben (Fallback wenn kein Foto)
const palette = [farben.primary, farben.secondary ?? farben.primary, farben.accent ?? farben.primary];

// CSS-Variablen: nur die 3 Basisfarben werden injiziert, abgeleitete Töne via color-mix.
const cssVars =
  `--c-primary:${farben.primary};` +
  `--c-secondary:${farben.secondary ?? farben.primary};` +
  `--c-accent:${farben.accent ?? farben.primary};`;

const ort = adresse && adresse.includes(',') ? adresse.split(',').slice(-1)[0].trim() : '';
const stadt = stadtRaw ?? ort;

const logoImg = clientImage(slug, logo);

// Showcase-Defaults greifen NUR auf der öffentlichen Demo-Marke. Echte Kunden
// ohne eigenes Logo/Foto behalten Text-Logo bzw. Initialen-Avatar.
const isShowcase = /golf\s*club\s*pforzheim/i.test(name);
const useDefaultLogo = !logoImg && isShowcase;

// Team-Default-Portraits (gleiche Mechanik wie galDefaults): Golfer
// (golf-spezifisch) als Head-PRO, dazu wiederverwendbare Portraits aus
// src/assets/_shared/team. Reihenfolge passt zur Demo-Team-Reihenfolge.
const portraitGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/_shared/team/portrait-*.webp', { eager: true });
const portrait = (n: string) => portraitGlob[`/src/assets/_shared/team/portrait-${n}.webp`]?.default ?? null;
const teamDefaults = [teamProDefault, portrait('02'), portrait('06'), portrait('01')];
// Hero-H1-Block (universell: branchen-sub · name · stadt-tag) + 1-zeiliger Lead.
const heroBrancheSub = 'Golf Club';
const heroBrancheTag = 'Golf';
const heroLead = config.hero?.text ?? slogan ?? 'Mehr Spiel. Weniger Drumherum.';
const ctaText = config.hero?.cta_text ?? 'Schnupperrunde anfragen';
const ctaZiel = config.hero?.cta_ziel ?? '#kontakt';
const telHref = `tel:${telefon.replace(/[^+\d]/g, '')}`;
// WhatsApp: rohe Ziffern, deutsche Vorwahl (0 → 49) wenn führend
const waDigits = telefon.replace(/[^\d]/g, '').replace(/^0/, '49');
const waHref = `https://wa.me/${waDigits}?text=${encodeURIComponent(`Hallo ${name}, ich interessiere mich für eine Schnupperrunde.`)}`;

const bewAvg = bewertungen.length
  ? (bewertungen.reduce((s, b) => s + b.sterne, 0) / bewertungen.length)
  : 0;
const bewAvgStr = bewAvg.toFixed(1).replace('.', ',');

function initialen(t: { name: string; initialen?: string | null }) {
  if (t.initialen) return t.initialen;
  return t.name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
}

// Strich-Icons (Feather-Stil, currentColor) — kein Emoji.
const I = {
  phone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>',
  pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
  clock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>',
  arrow: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>',
  check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>',
  star: '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 2.9 6.26 6.6.79-4.9 4.6 1.3 6.55L12 17.1 6.1 20.2l1.3-6.55-4.9-4.6 6.6-.79Z"/></svg>',
  menu: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>',
  flag: '<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 56V8"/><path d="M20 10h28l-7 8 7 8H20"/><path d="M12 56h16"/></svg>',
  instagram: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg>',
  whatsapp: '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.15-1.75-.86-2.02-.96-.27-.1-.47-.15-.66.15-.2.3-.76.96-.93 1.16-.17.2-.34.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.66-1.6-.9-2.18-.24-.57-.48-.5-.66-.5l-.56-.01c-.2 0-.51.07-.78.37-.27.3-1.02 1-1.02 2.44 0 1.44 1.05 2.83 1.2 3.03.15.2 2.06 3.14 4.99 4.4.7.3 1.24.48 1.66.62.7.22 1.33.19 1.83.11.56-.08 1.75-.71 2-1.4.25-.69.25-1.28.17-1.4-.07-.13-.27-.2-.57-.35Zm-5.4 7.36c-1.65 0-3.27-.44-4.69-1.28l-.34-.2-3.48.91.93-3.39-.22-.36c-.92-1.47-1.41-3.16-1.41-4.9 0-5.07 4.13-9.2 9.21-9.2 2.46 0 4.77.96 6.51 2.7 1.74 1.74 2.69 4.05 2.69 6.51 0 5.08-4.13 9.21-9.2 9.21Zm7.83-17.05A11.04 11.04 0 0 0 12.11 1c-6.1 0-11.07 4.96-11.07 11.06 0 1.95.51 3.85 1.48 5.52L1 23l5.55-1.46a11.06 11.06 0 0 0 5.56 1.42h.01c6.1 0 11.07-4.96 11.07-11.06 0-2.96-1.15-5.74-3.24-7.83Z"/></svg>',
};

const navLinks = [
  { href: '#angebot', label: 'Angebot' },
  { href: '#story', label: 'Der Platz' },
  { href: '#team', label: 'Team' },
  { href: '#stimmen', label: 'Stimmen' },
  { href: '#kontakt', label: 'Kontakt' },
];

// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde personalisiert):
const trust = [
  'Gäste & Mitglieder willkommen',
  'Platzreife-Kurse das ganze Jahr',
  'Kurze Startzeiten ohne langes Warten',
  'Clubhaus mit Küche & Terrasse',
];

// [Vertrauen] Assurance Bar — agentur-gepflegt, branche-spezifisch.
// Conversion-Hebel #1 laut zielgruppen.md: die Einschüchterungs-Wand
// einreißen, niedrigschwellig einsteigen, „ohne Aufnahmegebühr" sichtbar
// machen — hoch platziert, vor dem Showpiece. Siehe conversion-playbook.md.
const assureKicker = 'Noch nie gespielt? Perfekt.';
const assureTitel = 'Golf wirkt elitär. Hier ist es das nicht.';
const assureText = 'Sie müssen nichts können, niemanden kennen und nichts mitbringen. Einmal ausprobieren reicht, um zu merken: entspannter als gedacht.';
const assure = [
  { t: 'Bei null anzufangen ist normal', d: 'Die meisten hier haben genau so begonnen — unsere PROs holen Sie dort ab.' },
  { t: 'Erst schnuppern, dann entscheiden', d: 'Eine Schnupperrunde ganz ohne Mitgliedschaft oder Verpflichtung.' },
  { t: 'Erstes Jahr ohne Aufnahmegebühr', d: 'Wenn Sie bleiben möchten: Einstieg ohne die sonst übliche hohe Hürde.' },
