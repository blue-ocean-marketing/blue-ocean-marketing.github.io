---
<!doctype html>
<html lang="de" style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{name}{slogan ? ` — ${slogan}` : ''}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      /* Markenfarbe sparsam — abgeleitete Töne via color-mix */
      --c-primary-dark: color-mix(in srgb, var(--c-primary) 72%, black);
      --c-wash:         color-mix(in srgb, var(--c-primary) 6%, white);
      --c-soft:         color-mix(in srgb, var(--c-primary) 11%, white);
      --c-line-brand:   color-mix(in srgb, var(--c-primary) 24%, transparent);
      --c-glow:         color-mix(in srgb, var(--c-primary) 26%, transparent);

      /* Neutrale Design-Farben — fix, NICHT aus der Config */
      --ink:    #12211a;
      --body:   #3f4f47;
      --muted:  #647269;
      --faint:  #93a09a;
      --line:   #e4e8e4;
      --line-2: #d6dcd6;
      --surface:#ffffff;
      --paper:  #f6f6f1;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: clip; }
    body {
      font-family: 'Source Sans 3', system-ui, -apple-system, sans-serif;
      color: var(--body); background: var(--paper);
      -webkit-font-smoothing: antialiased; line-height: 1.62;
      overflow-x: clip; overscroll-behavior-x: none;
    }
    h1, h2, h3 { color: var(--ink); line-height: 1.12; letter-spacing: -0.02em; }
    a { color: inherit; }
    img { max-width: 100%; display: block; }

    .wrap { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }
    .ico { display: inline-flex; }
    .ico svg { width: 1.15em; height: 1.15em; display: block; }

    .eyebrow {
      display: inline-block; font-size: 0.73rem; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--c-primary-dark);
    }
    .lead { color: var(--muted); font-size: 1.06rem; line-height: 1.72; }

    /* Buttons — Touch-Target ≥ 44px */
    .btn {
      display: inline-flex; align-items: center; gap: 0.55rem;
      padding: 0.85rem 1.6rem; border-radius: 100px;
      font-size: 0.95rem; font-weight: 600; text-decoration: none;
      min-height: 48px; cursor: pointer; border: 1.5px solid transparent;
      transition: background 0.18s, border-color 0.18s, color 0.18s, transform 0.18s;
    }
    .btn-primary { background: var(--c-primary); color: #fff; }
    .btn-primary:hover { background: var(--c-primary-dark); transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--ink); border-color: var(--line-2); }
    .btn-ghost:hover { border-color: var(--ink); }
    .btn .ico svg { width: 1.05em; height: 1.05em; }

    /* ─────────── [Nav] Course Bar ─────────── */
    .demo-banner {
      background: var(--ink); color: #b6c2ba;
      text-align: center; padding: 0.6rem 1.5rem;
      font-size: 0.78rem; line-height: 1.5;
    }
    .demo-banner a { color: #fff; text-decoration: none; font-weight: 600; }
    .demo-banner .dot { color: color-mix(in srgb, var(--c-primary) 60%, white); }
    .demo-banner .cta {
      display: inline-block; margin-left: 0.6rem;
      background: var(--c-primary); color: #fff;
      padding: 0.2rem 0.7rem; border-radius: 100px; font-weight: 600;
    }

    .nav {
      position: sticky; top: 0; z-index: 50;
      background: color-mix(in srgb, var(--paper) 92%, transparent);
      -webkit-backdrop-filter: blur(9px); backdrop-filter: blur(9px);
      border-bottom: 1px solid var(--line);
    }
    .nav-inner {
      padding: 0.85rem clamp(1.25rem, 4vw, 3rem);
      display: flex; align-items: center; gap: 1.5rem; flex-wrap: nowrap;
    }
    .brand {
      font-size: 1.12rem; font-weight: 700; color: var(--ink);
      text-decoration: none; letter-spacing: -0.02em;
      white-space: nowrap; flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.5rem;
    }
    .brand .mark { color: var(--c-primary); display: inline-flex; }
    .brand .mark svg { width: 1.1rem; height: 1.1rem; }
    .brand span { color: var(--c-primary); }
    .brand img { height: 38px; width: auto; display: block; }
    .brand img.brand-emblem { height: 56px; }
    .nav-links {
      display: flex; align-items: center; gap: 1.6rem; list-style: none;
      margin-left: auto;
    }
    .nav-links a {
      color: var(--body); text-decoration: none; white-space: nowrap;
      font-size: 0.92rem; font-weight: 500; padding: 0.4rem 0;
    }
    .nav-links a:hover { color: var(--c-primary); }
    .nav-actions { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
    .nav-call {
      display: inline-flex; align-items: center; gap: 0.45rem;
      color: var(--ink); text-decoration: none; font-weight: 600;
      font-size: 0.9rem; min-height: 44px; white-space: nowrap;
    }
    .nav-call:hover { color: var(--c-primary); }
    .nav-cta {
      background: var(--c-primary); color: #fff; text-decoration: none;
      padding: 0 1.2rem; border-radius: 100px; white-space: nowrap;
      font-size: 0.88rem; font-weight: 600; min-height: 44px;
      display: inline-flex; align-items: center;
    }
    .nav-cta:hover { background: var(--c-primary-dark); }
    .menu { display: none; }
    .menu > summary { list-style: none; }
    .menu > summary::-webkit-details-marker { display: none; }
    .burger {
      width: 46px; height: 46px; border: 1px solid var(--line-2);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      color: var(--ink); cursor: pointer;
    }
    .menu-panel { display: none; }

    /* ─────────── [Story] Fairway Cinema — eine scroll-gekoppelte 3D-Sequenz ───────────
       Aufbau: .cinema (Ancestor, KEIN overflow — sonst bricht sticky) →
       .cinema-track (gibt den Scroll-Weg = Höhe) → .cinema-sticky (pinnt, clippt).
       JS bewegt .cm-ball per transform; Kamera via model-viewer cameraOrbit. */
    .cinema { background: var(--ink); color: var(--paper); position: relative; padding: 0; }
    .cinema-track { position: relative; min-height: 480vh; }
    .cinema-sticky {
      position: sticky; top: 0; height: 100svh; min-height: 100svh;
      overflow: hidden; isolation: isolate;
    }
    /* ruhiger Grün-Schimmer + Boden-Vignette, hält die Bühne edel-dunkel */
    .cinema-sticky::before {
      content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 58% 56% at 70% 40%, var(--c-glow) 0%, transparent 62%),
        radial-gradient(ellipse 95% 70% at 50% 122%, rgba(6,12,9,0.65) 0%, transparent 60%);
    }

    .cinema-stage { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
    /* Bodenschatten — folgt dem Ball, staucht beim Rollen (JS setzt transform) */
    .cm-shadow {
      position: absolute; left: 50%; top: 50%; z-index: 0;
      width: min(40vh, 360px); height: 5.5vh;
      background: radial-gradient(ellipse, rgba(4,9,6,0.5) 0%, transparent 72%);
      filter: blur(7px); transform: translate(-50%, -50%);
      opacity: 0; pointer-events: none; will-change: transform, opacity;
    }
    .cm-obj {
      position: absolute; top: 50%; left: 50%;
      width: min(58vh, 560px); aspect-ratio: 1 / 1;
      transform: translate(-50%, -50%);
      will-change: transform, opacity;
    }
    .cm-obj model-viewer {
      width: 100%; height: 100%;
      background: transparent; --poster-color: transparent;
      touch-action: pan-y; pointer-events: none;
    }
    .cm-fallback {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      color: color-mix(in srgb, var(--c-primary) 55%, #fff);
    }
    .cm-fallback svg { width: 42%; height: auto; }
    .cm-fallback .dot {
      width: 60%; aspect-ratio: 1; border-radius: 50%;
      background: radial-gradient(circle at 36% 32%, #fff 0%, #eef0ec 45%, #cdd3cc 100%);
      box-shadow: inset -10px -12px 26px rgba(6,12,9,0.4), 0 22px 44px rgba(0,0,0,0.45);
    }

    .cinema-copy {
      position: absolute; inset: 0; z-index: 2;
      max-width: 1240px; left: 50%; transform: translateX(-50%);
      pointer-events: none;
    }
    /* Seite je Szene fest (CSS), Sichtbarkeit/Slide treibt JS pro Frame —
       deshalb KEINE CSS-Transition (würde gegen die rAF-Updates schmieren). */
    .cm-scene {
      position: absolute; top: 50%; width: min(30rem, 44%);
      opacity: 0; transform: translate(0, -50%);
    }
    .cm-scene.side-left  { left: clamp(1.5rem, 6vw, 5rem); right: auto; }
    .cm-scene.side-right { right: clamp(1.5rem, 6vw, 5rem); left: auto; }
    .cm-scene .eyebrow { color: color-mix(in srgb, var(--c-primary) 50%, #fff); }
    .cm-scene h2 {
      color: #fff; font-size: clamp(2rem, 4.6vw, 3.4rem);
      font-weight: 700; letter-spacing: -0.025em; margin: 0.6rem 0 0.9rem;
    }
    .cm-scene p { color: rgba(246,246,241,0.66); font-size: 1.05rem; line-height: 1.7; }
    .cm-scene .btn { margin-top: 1.6rem; pointer-events: auto; }

    .cinema-progress {
      position: absolute; left: 0; right: 0; bottom: 0; z-index: 3;
      height: 3px; background: rgba(246,246,241,0.12);
    }
    .cinema-progress i {
      display: block; height: 100%; width: 0%;
      background: var(--c-primary); transition: width 0.1s linear;
    }
    .cinema-hint {
      position: absolute; left: 50%; bottom: 1.5rem; transform: translateX(-50%);
      z-index: 3; font-size: 0.64rem; letter-spacing: 0.22em;
      text-transform: uppercase; color: rgba(246,246,241,0.5);
    }
    @media (prefers-reduced-motion: reduce) {
      .cm-scene { transition: none; }
    }

    /* Gestapelt (Mobil ODER Reduced-Motion via .is-static): kein Pin, alles lesbar.
       transform:none!important neutralisiert die JS-Inline-Transforms — die Kamera
       (model-viewer) animiert dort weiter, die Container bleiben aber im Fluss. */
    .cinema.is-static .cinema-track,
    .cinema.is-static .cinema-sticky { position: static; height: auto; min-height: 0; }
    .cinema.is-static .cinema-sticky { overflow: visible; padding: 3rem 0 3.5rem; }
    .cinema.is-static .cinema-stage {
      position: relative; inset: auto;
      display: flex; gap: 1rem; justify-content: center; align-items: center;
      height: 52vw; max-height: 340px; margin-bottom: 1rem;
    }
    .cinema.is-static .cm-obj {
      position: relative; top: auto; left: auto;
      width: 44%; max-width: 290px;
      opacity: 1 !important; transform: none !important;
    }
    .cinema.is-static .cinema-copy {
      position: static; transform: none; max-width: none;
      padding: 0 clamp(1.5rem, 5vw, 3rem);
    }
    .cinema.is-static .cm-scene {
      position: static; width: auto; max-width: none;
      left: auto !important; right: auto !important;
      opacity: 1 !important; transform: none !important;
      padding: 1.4rem 0; border-top: 1px solid rgba(246,246,241,0.14);
    }
    .cinema.is-static .cm-scene:first-child { border-top: 0; }
    .cinema.is-static .cm-shadow { display: none; }
    .cinema.is-static .cinema-progress,
    .cinema.is-static .cinema-hint { display: none; }

    /* Mobil-Kino: bleibt gepinnt wie Desktop, aber der Ball rollt SENKRECHT
       und die Szenen sitzen mittig (kein Links/Rechts — zu schmal). JS-Bahn
       in render() darauf abgestimmt. Nur Reduced-Motion bleibt .is-static. */
    .cinema.is-mobilecine .cinema-track { min-height: 320vh; }
    .cinema.is-mobilecine .cm-obj { width: min(70vw, 260px); max-width: 90vw; }
    .cinema.is-mobilecine .cm-scene {
      left: 50%; right: auto; width: min(30rem, 90%); max-width: calc(100vw - 1.5rem);
      top: auto; bottom: auto; text-align: center;
    }
    /* Text dicht an den Ball — der Ball rollt senkrecht (Szene 0/2/3/4 oben,
       Szene 1 unten), Text sitzt jeweils auf der freien Hälfte und wird am
       Ball-Rand verankert (statt am Viewport-Rand), damit der Spalt zum
       Modell konstant bleibt, egal ob die Szene einen Button hat. */
    .cinema.is-mobilecine .cm-scene.side-right { bottom: 49vh; top: auto; }
    .cinema.is-mobilecine .cm-scene.side-left  { top: 38vh; bottom: auto; }
    /* Kompaktere Typo im Mobil-Kino — die inhaltsreichen Szenen (0 & 4 mit
       CTA-Button) müssen in die zum Ball gegenüberliegende Hälfte passen,
       sonst überlappt der ruhende Ball den Text auf kurzen Screens. */
    .cinema.is-mobilecine .cm-scene .eyebrow { font-size: 0.66rem; }
    .cinema.is-mobilecine .cm-scene h2 { font-size: clamp(1.35rem, 5.6vw, 1.7rem); margin: 0.45rem 0 0.55rem; word-break: break-word; }
    /* Mobil: Body-Text raus — nur Eyebrow + Titel (+ CTA) bleiben, weniger Kollision mit dem Ball. */
    .cinema.is-mobilecine .cm-scene p  { display: none; }
    .cinema.is-mobilecine .cm-scene .btn { margin-top: 1rem; }
    /* Kurze Screens (SE/kleine Androids): kleinerer Ball + noch kompakter */
    @media (max-height: 720px) {
      .cinema.is-mobilecine .cm-obj { width: min(46vw, 164px); }
      .cinema.is-mobilecine .cm-scene h2 { font-size: 1.4rem; }
    }

    /* ─────────── [Hero] Open Course — Vollbild-Video-Reel ─────────── */
    /* Hintergrund: 4 Clips (Desktop) bzw. 1 Hochformat (Mobil), per JS
       gewählt — kein doppelter Download. Reduced-Motion/Save-Data → Poster. */
    .cine {
      position: relative; min-height: 92vh; min-height: 92svh;
      display: flex; align-items: flex-end;
      overflow: hidden; background: var(--ink); isolation: isolate;
    }
    .cine-bg { position: absolute; inset: 0; z-index: 0; }
    .cine-poster, .cine-vid {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; display: block;
    }
    .cine-poster { z-index: 0; }
    .cine-vid {
      z-index: 1; opacity: 0;
      transition: opacity 1.1s ease; will-change: opacity;
    }
    .cine-vid.on { opacity: 1; }
    /* Marken-Schimmer oben rechts + Lesbarkeits-Verlauf unten/links */
    .cine-bg::before {
      content: ''; position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background: radial-gradient(ellipse 58% 58% at 82% 14%,
        var(--c-glow) 0%, transparent 60%);
    }
    .cine-bg::after {
      content: ''; position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background:
        linear-gradient(to top, rgba(8,16,11,0.88) 0%, rgba(8,16,11,0.30) 46%, rgba(8,16,11,0.18) 100%),
        linear-gradient(to right, rgba(8,16,11,0.58) 0%, rgba(8,16,11,0.12) 60%, transparent 100%);
    }
    .cine-inner {
      position: relative; z-index: 3; width: 100%;
      max-width: 1140px; margin: 0 auto;
      padding: clamp(3rem, 8vw, 6rem) 1.5rem clamp(3.5rem, 7vw, 5.5rem);
    }
    .cine-stage { max-width: 40rem; }
    .cine .eyebrow {
      color: #fff; background: color-mix(in srgb, var(--c-primary) 60%, transparent);
      padding: 0.36rem 0.9rem; border-radius: 100px;
      -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    }
    /* [Hero] Brand H1 — universeller 3-zeiliger Block: sub · name · tag */
    .cine h1 { margin: 0.6rem 0 1.1rem; display: flex; flex-direction: column; gap: 0.35rem; max-width: 18ch; }
    .cine h1 .h1-sub {
      font-size: clamp(0.95rem, 1.4vw, 1.15rem); font-weight: 500;
      letter-spacing: 0.02em; color: rgba(255,255,255,0.78); line-height: 1.2;
    }
    .cine h1 .h1-name {
      color: #fff; font-size: clamp(2.4rem, 6.4vw, 4.6rem);
      font-weight: 700; letter-spacing: -0.025em; line-height: 1.02;
    }
    .cine h1 .h1-tag {
      align-self: flex-start; font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: rgba(255,255,255,0.7); margin-top: 0.45rem;
    }
    .cine-lead {
      color: rgba(255,255,255,0.82); line-height: 1.7;
      font-size: clamp(1rem, 1.5vw, 1.15rem); max-width: 34rem;
    }
    /* [Hero] Brand Mark — Logo linksbündig über der Headline (auf Video-Reel). */
    .cine-brand { display: inline-flex; align-items: center; margin-bottom: clamp(0.75rem, 1.6vw, 1.25rem); }
    .cine-brand img {
      height: clamp(44px, 5.5vw, 68px); width: auto; max-width: min(240px, 62vw);
      filter: drop-shadow(0 2px 18px rgba(0,0,0,0.5));
    }
    @media (max-width: 480px) {
      .cine-brand img { height: 42px; max-width: 180px; }
    }
    .cine-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2.1rem; }
    .btn-glass {
      background: rgba(255,255,255,0.10); color: #fff;
      border-color: rgba(255,255,255,0.34);
      -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    }
    .btn-glass:hover { background: rgba(255,255,255,0.18); border-color: #fff; }
    .cine-rating {
      display: inline-flex; align-items: center; gap: 0.6rem;
      margin-top: 1.6rem; font-size: 0.92rem; color: rgba(255,255,255,0.72);
    }
    .cine-rating .stars { display: inline-flex; gap: 1px; color: #fff; }
    .cine-rating .stars .ico svg { width: 1rem; height: 1rem; }
    .cine-rating b { color: #fff; font-weight: 700; }
    .cine-scroll {
      position: absolute; left: 50%; bottom: 1.3rem; transform: translateX(-50%);
      z-index: 3; display: flex; flex-direction: column; align-items: center;
      gap: 0.45rem; text-decoration: none;
      color: rgba(255,255,255,0.72); font-size: 0.64rem;
      letter-spacing: 0.2em; text-transform: uppercase;
    }
    .cine-scroll i {
      display: block; width: 1px; height: 34px;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.85));
      animation: cineScroll 2s ease-in-out infinite;
    }
    @keyframes cineScroll {
      0%, 100% { opacity: 0.3; transform: scaleY(1); }
      50%      { opacity: 0.9; transform: scaleY(1.18); }
    }
    @media (prefers-reduced-motion: reduce) {
      .cine-vid { transition: none; }
      .cine-scroll i { animation: none; }
    }

    /* ─────────── [Vertrauen] Assurance Bar ─────────── */
    .assure { background: var(--c-wash); border-top: 1px solid var(--line); }
    .assure-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: center; }
    .assure-lead h2 { font-size: clamp(1.5rem, 3vw, 2.15rem); line-height: 1.2; color: var(--ink); margin: 0.5rem 0 0.8rem; }
    .assure-lead p { color: var(--body); font-size: 1rem; line-height: 1.65; max-width: 40ch; }
    .assure-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.7rem; }
    .assure-points { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.85rem; }
    .assure-points li { display: flex; gap: 0.85rem; align-items: flex-start; background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 1.05rem 1.2rem; }
    .assure-points .ico { color: var(--c-primary); flex: none; margin-top: 0.05rem; }
    .assure-points .ico svg { width: 1.15rem; height: 1.15rem; }
    .assure-points b { display: block; color: var(--ink); font-size: 0.98rem; margin-bottom: 0.18rem; }
    .assure-points .ap-txt { color: var(--body); font-size: 0.9rem; line-height: 1.5; }
    @media (max-width: 820px) {
      .assure-grid { grid-template-columns: 1fr; gap: 1.9rem; }
      .assure-lead p { max-width: none; }
    }

    /* ─────────── [Scorecard] Self-Check ─────────── */
    .sc { background: var(--c-wash); border-top: 1px solid var(--line); }
    .sc-card { max-width: 620px; margin: 0 auto; background: var(--surface); border: 1px solid var(--line); border-radius: 18px; padding: clamp(1.5rem, 4vw, 2.75rem); position: relative; overflow: hidden; }
    .sc-progress { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--line); }
    .sc-progress > i { display: block; height: 100%; width: 0; background: var(--c-primary); transition: width 0.4s ease; }
    .sc-step { animation: scIn 0.32s ease; }
    @keyframes scIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .sc-step h2 { font-size: clamp(1.5rem, 3.2vw, 2.1rem); color: var(--ink); line-height: 1.18; margin: 0.4rem 0 0.7rem; }
    .sc-step h3 { font-size: clamp(1.2rem, 2.6vw, 1.55rem); color: var(--ink); line-height: 1.25; margin: 0.5rem 0 1.3rem; }
    .sc-intro { color: var(--body); line-height: 1.6; }
    .sc-meta { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem 0.7rem; margin: 1.1rem 0 1.6rem; padding: 0; }
    .sc-meta li { font-size: 0.8rem; font-weight: 600; color: var(--c-primary); background: var(--c-wash); border: 1px solid var(--line); border-radius: 100px; padding: 0.4rem 0.9rem; }
    .sc-start, .sc-reveal, .sc-cta { width: 100%; justify-content: center; }
    .sc-note { font-size: 0.78rem; color: var(--body); opacity: 0.78; margin-top: 1rem; }
    .sc-count { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--c-primary); }
    .sc-qhead { margin-bottom: 0.5rem; }
    .sc-opts { display: grid; gap: 0.7rem; }
    .sc-opt { text-align: left; font: inherit; font-size: 1rem; font-weight: 600; color: var(--ink); background: var(--surface); border: 1.5px solid var(--line); border-radius: 12px; padding: 1rem 1.15rem; min-height: 52px; cursor: pointer; transition: border-color 0.15s, background 0.15s, transform 0.12s; }
    .sc-opt:hover { border-color: var(--c-primary); transform: translateY(-1px); }
    .sc-opt.is-sel { border-color: var(--c-primary); background: var(--c-wash); }
    .sc-back, .sc-restart { display: inline-block; margin-top: 1.3rem; background: none; border: none; color: var(--body); font: inherit; font-size: 0.85rem; cursor: pointer; text-decoration: underline; padding: 0.5rem 0.25rem; min-height: 44px; }
    .sc-field { margin-bottom: 1rem; }
    .sc-field label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--body); margin-bottom: 0.35rem; }
    .sc-in { width: 100%; font: inherit; font-size: 1rem; color: var(--ink); background: var(--surface); border: 1.5px solid var(--line); border-radius: 10px; padding: 0.85rem 1rem; min-height: 48px; }
    .sc-in:focus { outline: none; border-color: var(--c-primary); }
    .sc-err { color: #c0392b; font-size: 0.85rem; margin: 0.2rem 0 1rem; }
    .sc-score { display: flex; align-items: baseline; gap: 0.5rem; margin: 0.6rem 0 0.5rem; }
    .sc-score b { font-size: clamp(2.6rem, 8vw, 3.6rem); color: var(--c-primary); line-height: 1; }
    .sc-score span { color: var(--body); font-size: 0.95rem; }
    .sc-tierbadge { display: inline-block; font-weight: 700; color: var(--ink); background: var(--c-wash); border: 1px solid var(--line); border-radius: 100px; padding: 0.4rem 1rem; margin-bottom: 1rem; }
    .sc-tiermsg { color: var(--body); line-height: 1.6; margin-bottom: 1.7rem; }
    @media (max-width: 520px) { .sc-card { border-radius: 14px; } }

    /* ─────────── [Trust] Endless Marquee ─────────── */
    .trust {
      border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
      background: var(--surface); overflow: hidden;
    }
    .trust-mask {
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
              mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    }
    .trust-track {
      display: flex; width: max-content;
      animation: trustScroll 34s linear infinite;
    }
    .trust:hover .trust-track { animation-play-state: paused; }
    .trust-item {
      display: flex; align-items: center; gap: 0.6rem; flex: none;
      padding: 1.35rem 0; margin-right: 3rem; white-space: nowrap;
      font-size: 0.95rem; font-weight: 600; color: var(--body);
    }
    .trust-item .ico { color: var(--c-primary); }
    .trust-item .ico svg { width: 1.05rem; height: 1.05rem; }
    @keyframes trustScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .trust-mask { -webkit-mask-image: none; mask-image: none; }
      .trust-track {
        animation: none; width: auto;
        flex-wrap: wrap; justify-content: center;
        gap: 0.5rem 2.5rem; padding: 1.1rem 1.5rem;
      }
      .trust-item { margin-right: 0; padding: 0; }
      .trust-item[aria-hidden="true"] { display: none; }
    }

    /* ─────────── Section base ─────────── */
    section { padding: 5.5rem 0; }
    section { scroll-margin-top: 80px; }
    .sec-head { max-width: 40rem; margin-bottom: 3.25rem; }
    .sec-head h2 {
      font-size: clamp(1.8rem, 3.4vw, 2.6rem); font-weight: 700;
      margin: 0.85rem 0 0.85rem;
    }
    .sec-head p { color: var(--muted); font-size: 1.02rem; line-height: 1.68; }

    .reveal {
      opacity: 0; transform: translateY(22px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* ─────────── [Angebot] Section wrapper — Inhalt = VerticalReel-Komponente ─────────── */
    .ang-sec { background: var(--surface); border-top: 1px solid var(--line); }

    /* ─────────── [Platz] Fact Strip ─────────── */
    .platz-sec { background: var(--surface); border-top: 1px solid var(--line); }
    .platz-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 1.5rem 1rem;
    }
    .platz-cell { border-left: 2px solid var(--c-line-brand); padding-left: 1.1rem; }
    .platz-val { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: var(--ink); }
    .platz-lbl { font-size: 0.84rem; color: var(--muted); margin-top: 0.3rem; }

    /* ─────────── [Galerie] Course Strip ─────────── */
    .gal-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }
    .gal-item {
      position: relative; aspect-ratio: 4 / 3; border-radius: 14px;
      overflow: hidden; background: var(--ink);
    }
    .gal-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .gal-item:hover img { transform: scale(1.05); }

    /* ─────────── [Team] Portrait Grid ─────────── */
    .team-sec { background: var(--c-wash); border-top: 1px solid var(--line); }
    .team-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
      gap: 2rem 1.5rem;
    }
    .team-card { text-align: center; }
    .avatar {
      width: 96px; height: 96px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 1.45rem; color: #fff;
      margin: 0 auto 1.1rem; overflow: hidden;
      box-shadow: 0 0 0 1px var(--line-2), 0 0 0 6px var(--paper);
    }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .team-card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.2rem; }
    .team-card p { color: var(--muted); font-size: 0.9rem; }

    /* ─────────── [Stimmen] Quote Wall ─────────── */
    .stimmen-sec { background: var(--surface); border-top: 1px solid var(--line); }
    .bew-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.25rem;
    }
    .bew-card {
      border: 1px solid var(--line); border-left: 3px solid var(--c-primary);
      border-radius: 0 14px 14px 0; padding: 1.75rem; background: var(--paper);
    }
    .bew-stars { display: inline-flex; gap: 2px; color: var(--c-primary); margin-bottom: 0.9rem; }
    .bew-stars .ico svg { width: 1rem; height: 1rem; }
    .bew-card p { color: var(--body); font-size: 0.97rem; line-height: 1.68; margin-bottom: 1.1rem; }
    .bew-name { font-size: 0.86rem; font-weight: 600; color: var(--ink); }

    /* ─────────── [Kontakt] Split Form ─────────── */
    .kontakt-sec { background: var(--c-wash); border-top: 1px solid var(--line); }
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
    .kontakt-info h2 { font-size: clamp(1.8rem, 3.4vw, 2.6rem); font-weight: 700; margin-bottom: 1rem; }
    .kontakt-info > p { color: var(--muted); font-size: 1.02rem; line-height: 1.68; margin-bottom: 2rem; }
    .kontakt-list { display: flex; flex-direction: column; gap: 0.4rem; }
    .kontakt-list a, .kontakt-list div {
      display: flex; align-items: center; gap: 0.85rem;
      padding: 0.7rem 0; color: var(--body); text-decoration: none;
      font-size: 0.97rem; border-bottom: 1px solid var(--line);
    }
    .kontakt-list .ico { color: var(--c-primary); }
    .kontakt-list a:hover { color: var(--c-primary); }

    .form-card {
      background: var(--surface); border: 1px solid var(--line);
      border-radius: 18px; padding: 2rem;
    }
    .form-card h3 { font-size: 1.15rem; font-weight: 600; margin-bottom: 1.4rem; }
    .field { margin-bottom: 1rem; }
    .field label {
      display: block; font-size: 0.8rem; font-weight: 600;
      color: var(--ink); margin-bottom: 0.4rem;
    }
    .field input, .field select, .field textarea {
      width: 100%; padding: 0.75rem 0.9rem; min-height: 46px;
      background: var(--surface); border: 1px solid var(--line-2);
      border-radius: 10px; color: var(--ink); font-size: 0.95rem;
      font-family: inherit;
    }
    .field textarea { min-height: 92px; resize: vertical; }
    .field input:focus, .field select:focus, .field textarea:focus {
      outline: none; border-color: var(--c-primary);
      box-shadow: 0 0 0 3px var(--c-line-brand);
    }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
    .form-card .btn { width: 100%; justify-content: center; margin-top: 0.5rem; }
    .form-note { font-size: 0.78rem; color: var(--faint); margin-top: 0.9rem; text-align: center; }

    /* ─────────── [Footer] Minimal ─────────── */
    footer { background: var(--surface); border-top: 1px solid var(--line); padding: 2.5rem 0; }
    .foot-inner {
      display: flex; flex-wrap: wrap; justify-content: space-between;
      align-items: center; gap: 1rem; font-size: 0.85rem; color: var(--muted);
    }
    .foot-inner a { color: var(--muted); text-decoration: none; }
    .foot-inner a:hover { color: var(--c-primary); }
    .foot-links { display: flex; gap: 1.5rem; }
    .foot-credit { width: 100%; font-size: 0.78rem; color: var(--faint);
      border-top: 1px solid var(--line); padding-top: 1.25rem; margin-top: 0.5rem; }
    .foot-credit a { color: var(--c-primary); font-weight: 500; }

    /* ─────────── Mobile First ─────────── */
    @media (max-width: 1080px) {
      .nav-call { display: none; }
      .nav-links { gap: 1.3rem; }
    }
    @media (max-width: 900px) {
      .nav-links, .nav-actions { display: none; }
      .menu { display: block; position: relative; margin-left: auto; }
      .menu[open] .menu-panel {
        display: flex; flex-direction: column;
        position: absolute; right: 0; top: calc(100% + 0.7rem);
        background: var(--surface); border: 1px solid var(--line);
        border-radius: 14px; padding: 0.5rem; min-width: 220px;
        box-shadow: 0 16px 38px rgba(18,33,26,0.14);
      }
      .menu-panel a {
        padding: 0.85rem 1rem; text-decoration: none; color: var(--ink);
        font-weight: 500; font-size: 0.95rem; border-radius: 10px;
      }
      .menu-panel a:hover { background: var(--paper); }
      .menu-panel .btn-primary { margin-top: 0.35rem; }
      section { padding: 4rem 0; }
    }
    @media (max-width: 880px) {
      .kontakt-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      /* Cinema-Stapelmodus läuft über .cinema.is-static (JS-getoggled), nicht hier */
      .cine { min-height: 86svh; }
      .cine-scroll { display: none; }
      .field-row { grid-template-columns: 1fr; }
      .foot-inner { flex-direction: column; align-items: flex-start; }
      /* Karten-Raster auf eine Spalte — beseitigt den Mini-Überlauf < 320 px */
      .bew-grid { grid-template-columns: 1fr; }
      /* Touch-Targets ≥ 44 px (Mobile-Checkliste) */
      .demo-banner .cta { display: inline-block; padding: 0.45rem 0.9rem; }
      .foot-links a { padding: 0.55rem 0; }
    }

    /* ─────────── [Sticky] Mobile CTA Bar — Anrufen + WhatsApp ─────────── */
    .sticky-cta {
      position: fixed; left: 0; right: 0; bottom: 0;
      z-index: 60; display: none; gap: 0.55rem;
      padding: 0.55rem 0.6rem calc(0.55rem + env(safe-area-inset-bottom, 0px));
      background: var(--surface);
      border-top: 1px solid var(--line);
      box-shadow: 0 -8px 24px rgba(15,10,22,0.10);
      transform: translateY(110%);
      transition: transform 0.32s cubic-bezier(.22,.61,.36,1);
    }
    .sticky-cta[data-visible="true"] { transform: translateY(0); }
    .sticky-cta-btn {
      flex: 1; min-height: 52px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 0.55rem; border-radius: 14px;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem; font-weight: 600; letter-spacing: 0.01em;
      text-decoration: none; color: #fff;
      transition: filter 0.18s ease, transform 0.12s ease;
    }
    .sticky-cta-btn:active { transform: scale(0.97); }
    .sticky-cta-btn .ico svg { width: 1.15rem; height: 1.15rem; }
    .sticky-cta-call { background: var(--c-primary); }
    .sticky-cta-call:hover { background: var(--c-primary-dark); }
    .sticky-cta-wa { background: #25D366; }
    .sticky-cta-wa:hover { filter: brightness(0.95); }
    @media (max-width: 767px) {
      .sticky-cta { display: flex; }
      body { padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px)); }
    }
    @media (prefers-reduced-motion: reduce) {
      .sticky-cta { transition: none; }
    }
  </style>
  {hasBall && (
    <script type="module" src="https://cdn.jsdelivr.net/npm/@google/model-viewer@4.0.0/dist/model-viewer.min.js"></script>
  )}
</head>
<body>

<!-- [Nav] Course Bar -->
<div class="demo-banner">
  <span class="dot">●</span> Musterseite von <a href="/">Blue Ocean Marketing</a> — in 48 h mit Ihrem Logo &amp; Ihren Farben.
  <a class="cta" href="https://blue-ocean.marketing/kontakt/" target="_blank" rel="noopener">Demo anfragen</a>
</div>

<nav class="nav">
  <div class="nav-inner">
    <a href="#" class="brand">
      {logoImg
        ? <Image src={logoImg} alt={name} height={38} width={Math.round(38 * (logoImg.width / logoImg.height))} />
        : useDefaultLogo
          ? <Image class="brand-emblem" src={logoDefault} alt={name} height={56} width={Math.round(56 * (logoDefault.width / logoDefault.height))} />
          : <Fragment><span class="mark" set:html={I.flag} />{name.split(' ')[0]}{' '}<span>{name.split(' ').slice(1).join(' ')}</span></Fragment>}
    </a>

    <ul class="nav-links">
      {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>

    <div class="nav-actions">
      <a href={telHref} class="nav-call"><span class="ico" set:html={I.phone} />{telefon}</a>
      <a href={ctaZiel} class="nav-cta">{ctaText}</a>
    </div>

    <details class="menu">
      <summary><span class="burger" aria-label="Menü öffnen"><span class="ico" set:html={I.menu} /></span></summary>
      <div class="menu-panel">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
        <a href={telHref}>{telefon}</a>
        <a href={ctaZiel} class="btn btn-primary">{ctaText}</a>
      </div>
    </details>
  </div>
</nav>

<!-- [Hero] Open Course -->
<header class="cine">
  <div class="cine-bg">
    <picture>
      <source media="(max-width: 767px)" srcset="/videos/golf/poster-mobile.webp" />
      <img class="cine-poster" src="/videos/golf/poster-desktop.webp" alt="" fetchpriority="high" />
    </picture>
    <!-- Reel per Gerät erst via JS verdrahtet (data-src → src): Mobil lädt
         nie die Desktop-Clips und umgekehrt; spart Daten. -->
    <video class="cine-vid" data-reel="d" data-src="/videos/golf/reel-1.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="d" data-src="/videos/golf/reel-2.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="d" data-src="/videos/golf/reel-3.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="d" data-src="/videos/golf/reel-4.mp4" muted playsinline preload="none" aria-hidden="true"></video>
    <video class="cine-vid" data-reel="m" data-src="/videos/golf/mobile.mp4" muted playsinline preload="none" aria-hidden="true"></video>
  </div>

  <div class="cine-inner">
    <div class="cine-stage">
      <h1>
        <span class="h1-sub">{heroBrancheSub}</span>
        <span class="h1-name">{name}</span>
        <span class="h1-tag">— {heroBrancheTag.toUpperCase()}{stadt ? ` · ${stadt.toUpperCase()}` : ''} —</span>
      </h1>
      <p class="cine-lead">{heroLead}</p>

      <div class="cine-actions">
        <a href={ctaZiel} class="btn btn-primary">{ctaText}<span class="ico" set:html={I.arrow} /></a>
        <a href={telHref} class="btn btn-glass"><span class="ico" set:html={I.phone} />Anrufen</a>
      </div>

      {bewertungen.length > 0 && (
        <div class="cine-rating">
          <span class="stars">{Array.from({ length: 5 }).map(() => <span class="ico" set:html={I.star} />)}</span>
          <span><b>{bewAvgStr}</b> aus {bewertungen.length} Mitgliederstimme{bewertungen.length === 1 ? '' : 'n'}</span>
        </div>
      )}
    </div>
  </div>

  <a href="#vertrauen" class="cine-scroll" aria-label="Weiter — Golf ohne Hürde">
    <span>Scroll</span><i></i>
  </a>
</header>

<!-- [Vertrauen] Assurance Bar — Einschüchterung zuerst nehmen, dann erst das Showpiece -->
<section id="vertrauen" class="assure">
  <div class="wrap assure-grid">
    <div class="assure-lead">
      <span class="eyebrow">{assureKicker}</span>
      <h2>{assureTitel}</h2>
      <p>{assureText}</p>
      <div class="assure-actions">
        <a href={ctaZiel} class="btn btn-primary">{ctaText}<span class="ico" set:html={I.arrow} /></a>
        <a href="#angebot" class="btn btn-ghost">Angebot &amp; Preise ansehen</a>
      </div>
    </div>
    <ul class="assure-points">
      {assure.map((a) => (
        <li>
          <span class="ico" set:html={I.check} />
          <span class="ap-txt"><b>{a.t}</b>{a.d}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- [Story] Fairway Cinema — gepinnte, scroll-gekoppelte 3D-Sequenz mit
     Seitenwechsel, NUR Ball: parkt rechts (Hero) → ROLLT nach links (wie
     frisch geschlagen), Text springt auf die Gegenseite → ROLLT zurück
     nach rechts, ruht kurz, und ROLLT am Ende rechts raus & verschwindet
     (CTA bleibt). Ball & Text nie auf derselben Seite (kein Überlappen).
     Seiten/Bänder = BANDS-Tabelle im
     Controller-JS. Mobil / Reduced-Motion → entpinnt & gestapelt. -->
<section class="cinema" id="story">
  <div class="cinema-track" id="cinemaTrack">
    <div class="cinema-sticky">
      <div class="cinema-stage">
        <div class="cm-shadow" aria-hidden="true"></div>
        <div class="cm-obj cm-ball">
          {hasBall ? (
            <model-viewer
              id="ballViewer"
              src={ballSrc}
              alt={`3D-Golfball — ${name}`}
              camera-orbit="0deg 78deg 100%"
              field-of-view="30deg"
              environment-image="neutral"
              exposure="1.05"
              shadow-intensity="0.4"
              shadow-softness="1"
              interaction-prompt="none"
              disable-zoom
              loading="eager"
              reveal="auto"
            ></model-viewer>
          ) : (
            <div class="cm-fallback"><div class="dot"></div></div>
          )}
        </div>
      </div>

      <div class="cinema-copy">
        {scenes.map((s, i) => (
          <article class={`cm-scene${i === 0 ? ' on' : ''}`} data-scene={i}>
            <span class="eyebrow">{s.eyebrow}</span>
            <h2>{s.titel}</h2>
            <p>{s.text}</p>
            {s.cta && (
              <a href={ctaZiel} class="btn btn-primary">{ctaText}<span class="ico" set:html={I.arrow} /></a>
            )}
          </article>
        ))}
      </div>

      <div class="cinema-progress" aria-hidden="true"><i id="cinemaBar"></i></div>
      <div class="cinema-hint" id="cinemaHint">Scrollen</div>
    </div>
  </div>
</section>

<!-- [Trust] Endless Marquee -->
<div class="trust">
  <div class="trust-mask">
    <div class="trust-track">
      {trust.map((t) => (
        <div class="trust-item"><span class="ico" set:html={I.check} />{t}</div>
      ))}
      {trust.map((t) => (
        <div class="trust-item" aria-hidden="true"><span class="ico" set:html={I.check} />{t}</div>
      ))}
    </div>
  </div>
</div>

<!-- [Angebot] Vertical Reel — Angebot als auto-cycling Carousel
     (Komponente: src/components/showcase/VerticalReel.astro). -->
<section id="angebot" class="ang-sec">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Angebot</span>
      <h2>Vom Schnupperkurs bis zur Mitgliedschaft</h2>
      <p>Alles, was eine gute Golfanlage ausmacht — klar gegliedert, ohne versteckte Kosten.</p>
    </div>
    <div class="reveal">
      <VerticalReel items={angebot} bilder={galDefaults} />
    </div>
  </div>
</section>

<!-- [Platz] Fact Strip -->
<section class="platz-sec">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Der Platz</span>
      <h2>Gepflegt, fair, gut zu spielen</h2>
      <p>Ein Platz, der Anfängern Spaß macht und Geübte fordert — mit Übungsanlage direkt nebenan.</p>
    </div>
    <div class="platz-grid reveal">
      {platzFacts.map((f) => (
        <div class="platz-cell">
          <div class="platz-val">{f.val}</div>
          <div class="platz-lbl">{f.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- [Galerie] Course Strip -->
{galBilder.length > 0 && (
  <section class="gal-sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Impressionen</span>
        <h2>Ein Eindruck vom Platz</h2>
      </div>
      <div class="gal-grid reveal">
        {galBilder.map((g, i) => (
          <div class="gal-item" style={g.img ? '' : `background:${galerieVerlauf[i % galerieVerlauf.length]};`}>
            {g.img && <Image src={g.img} alt={g.alt} width={640} height={480} loading="lazy" />}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- [Team] Portrait Grid -->
{team.length > 0 && (
  <section id="team" class="team-sec">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Team &amp; PROs</span>
        <h2>Menschen, die Ihr Spiel besser machen</h2>
        <p>Ausgebildete PROs und ein Clubteam, das sich Zeit nimmt — für Einsteiger wie für Tiefhandicapper.</p>
      </div>
      <div class="team-grid">
        {team.map((t, i) => {
          const bild = clientImage(slug, t.bild) ?? (isShowcase ? teamDefaults[i] ?? null : null);
          return (
            <div class="team-card">
              <div class="avatar" style={bild ? '' : `background: ${palette[i % palette.length]};`}>
                {bild ? <Image src={bild} alt={t.name} width={96} height={96} /> : initialen(t)}
              </div>
              <h3>{t.name}</h3>
              <p>{t.rolle}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}

<!-- [Stimmen] Quote Wall -->
{bewertungen.length > 0 && (
  <section id="stimmen" class="stimmen-sec">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Mitgliederstimmen</span>
        <h2>Was unsere Mitglieder sagen</h2>
        <p>Durchschnittlich {bewAvgStr} von 5 Sternen aus {bewertungen.length} Bewertung{bewertungen.length === 1 ? '' : 'en'}.</p>
      </div>
      <div class="bew-grid reveal">
        {bewertungen.map((b) => (
          <div class="bew-card">
            <div class="bew-stars">{Array.from({ length: b.sterne }).map(() => <span class="ico" set:html={I.star} />)}</div>
            <p>„{b.text}"</p>
            <div class="bew-name">{b.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- [Scorecard] Self-Check — interaktiver Lead-Magnet (Priestley/ScoreApp-Methodik) -->
<section id="check" class="sc">
  <div class="wrap">
    <div class="sc-card" data-sc>
      <div class="sc-progress" aria-hidden="true"><i></i></div>

      <div class="sc-step" data-step="intro">
        <span class="eyebrow">{sc.kicker}</span>
        <h2>{sc.titel}</h2>
        <p class="sc-intro">{sc.intro}</p>
        <ul class="sc-meta">{sc.meta.map((m) => <li>{m}</li>)}</ul>
        <button type="button" class="btn btn-primary sc-start">{sc.startLabel}<span class="ico" set:html={I.arrow} /></button>
        <p class="sc-note">{sc.note}</p>
      </div>

      {sc.fragen.map((f, i) => (
        <div class="sc-step sc-q" data-step={`q${i}`} hidden>
          <div class="sc-qhead"><span class="sc-count">Frage {i + 1} / {sc.fragen.length}</span></div>
          <h3>{f.q}</h3>
          <div class="sc-opts">
            {f.a.map((o) => (
              <button type="button" class="sc-opt" data-points={o.p}>{o.t}</button>
            ))}
          </div>
          <button type="button" class="sc-back" data-back>← Zurück</button>
        </div>
      ))}

      <div class="sc-step sc-form" data-step="lead" hidden>
        <span class="eyebrow">Fast geschafft</span>
        <h3>{sc.leadTitel}</h3>
        <p class="sc-intro">{sc.leadSub}</p>
        <div class="sc-field"><label for="sc-name">Name</label><input id="sc-name" class="sc-in" type="text" data-req="name" autocomplete="name" /></div>
        <div class="sc-field"><label for="sc-mail">E-Mail</label><input id="sc-mail" class="sc-in" type="email" data-req="email" autocomplete="email" /></div>
        <div class="sc-field"><label for="sc-tel">Telefon (optional)</label><input id="sc-tel" class="sc-in" type="tel" autocomplete="tel" /></div>
        <p class="sc-err" data-err hidden>Bitte Namen und eine gültige E-Mail-Adresse angeben.</p>
        <button type="button" class="btn btn-primary sc-reveal">Mein Ergebnis ansehen<span class="ico" set:html={I.arrow} /></button>
        <p class="sc-note">Demo-Formular — Eingaben werden nicht übertragen oder gespeichert.</p>
      </div>

      <div class="sc-step sc-result" data-step="result" hidden>
        <span class="eyebrow">Ihr Ergebnis</span>
        <div class="sc-score"><b data-score>0</b><span>von 100 Punkten</span></div>
        <div class="sc-tierbadge" data-tierlabel>—</div>
        <p class="sc-tiermsg" data-tiermsg></p>
        <a href={ctaZiel} class="btn btn-primary sc-cta">{ctaText}<span class="ico" set:html={I.arrow} /></a>
        <button type="button" class="sc-restart" data-restart>Check neu starten</button>
        <div class="sc-tiers" hidden>
          {sc.tiers.map((t) => (
            <div class="sc-tier" data-min={t.min} data-label={t.label}>{t.msg}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- [Kontakt] Split Form -->
