];

// [Story] Fairway Cinema — selbst gehostetes 3D-Modell (nur Ball).
const ballSrc = '/models/golf/ball/scene.gltf';
const hasBall = existsSync(`${process.cwd()}/public/models/golf/ball/scene.gltf`);
const modelCredits = [
  hasBall && '3D-Modell „Golf Ball" von ree27703 (sketchfab.com/ree27703)',
].filter(Boolean).join(' · ');
const galerieVerlauf = [
  'linear-gradient(160deg,#0e2a18,#1d6f42 60%,#0e2a18)',
