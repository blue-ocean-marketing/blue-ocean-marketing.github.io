// Fragen niedrigschwellig, ohne Fachwissen, eine wacht die typische
// Einschüchterungs-Bremse aktiv auf und benennt sie. Siehe scoreapp.md.
const sc = {
  kicker: 'Kostenloser Selbst-Check',
  titel: 'Welcher Golf-Typ steckt in Ihnen?',
  intro: 'Sechs Fragen, kein Fachwissen nötig, in 2 Minuten. Am Ende wissen Sie, wie Ihr einfachster Einstieg aussieht — und was zu Ihnen passt.',
  meta: ['6 Fragen', 'ca. 2 Minuten', 'Sofort-Ergebnis'],
  startLabel: 'Los geht\'s',
  note: 'Entwickelt mit unseren PROs — für Neugierige genauso wie für Wiedereinsteiger.',
  fragen: [
    { q: 'Haben Sie schon einmal Golf gespielt?', a: [ { t: 'Noch nie', p: 1 }, { t: 'Ein-, zweimal probiert', p: 2 }, { t: 'Schon öfter', p: 3 } ] },
    { q: 'Haben Sie eine Platzreife (den Golf-Führerschein)?', a: [ { t: 'Ja', p: 3 }, { t: 'Habe angefangen', p: 2 }, { t: 'Nein', p: 1 } ] },
    { q: 'Wie oft sind Sie sportlich oder draußen aktiv?', a: [ { t: 'Regelmäßig', p: 3 }, { t: 'Ab und zu', p: 2 }, { t: 'Selten', p: 1 } ] },
    { q: 'Was reizt Sie am meisten am Golf?', a: [ { t: 'Rauskommen & entspannen', p: 2 }, { t: 'Neue Leute treffen', p: 2 }, { t: 'Mich sportlich fordern', p: 3 } ] },
    { q: 'Was hat Sie bisher abgehalten?', a: [ { t: 'Wirkt teuer oder elitär', p: 1 }, { t: 'Keine Zeit gefunden', p: 2 }, { t: 'Nichts — nur noch nicht gemacht', p: 3 } ] },
    { q: 'Würden Sie es unverbindlich ausprobieren, wenn es einfach gemacht wird?', a: [ { t: 'Auf jeden Fall', p: 3 }, { t: 'Wahrscheinlich', p: 2 }, { t: 'Vielleicht', p: 1 } ] },
  ],
  leadTitel: 'Wohin schicken wir Ihre Empfehlung?',
  leadSub: 'Ihr Ergebnis sehen Sie sofort. Kein Spam, versprochen — wir melden uns nur, wenn Sie es wünschen.',
  tiers: [
    { min: 0,  label: 'Der neugierige Einsteiger', msg: 'Sie sind genau richtig: ohne Vorkenntnisse, ohne Druck. Eine Schnupperrunde zeigt Ihnen in einer Stunde, wie entspannt Golf wirklich ist.' },
    { min: 50, label: 'Der startklare Wiedereinsteiger', msg: 'Die Basis ist da — jetzt fehlt nur der nächste Schritt. Ein Platzreife- oder Auffrischungskurs bringt Sie schnell auf den Platz.' },
    { min: 80, label: 'Der club-reife Spieler', msg: 'Sie spielen oder wollen es ernst angehen. Lohnt sich: Mitgliedschaft im ersten Jahr ohne Aufnahmegebühr — mehr Spiel, weniger Drumherum.' },
  ],
};
const platzFacts = [
  { val: '18', label: 'Loch · Par 72' },
  { val: '6.180 m', label: 'Meisterschafts-Länge' },
  { val: 'Driving Range', label: 'Überdacht & beleuchtet' },
  { val: 'ab 9:00', label: 'Tägliche Startzeiten' },
];
// [Story] Fairway Cinema — Copy-Szenen, am Scroll an die Ball-Bahn gekoppelt.
// Inhaltlich an dem orientiert, was Golfclubs online zeigen: Platz, Übungsanlage,
// Schwung/Golfschule, Clubhaus. Szene 0 & 4 tragen den Haupt-CTA.
const scenes = [
  { eyebrow: ort ? `Golfclub · ${ort}` : 'Willkommen', titel: 'Vom ersten Abschlag an.', text: 'Ein gepflegter Platz, kurze Wege und ein Team, das Golf einfach macht — vom Tee bis zum letzten Putt.', cta: true },
  { eyebrow: '18 Loch · Par 72', titel: 'Ein Platz mit Rhythmus.', text: 'Faire Bahnen für Einsteiger, fordernd für Geübte — und nie überlaufen. Golf im eigenen Tempo.' },
  { eyebrow: 'Übungsanlage', titel: 'Erst sauber einspielen.', text: 'Überdachte, beleuchtete Driving Range mit Putting- und Pitching-Grün. Direkt neben dem ersten Tee.' },
  { eyebrow: 'Der Schwung', titel: 'Dann einfach durch.', text: 'Ausholen, Tempo halten, sauber durchschwingen — Technik, die unsere PROs in Ruhe mit Ihnen feilen.' },
