    return (
      <div class={`hero-scene${i === 0 ? ' active' : ''}`} data-index={i}>
        <div class="scene-bg" style={`background:${verlauf[i % verlauf.length]};`}>
          {img && <Image src={img} alt={galerie[i]?.alt ?? o.titel} width={1600} height={1000} loading={i === 0 ? 'eager' : 'lazy'} />}
        </div>
        <div class="scene-orb"></div>
      </div>
    );
  })}

  {objekte.map((o, i) => {
    const n = splitName(o.titel);
    return (
      <div class={`hero-project${i === 0 ? ' active' : ''}`} data-index={i}>
        <div class="proj-meta">
          <span class="proj-badge">{o.hot ? 'Exklusiv' : 'Verkauf'}</span>
          {o.dauer && (
            <span class="proj-location">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {o.dauer}
            </span>
          )}
        </div>
        <h1 class="proj-title">{n.lead}{n.em && <em> {n.em}</em>}</h1>
        {o.text && <p class="proj-desc">{o.text}</p>}
