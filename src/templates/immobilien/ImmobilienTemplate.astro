---
// [Template] Immobilien — Luxus-Maklerseite (Cinematic-Hero · Objekte · Ablauf · Makler · Stimmen)
// Datengetrieben aus Client-Config (Form: clients/_schema.json). Optik 1:1 nach crownd.at:
// Vollbild-Foto-Szenen, Projekttext unten links, horizontale Thumbnail-Leiste zum Wechseln.
// Hero-Mechanik portiert aus dem statischen Build ~/Documents/immo (copy)/index.html.
// Neutrale Anthrazit-Basis bleibt fest — der Gold-Akzent kommt aus config.marke.farben.primary.
//
// Feld-Mapping (Schema = LeadBook-Schnittstelle, NICHT umbenennen — hier nur anders gerendert):
//   leistungen[] = Objekte: titel=Objektname · text=Beschreibung · preis=Preis · dauer=Lage · hot=Exklusiv-Badge
//   galerie[]    = Objektbilder, index-gekoppelt an leistungen[] (galerie[i] ↔ leistungen[i]);
//                  fehlt eins → web-optimiertes Default-Foto aus src/assets/immobilien/hero-N.webp
//   team[]       = Makler · bewertungen[] = Kundenstimmen
// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde): Trust-Bar, Ablauf-Schritte.
import { Image } from 'astro:assets';
import { clientImage } from '../_shared/clientImage';
// Agentur-eigene Default-Wortmarke (vom Nutzer erstellt). Weiß = über dem Foto-Hero,
// dunkel = bei gescrollter heller Nav. Greift nur für die Marke "Beyond Estates" —
// echte Kunden ohne eigenes Logo bekommen weiterhin ihre Text-Wortmarke (kein Fremd-Branding).
import logoDefaultDark from '../../assets/immobilien/logo.png';
import logoDefaultWhite from '../../assets/immobilien/logo-white.png';

interface Farben { primary: string; secondary?: string; accent?: string }
interface Objekt { icon?: string; titel: string; text?: string; preis?: string; dauer?: string; hot?: boolean }
interface Config {
  slug: string;
  marke: { name: string; slogan?: string | null; logo?: string | null; farben: Farben };
  kontakt: { adresse?: string | null; telefon: string; email: string; oeffnung?: string | null; instagram?: string | null };
  hero?: { ueberschrift?: string; text?: string; cta_text?: string; cta_ziel?: string } | null;
  leistungen?: Objekt[];
  team?: { name: string; rolle: string; bild?: string | null; initialen?: string | null }[];
  bewertungen?: { name: string; sterne: number; text: string }[];
  galerie?: { bild: string; alt?: string }[];
}

const { config } = Astro.props as { config: Config };
const { slug } = config;
const { name, slogan, logo, farben } = config.marke;
const { adresse, telefon, email, oeffnung, instagram } = config.kontakt;
const objekte = (config.leistungen ?? []).slice(0, 6);
const team = config.team ?? [];
const bewertungen = config.bewertungen ?? [];
const galerie = config.galerie ?? [];

// Nur die 3 Basisfarben werden injiziert, abgeleitete Töne via color-mix im :root.
const cssVars =
  `--c-primary:${farben.primary};` +
  `--c-secondary:${farben.secondary ?? farben.primary};` +
  `--c-accent:${farben.accent ?? farben.primary};`;

const logoImg = clientImage(slug, logo);
const useDefaultLogo = !logoImg && /beyond\s*estates/i.test(name);
const nameWords = name.split(' ');
const ort = adresse && adresse.includes(',') ? adresse.split(',').slice(-1)[0].trim() : '';

const titel = config.hero?.ueberschrift ?? slogan ?? 'Für Immobilien, die alles sind. Außer gewöhnlich.';
const heroText =
  config.hero?.text ??
  `Diskrete Vermittlung außergewöhnlicher Wohnobjekte${ort ? ` in ${ort}` : ''} — kuratiert, persönlich, ohne Kompromiss.`;
const ctaText = config.hero?.cta_text ?? 'Beratungstermin';
const ctaZiel = config.hero?.cta_ziel ?? '#kontakt';
const telHref = `tel:${telefon.replace(/\s/g, '')}`;

// Default-Hero-Fotos (web-optimiert, astro:assets) — Fallback wenn kein galerie[i]-Bild.
const heroGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/immobilien/hero-*.webp', { eager: true });
const heroDefaults = Object.keys(heroGlob).sort().map((k) => heroGlob[k].default);
const sceneImg = (i: number) => clientImage(slug, galerie[i]?.bild) ?? heroDefaults[i % (heroDefaults.length || 1)] ?? null;

// Zweifarbiger Projekttitel: erstes Wort normal, Rest als <em> (Gold). Einwort → ganz normal.
function splitName(t: string) {
  const sp = t.indexOf(' ');
  return sp > 0 ? { lead: t.slice(0, sp), em: t.slice(sp + 1) } : { lead: t, em: '' };
}
function initialen(t: { name: string; initialen?: string | null }) {
  if (t.initialen) return t.initialen;
  return t.name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
}

// Luxus-Duotones als Bild-Sockel (zeigt sich nur falls ein Foto fehlt)
const verlauf = [
  'linear-gradient(165deg,#0d0a04 0%,#3a2a10 38%,#5c4420 54%,#1a1206 100%)',
  'linear-gradient(165deg,#020810 0%,#0e2440 38%,#162f52 54%,#020508 100%)',
  'linear-gradient(165deg,#060d04 0%,#1c2e10 38%,#2a4018 54%,#040804 100%)',
  'linear-gradient(165deg,#0a0c14 0%,#222840 38%,#2e3550 54%,#0a0c14 100%)',
  'linear-gradient(165deg,#050908 0%,#152418 38%,#1e3022 54%,#050908 100%)',
  'linear-gradient(165deg,#100806 0%,#382210 38%,#502e16 54%,#100806 100%)',
];

// Sample-Inhalt (agentur-gepflegt, nicht pro Kunde personalisiert)
const trust = [
  { val: '180+', label: 'Vermittelte Objekte' },
  { val: '38 Tage', label: 'Ø bis Notartermin' },
  { val: '1,4 Mrd. €', label: 'Transaktionsvolumen' },
  { val: 'seit 1998', label: 'Am Markt' },
];
const ablauf = [
  { nr: '01', titel: 'Wertermittlung', text: 'Fundierte Marktbewertung Ihrer Immobilie — diskret, kostenfrei, in 48 Stunden.' },
  { nr: '02', titel: 'Inszenierung', text: 'Architekturfotografie, Exposé und gezielte Ansprache eines vorgemerkten Käuferkreises.' },
  { nr: '03', titel: 'Abschluss', text: 'Verhandlung, Bonitätsprüfung und Begleitung bis zum Notartermin — alles aus einer Hand.' },
];
---
<!doctype html>
<html lang="de" style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{name}{slogan ? ` — ${slogan}` : ''}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&display=optional" rel="stylesheet" />
  <style is:global>
    :root {
      --c-primary-dark: color-mix(in srgb, var(--c-primary) 62%, black);
      --c-primary-light: color-mix(in srgb, var(--c-primary) 58%, white);
      --c-p-08: color-mix(in srgb, var(--c-primary) 8%, transparent);
      --c-p-14: color-mix(in srgb, var(--c-primary) 14%, transparent);
      --c-p-22: color-mix(in srgb, var(--c-primary) 22%, transparent);
      --c-p-40: color-mix(in srgb, var(--c-primary) 40%, transparent);
      /* Neutrale Luxus-Basis — bewusst fest */
      --ink: #1c1c1e;
      --paper: #f7f4ee;
      --muted: #7a7166;
      --line: rgba(28,28,30,0.12);
      --font-display: 'Cormorant', Georgia, serif;
      --ease: 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: var(--ink); background: var(--paper); -webkit-font-smoothing: antialiased; }
    .serif { font-family: var(--font-display); font-weight: 500; }
    img { max-width: 100%; display: block; }

    /* DEMO BANNER */
    .demo-banner {
      background: #0d0d14; color: #94a3b8;
      text-align: center; padding: 0.6rem 1rem;
      font-size: 0.75rem; position: sticky; top: 0; z-index: 100;
      border-bottom: 1px solid var(--c-p-40);
    }
    .demo-banner a { color: var(--c-primary); text-decoration: none; font-weight: 600; }
    .demo-banner .cta-btn { background: var(--c-primary); color: #15110d; padding: 0.2rem 0.75rem; border-radius: 4px; margin-left: 0.75rem; }

    /* NAV — über dem Hero schwebend, wird beim Scrollen fest */
    nav {
      position: fixed; top: 37px; left: 0; right: 0; z-index: 50;
      padding: 1.25rem clamp(1.25rem, 4vw, 3rem);
      display: flex; align-items: center; justify-content: space-between;
      background: transparent; border-bottom: 1px solid transparent;
      transition: background var(--ease), border-color var(--ease);
    }
    nav.scrolled { background: color-mix(in srgb, var(--paper) 94%, transparent); backdrop-filter: blur(10px); border-bottom-color: var(--line); }
    .logo { font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; color: #fff; letter-spacing: 0.06em; text-transform: uppercase; transition: color var(--ease); }
    .logo span { color: var(--c-primary); }
    .logo img { height: 38px; width: auto; }
    .logo .logo-white, .logo .logo-dark { height: 30px; }
    .logo-dark { display: none; }
    nav.scrolled .logo-white { display: none; }
    nav.scrolled .logo-dark { display: inline-block; }
    nav.scrolled .logo { color: var(--ink); }
    .nav-links { display: flex; gap: 2.25rem; list-style: none; }
    .nav-links a { color: rgba(255,255,255,0.82); text-decoration: none; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; transition: color var(--ease); }
    .nav-links a:hover { color: var(--c-primary); }
    nav.scrolled .nav-links a { color: var(--muted); }
    nav.scrolled .nav-links a:hover { color: var(--c-primary); }
    .nav-cta {
      background: var(--c-primary); color: #15110d;
      padding: 0.7rem 1.5rem; font-size: 0.76rem; font-weight: 600;
      letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
      border-radius: 100px; min-height: 44px; display: inline-flex; align-items: center;
      transition: background var(--ease), transform var(--ease);
    }
    .nav-cta:hover { background: var(--c-primary-light); transform: translateY(-1px); }
    .nav-call { display: none; }
    @media (max-width: 860px) { .nav-links { display: none; } }
    @media (max-width: 600px) {
      .nav-cta { display: none; }
      .nav-call {
        display: inline-flex; align-items: center; justify-content: center;
        width: 44px; height: 44px; border-radius: 50%;
        background: var(--c-primary); color: #15110d; text-decoration: none; flex-shrink: 0;
      }
      .logo { font-size: 1.25rem; }
    }

    /* ════════ HERO — [Hero] Estate Cinematic (Vorbild: crownd.at) ════════ */
    .hero { position: relative; height: 100svh; min-height: 620px; overflow: hidden; }
    .hero-scene { position: absolute; inset: 0; opacity: 0; transition: opacity 1.4s cubic-bezier(0.4,0,0.2,1); z-index: 0; }
    .hero-scene.active { opacity: 1; }
    .scene-bg { position: absolute; inset: 0; }
    .scene-bg img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
    .scene-bg::before {
      content: ''; position: absolute; inset: 0; z-index: 1;
      background-image: linear-gradient(rgba(255,255,255,0.016) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.016) 1px, transparent 1px);
      background-size: 80px 80px;
    }
    .hero-scene::after {
      content: ''; position: absolute; inset: 0;
      background:
        linear-gradient(to right, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.28) 52%, rgba(0,0,0,0.06) 100%),
        linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 32%, rgba(0,0,0,0.1) 62%);
    }
    .scene-orb {
      position: absolute; inset: 0; z-index: 0;
      background: radial-gradient(ellipse 55% 68% at 75% 22%, var(--c-p-22) 0%, transparent 65%);
      animation: sceneOrb 14s ease-in-out infinite alternate;
    }
    @keyframes sceneOrb {
      0%   { transform: scale(1) translate(0,0); }
      50%  { transform: scale(1.14) translate(-4%,5%); }
      100% { transform: scale(0.92) translate(3%,-4%); }
    }

    .hero-project {
      position: absolute; bottom: 200px; left: clamp(2rem,6vw,5rem);
      z-index: 2; max-width: 580px;
      opacity: 0; transform: translateY(18px);
      transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
      pointer-events: none;
    }
    .hero-project.active { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .proj-meta { display: flex; align-items: center; gap: 0.875rem; margin-bottom: 0.8rem; }
    .proj-badge {
      display: inline-block; font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: #15110d; background: var(--c-primary);
      padding: 0.34rem 0.95rem; border-radius: 100px;
    }
    .proj-location { display: flex; align-items: center; gap: 0.38rem; font-size: 0.83rem; color: rgba(255,255,255,0.62); }
    .proj-title {
      font-family: var(--font-display); font-size: clamp(4.2rem,10vw,9rem);
      font-weight: 600; font-style: italic; color: #fff;
      line-height: 0.85; letter-spacing: -0.03em; margin-bottom: 1.1rem;
    }
    .proj-title em { font-style: normal; color: var(--c-primary-light); }
    .proj-desc {
      font-size: clamp(0.85rem,1.4vw,0.96rem); color: rgba(255,255,255,0.6);
      line-height: 1.72; font-weight: 300; max-width: 400px; margin-bottom: 1.7rem;
      display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    }
    .proj-cta {
      display: inline-flex; align-items: center; gap: 0.55rem;
      font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em;
      color: #15110d; background: var(--c-primary);
      padding: 0.9rem 1.9rem; border-radius: 100px; text-decoration: none;
      min-height: 44px; transition: background var(--ease), transform var(--ease), box-shadow var(--ease);
    }
    .proj-cta:hover { background: #fff; transform: translateY(-2px); box-shadow: 0 10px 28px rgba(0,0,0,0.4); }

    /* Side dots */
    .hero-dots { position: absolute; right: clamp(1.5rem,2.5vw,2.5rem); top: 50%; transform: translateY(-50%); z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 0.55rem; }
    .hero-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.25); cursor: pointer; transition: background 0.3s, transform 0.3s; }
    .hero-dot.active { background: #fff; transform: scale(1.5); }
    .hero-dot:hover:not(.active) { background: rgba(255,255,255,0.52); }

    /* Scroll cue */
    .hero-scroll { position: absolute; bottom: 215px; right: clamp(1.5rem,2.5vw,2.5rem); z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; opacity: 0; animation: fadeUp 1s 1.4s forwards; }
    .hero-scroll-line { width: 1px; height: 36px; background: linear-gradient(to bottom, rgba(255,255,255,0.35), transparent); animation: pulse 2.4s ease-in-out infinite; }
    .hero-scroll span { font-size: 0.57rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.3); writing-mode: vertical-rl; transform: rotate(180deg); }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes pulse { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }

    /* Thumbnail strip */
    .hero-thumbs {
      position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
      display: flex; gap: clamp(0.4rem,0.7vw,0.7rem);
      padding: clamp(0.8rem,1.5vw,1.1rem) clamp(1.5rem,4vw,3.5rem) clamp(1.5rem,2.5vw,2rem);
      overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch;
    }
    .hero-thumbs::-webkit-scrollbar { display: none; }
    .hero-thumb {
      position: relative; flex: 0 0 clamp(120px,13vw,195px);
      aspect-ratio: 16/10; cursor: pointer; border-radius: 5px; overflow: hidden;
      border: 2px solid transparent;
      transition: border-color 0.35s, transform 0.35s var(--ease), box-shadow 0.35s;
    }
    .hero-thumb.active { border-color: rgba(255,255,255,0.88); transform: translateY(-4px); box-shadow: 0 14px 36px rgba(0,0,0,0.55); }
    .hero-thumb:hover:not(.active) { border-color: rgba(255,255,255,0.32); transform: translateY(-2px); }
    .thumb-bg { position: absolute; inset: 0; }
    .thumb-bg img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .hero-thumb::before { content: ''; position: absolute; inset: 0; z-index: 1; background: linear-gradient(to top, rgba(0,0,0,0.74) 0%, rgba(0,0,0,0.1) 55%); }
    .thumb-label { position: absolute; bottom: 0.52rem; left: 0.65rem; right: 0.4rem; z-index: 2; font-family: var(--font-display); font-size: clamp(0.7rem,1.1vw,0.9rem); font-weight: 500; font-style: italic; color: #fff; line-height: 1.1; }
    .thumb-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 2.5px; background: var(--c-primary); transform: scaleX(0); transform-origin: left; transition: transform 0.45s var(--ease); z-index: 3; }
    .hero-thumb.active .thumb-bar { transform: scaleX(1); }

    @media (max-width: 768px) {
      .hero-project { bottom: 175px; left: 1.5rem; max-width: calc(100vw - 3rem); }
      .proj-title { font-size: clamp(2.8rem,14vw,5rem); }
      .hero-dots, .hero-scroll { display: none; }
    }
    @media (max-width: 480px) {
      .hero-thumb { flex: 0 0 105px; }
      .hero-project { bottom: 155px; }
    }

    /* TRUST BAR */
    .trust { border-bottom: 1px solid var(--line); padding: clamp(2rem, 4vw, 2.75rem) clamp(1.25rem, 4vw, 3rem); }
    .trust-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem; }
    .trust-cell { text-align: center; }
    .trust-val { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 600; color: var(--ink); }
    .trust-lbl { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-top: 0.4rem; }

    /* SECTIONS */
    section { padding: clamp(3.5rem, 7vw, 6rem) clamp(1.25rem, 4vw, 3rem); }
    .section-inner { max-width: 1240px; margin: 0 auto; }
    .section-head { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 3rem; }
    .section-head h2 { font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 500; font-style: italic; color: var(--ink); line-height: 1.12; }
    .eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--c-primary); display: block; margin-bottom: 0.6rem; }
    .section-head p { color: var(--muted); font-size: 0.92rem; max-width: 34ch; line-height: 1.7; }

    /* OBJEKTE GRID */
    .objekt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
    .objekt-card { text-decoration: none; color: inherit; display: block; }
    .objekt-media { position: relative; aspect-ratio: 3 / 2; overflow: hidden; background: var(--ink); }
    .objekt-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .objekt-card:hover .objekt-media img { transform: scale(1.05); }
    .objekt-badge {
      position: absolute; top: 1rem; left: 1rem;
      background: var(--c-primary); color: #15110d;
      font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      padding: 0.3rem 0.7rem; border-radius: 100px;
    }
    .objekt-body { padding: 1.25rem 0.25rem; border-bottom: 1px solid var(--line); }
    .objekt-loc { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c-primary); margin-bottom: 0.5rem; }
    .objekt-name { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; font-style: italic; color: var(--ink); margin-bottom: 0.35rem; }
    .objekt-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }
    .objekt-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; }
    .objekt-price { font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; color: var(--ink); }
    .objekt-more { font-size: 0.74rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-primary); }

    /* SIGNATURE — [Video] Signature Reel */
    .signature { position: relative; min-height: clamp(520px, 80vh, 820px); display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; background: var(--ink); }
    .sig-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
    .sig-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(rgba(20,18,16,0.5) 0%, rgba(20,18,16,0.62) 100%); }
    .sig-inner { position: relative; z-index: 2; padding: 3rem clamp(1.25rem, 5vw, 3rem); max-width: 760px; }
    .sig-eyebrow { display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--c-primary); margin-bottom: 1.5rem; }
    .sig-title { font-family: var(--font-display); color: #fff; font-size: clamp(2.4rem, 6vw, 5rem); font-weight: 600; line-height: 1.05; letter-spacing: 0.04em; text-transform: uppercase; }
    .sig-title em { font-style: italic; text-transform: none; font-weight: 500; letter-spacing: 0; color: var(--c-primary-light); }
    .sig-sub { color: rgba(255,255,255,0.8); font-size: clamp(0.95rem, 1.6vw, 1.15rem); line-height: 1.7; font-weight: 300; margin: 1.25rem auto 2rem; max-width: 32ch; }
    .sig-cta { display: inline-flex; align-items: center; gap: 0.55rem; background: var(--c-primary); color: #15110d; padding: 0.95rem 2.2rem; border-radius: 100px; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; min-height: 44px; transition: background var(--ease), transform var(--ease); }
    .sig-cta:hover { background: #fff; transform: translateY(-2px); }
    .sig-search { display: flex; align-items: center; gap: 0.65rem; width: min(420px, 100%); margin: 2.25rem auto 0; background: #fff; border-radius: 100px; padding: 0.9rem 1.6rem; color: var(--muted); font-size: 0.92rem; text-decoration: none; min-height: 44px; }
    .sig-search svg { color: var(--c-primary); flex-shrink: 0; }
    .sig-search:hover { color: var(--ink); }

    /* ABLAUF */
    .ablauf-bg { background: var(--ink); color: var(--paper); }
    .ablauf-bg .section-head h2 { color: var(--paper); }
    .ablauf-bg .section-head p { color: rgba(247,244,238,0.55); }
    .ablauf-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2.5rem; }
    .ablauf-step { border-top: 1px solid rgba(247,244,238,0.18); padding-top: 1.5rem; }
    .ablauf-nr { font-family: var(--font-display); font-size: 2.5rem; font-weight: 600; font-style: italic; color: var(--c-primary); margin-bottom: 1rem; }
    .ablauf-step h3 { font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; margin-bottom: 0.75rem; }
    .ablauf-step p { font-size: 0.88rem; line-height: 1.7; color: rgba(247,244,238,0.6); }

    /* MAKLER */
    .makler-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; }
    .makler-photo { aspect-ratio: 1; overflow: hidden; background: var(--ink); margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; }
    .makler-photo img { width: 100%; height: 100%; object-fit: cover; }
    .makler-ini { font-family: var(--font-display); font-size: 2.5rem; font-style: italic; color: var(--c-primary); }
    .makler-name { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: var(--ink); }
    .makler-rolle { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-top: 0.3rem; }

    /* STIMMEN */
    .stimmen-bg { background: color-mix(in srgb, var(--c-primary) 6%, var(--paper)); }
    .stimmen-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
    .stimme { background: var(--paper); border: 1px solid var(--line); padding: 2.25rem; }
    .stimme-stars { color: var(--c-primary); letter-spacing: 0.25em; font-size: 0.8rem; margin-bottom: 1.25rem; }
    .stimme-text { font-family: var(--font-display); font-size: 1.25rem; font-style: italic; line-height: 1.55; color: var(--ink); margin-bottom: 1.5rem; }
    .stimme-name { font-size: 0.76rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }

    /* KONTAKT */
    .kontakt-bg { background: var(--ink); color: var(--paper); }
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2.5rem, 5vw, 5rem); align-items: center; }
    @media (max-width: 820px) { .kontakt-grid { grid-template-columns: 1fr; } }
    .kontakt-bg h2 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; font-style: italic; line-height: 1.12; margin-bottom: 1.25rem; }
    .kontakt-bg .lead { color: rgba(247,244,238,0.6); font-size: 0.98rem; line-height: 1.75; margin-bottom: 2.5rem; max-width: 40ch; }
    .kontakt-row { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-top: 1px solid rgba(247,244,238,0.15); }
    .kontakt-row:last-child { border-bottom: 1px solid rgba(247,244,238,0.15); }
    .kontakt-row .k-lbl { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c-primary); width: 6rem; flex-shrink: 0; }
    .kontakt-row a, .kontakt-row span { color: var(--paper); text-decoration: none; font-size: 0.95rem; }
    .kontakt-cta {
      display: inline-flex; align-items: center; gap: 0.6rem;
      background: var(--c-primary); color: #15110d;
      padding: 1rem 2rem; font-size: 0.82rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
      border-radius: 100px; margin-top: 2.5rem; min-height: 44px;
    }
    .kontakt-cta:hover { background: var(--c-primary-light); }

    /* FOOTER */
    footer { background: #141214; color: rgba(247,244,238,0.4); padding: 3rem clamp(1.25rem, 4vw, 3rem) 2.5rem; text-align: center; font-size: 0.8rem; }
    footer .f-name { font-family: var(--font-display); font-size: 1.4rem; font-style: italic; color: rgba(247,244,238,0.7); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.75rem; }
    footer a { color: var(--c-primary); text-decoration: none; }
    footer .f-legal { margin-top: 0.75rem; font-size: 0.72rem; opacity: 0.6; }
  </style>
</head>
<body>

