  🎨 Musterseite von <a href="/">Blue Ocean Marketing</a> — mit Ihrem Branding in 48h personalisiert.
  <a href="https://blue-ocean.marketing/kontakt/" target="_blank" rel="noopener" class="cta-btn">Demo anfragen →</a>
</div>

<!-- NAV -->
<nav id="nav">
  <div class="logo">
    {logoImg
      ? <Image src={logoImg} alt={name} height={38} width={Math.round(38 * (logoImg.width / logoImg.height))} />
      : useDefaultLogo
        ? <Fragment>
            <Image class="logo-white" src={logoDefaultWhite} alt={name} height={30} width={Math.round(30 * (logoDefaultWhite.width / logoDefaultWhite.height))} />
            <Image class="logo-dark" src={logoDefaultDark} alt={name} height={30} width={Math.round(30 * (logoDefaultDark.width / logoDefaultDark.height))} />
          </Fragment>
        : <Fragment>{nameWords[0]} {nameWords.length > 1 && <span>{nameWords.slice(1).join(' ')}</span>}</Fragment>}
  </div>
  <ul class="nav-links">
    <li><a href="#objekte">Objekte</a></li>
    <li><a href="#ablauf">Ablauf</a></li>
    <li><a href="#makler">Team</a></li>
    <li><a href="#kontakt">Kontakt</a></li>
  </ul>
  <a href={ctaZiel} class="nav-cta">{ctaText}</a>
