---
// [Template] Zahnarzt — Praxis-Demo (Hero-Card · Leistungen · Team · Bewertungen · Kontaktformular)
// Datengetrieben aus einer Client-Config (Form: clients/_schema.json).
// Styles 1:1 aus der ursprünglichen Standalone-Seite portiert — nur Markenfarben
// sind jetzt CSS-Variablen aus config.marke.farben (das ist genau das injizierte Element).
// Genutzte Config-Felder: marke (name, slogan, logo, farben), kontakt, hero?, leistungen, team, bewertungen.
import { Image } from 'astro:assets';
import { clientImage } from '../_shared/clientImage';

interface Farben { primary: string; secondary?: string; accent?: string }
interface Config {
  slug: string;
  marke: { name: string; slogan?: string | null; logo?: string | null; farben: Farben };
  kontakt: { adresse?: string | null; telefon: string; email: string; oeffnung?: string | null };
  hero?: { ueberschrift?: string; text?: string } | null;
  leistungen?: { icon?: string; titel: string; text: string }[];
  team?: { name: string; rolle: string; bild?: string | null; initialen?: string | null }[];
  bewertungen?: { name: string; sterne: number; text: string }[];
}

const { config } = Astro.props as { config: Config };
const { slug } = config;
const { name, slogan, logo, farben } = config.marke;
const { adresse, telefon, email, oeffnung } = config.kontakt;
const leistungen = config.leistungen ?? [];
const team = config.team ?? [];
const bewertungen = config.bewertungen ?? [];

// Avatar-Palette: zyklisch durch die Markenfarben (ersetzt die früheren festen Einzelfarben)
const palette = [farben.primary, farben.secondary ?? farben.primary, farben.accent ?? farben.primary];

// CSS-Variablen: nur die 3 Basisfarben werden injiziert, abgeleitete Töne via color-mix
const cssVars =
  `--c-primary:${farben.primary};` +
  `--c-secondary:${farben.secondary ?? farben.primary};` +
  `--c-accent:${farben.accent ?? farben.primary};`;

// Ort sicher aus der Adresse ableiten (Adresse kann null sein / kein Komma haben)
const ort = adresse && adresse.includes(',') ? adresse.split(',')[1].trim() : '';

const logoImg = clientImage(slug, logo);
const titel = config.hero?.ueberschrift ?? slogan ?? name;
const heroText =
  config.hero?.text ??
  `Moderne Zahnmedizin${ort ? ` in ${ort}` : ''} — einfühlsam, schmerzfrei und auf dem neuesten Stand der Technik.`;
const telHref = `tel:${telefon.replace(/\s/g, '')}`;

function initialen(t: { name: string; initialen?: string | null }) {
  if (t.initialen) return t.initialen;
  return t.name.split(' ').map((w) => w[0]).slice(0, 2).join('').toUpperCase();
}
---
<!doctype html>
<html lang="de" style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{name}{slogan ? ` — ${slogan}` : ''}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=optional" rel="stylesheet" />
  <style is:global>
    :root {
      --c-primary-dark: color-mix(in srgb, var(--c-primary) 80%, black);
      --c-tint:  color-mix(in srgb, var(--c-primary) 8%, white);
      --c-tint2: color-mix(in srgb, var(--c-primary) 14%, white);
      --c-primary-12: color-mix(in srgb, var(--c-primary) 12%, transparent);
      --c-primary-25: color-mix(in srgb, var(--c-primary) 25%, transparent);
      --c-primary-30: color-mix(in srgb, var(--c-primary) 30%, transparent);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #1e293b; background: #fff; }
    .serif { font-family: 'Playfair Display', Georgia, serif; }

    /* DEMO BANNER */
    .demo-banner {
      background: #0d0d14;
      color: #94a3b8;
      text-align: center;
      padding: 0.6rem 1rem;
      font-size: 0.75rem;
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--c-primary-30);
    }
    .demo-banner a { color: var(--c-primary); text-decoration: none; font-weight: 600; }

    /* NAV */
    nav {
      background: #fff;
      border-bottom: 1px solid #e2e8f0;
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 37px;
      z-index: 50;
    }
    .nav-logo { font-size: 1.1rem; font-weight: 700; color: #0f172a; }
    .nav-logo span { color: var(--c-primary); }
    .nav-logo img { height: 40px; width: auto; display: block; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: #475569; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
    .nav-cta {
      background: var(--c-primary); color: white;
      padding: 0.6rem 1.5rem; border-radius: 8px;
      font-size: 0.875rem; font-weight: 600;
      text-decoration: none; border: none; cursor: pointer;
    }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, var(--c-tint) 0%, var(--c-tint2) 50%, var(--c-tint) 100%);
      padding: 5rem 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      max-width: 1200px;
      margin: 0 auto;
      align-items: center;
    }
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; gap: 2rem; }
      .nav-links { display: none; }
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--c-primary-12); color: var(--c-primary-dark);
      border: 1px solid var(--c-primary-25);
      border-radius: 100px; padding: 0.375rem 1rem;
      font-size: 0.78rem; font-weight: 600; margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700; line-height: 1.2;
      color: #0f172a; margin-bottom: 1.25rem;
    }
    .hero p { color: #475569; font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-primary {
      background: var(--c-primary); color: white;
      padding: 0.875rem 2rem; border-radius: 10px;
      font-size: 0.95rem; font-weight: 600;
      text-decoration: none;
    }
    .btn-secondary {
      background: transparent; color: var(--c-primary);
      border: 2px solid var(--c-primary);
      padding: 0.875rem 2rem; border-radius: 10px;
      font-size: 0.95rem; font-weight: 600;
      text-decoration: none;
    }
    .hero-card {
      background: white; border-radius: 20px;
      padding: 2rem; box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    }
    .hero-card h3 { color: #0f172a; font-size: 1.1rem; font-weight: 600; margin-bottom: 1.25rem; }
    .info-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.875rem; font-size: 0.875rem; color: #475569; }
    .info-icon { width: 36px; height: 36px; background: var(--c-tint); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1rem; }

    /* SECTION */
    section { padding: 5rem 2rem; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 3rem; }
    .section-label { font-size: 0.78rem; font-weight: 700; color: var(--c-primary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
    .section-title { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; color: #0f172a; margin-bottom: 0.75rem; }
    .section-sub { color: #64748b; font-size: 0.975rem; max-width: 560px; margin: 0 auto; line-height: 1.6; }

    /* LEISTUNGEN GRID */
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .leistung-card {
      background: #f8fafc; border: 1px solid #e2e8f0;
      border-radius: 16px; padding: 1.75rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .leistung-card:hover { box-shadow: 0 8px 30px var(--c-primary-12); transform: translateY(-2px); }
    .leistung-icon { font-size: 2rem; margin-bottom: 1rem; }
    .leistung-card h3 { font-size: 1rem; font-weight: 600; color: #0f172a; margin-bottom: 0.5rem; }
    .leistung-card p { color: #64748b; font-size: 0.875rem; line-height: 1.6; }

    /* TEAM */
    .team-bg { background: #f8fafc; }
    .grid-4 { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; }
    .team-card { background: white; border-radius: 16px; padding: 2rem 1.5rem; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .avatar { width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem; color: white; margin: 0 auto 1rem; overflow: hidden; }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .team-card h3 { font-size: 1rem; font-weight: 600; color: #0f172a; margin-bottom: 0.25rem; }
    .team-card p { color: #64748b; font-size: 0.8rem; }

    /* BEWERTUNGEN */
    .grid-bewertungen { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .bew-card { background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 1.75rem; }
    .sterne { color: #f59e0b; font-size: 1rem; margin-bottom: 0.75rem; }
    .bew-card p { color: #475569; font-size: 0.9rem; line-height: 1.65; margin-bottom: 1rem; font-style: italic; }
    .bew-name { font-size: 0.85rem; font-weight: 600; color: #0f172a; }

    /* KONTAKT */
    .kontakt-bg { background: linear-gradient(135deg, var(--c-primary-dark), var(--c-primary)); color: white; }
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    @media (max-width: 768px) { .kontakt-grid { grid-template-columns: 1fr; } }
    .kontakt-bg h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin-bottom: 1rem; }
    .kontakt-bg p { opacity: 0.85; line-height: 1.7; margin-bottom: 1.5rem; }
    .kontakt-btn { display: inline-block; background: white; color: var(--c-primary-dark); padding: 0.875rem 2rem; border-radius: 10px; font-weight: 600; text-decoration: none; }
    .form-group { margin-bottom: 1rem; }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%; padding: 0.75rem 1rem;
      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
      border-radius: 8px; color: white; font-size: 0.9rem; font-family: inherit;
    }
    .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,0.6); }
    .form-group select option { color: #0f172a; background: white; }
    .form-btn {
      width: 100%; background: white; color: var(--c-primary-dark);
      padding: 0.875rem; border-radius: 8px;
      font-weight: 700; font-size: 0.95rem;
      border: none; cursor: pointer;
    }

    /* FOOTER */
    footer { background: #0f172a; color: #64748b; padding: 2rem; text-align: center; font-size: 0.8rem; }
    footer a { color: #94a3b8; text-decoration: none; margin: 0 0.5rem; }
  </style>
</head>
<body>

<!-- DEMO BANNER -->
<div class="demo-banner">
  🎨 Dies ist eine Musterseite von <a href="/">Blue Ocean Marketing</a> — personalisiert mit Ihrem Logo &amp; Ihren Farben in 48h.
  <a href="https://blue-ocean.marketing/kontakt/" target="_blank" rel="noopener" style="margin-left: 0.75rem; background: var(--c-primary); color: white; padding: 0.2rem 0.75rem; border-radius: 4px;">Demo anfragen →</a>
</div>

<!-- NAV -->
<nav>
  <div class="nav-logo">
    {logoImg
      ? <Image src={logoImg} alt={name} height={40} width={Math.round(40 * (logoImg.width / logoImg.height))} />
      : <Fragment>{name.split(' ')[0]} <span>{name.split(' ').slice(1).join(' ')}</span></Fragment>}
  </div>
  <ul class="nav-links">
    <li><a href="#leistungen">Leistungen</a></li>
    <li><a href="#team">Unser Team</a></li>
    <li><a href="#bewertungen">Bewertungen</a></li>
    <li><a href="#kontakt">Kontakt</a></li>
  </ul>
  <a href={telHref} class="nav-cta">📞 Termin vereinbaren</a>
</nav>

<!-- HERO -->
<div style="background: linear-gradient(135deg, var(--c-tint) 0%, var(--c-tint2) 50%, var(--c-tint) 100%); padding: 0 2rem;">
  <div class="hero">
    <div>
      <div class="hero-badge">⭐ 4,9 / 5 — über 200 Bewertungen</div>
      <h1>{titel}</h1>
      <p>{heroText}</p>
      <div class="hero-actions">
        <a href="#kontakt" class="btn-primary">Termin online buchen</a>
        <a href="#leistungen" class="btn-secondary">Unsere Leistungen</a>
      </div>
    </div>
    <div class="hero-card">
      <h3>🗓️ Schnell einen Termin buchen</h3>
      {adresse && (
        <div class="info-row"><div class="info-icon">📍</div><span>{adresse}</span></div>
      )}
      <div class="info-row"><div class="info-icon">📞</div><span>{telefon}</span></div>
      {oeffnung && (
        <div class="info-row"><div class="info-icon">⏰</div><span>{oeffnung}</span></div>
      )}
      <div class="info-row"><div class="info-icon">✉️</div><span>{email}</span></div>
      <a href="#kontakt" style="display: block; background: var(--c-primary); color: white; text-align: center; padding: 0.875rem; border-radius: 10px; font-weight: 600; text-decoration: none; margin-top: 1.25rem;">
        Jetzt Termin anfragen →
      </a>
    </div>
  </div>
</div>

<!-- VERTRAUEN -->
<section style="padding: 2rem; background: white; border-bottom: 1px solid #f1f5f9;">
  <div style="max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; text-align: center;">
    {[
      { val: '15+', label: 'Jahre Erfahrung' },
      { val: '3.500+', label: 'Zufriedene Patienten' },
      { val: '4,9 ⭐', label: 'Ø Bewertung' },
      { val: '0', label: 'Wartezeit mit Termin' },
    ].map(s => (
      <div>
        <div style="font-size: 1.6rem; font-weight: 700; color: var(--c-primary);">{s.val}</div>
        <div style="font-size: 0.8rem; color: #64748b; margin-top: 0.2rem;">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- LEISTUNGEN -->
<section id="leistungen">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-label">Was wir anbieten</div>
      <h2 class="section-title">Unsere Leistungen</h2>
      <p class="section-sub">Von der Vorsorge bis zur kosmetischen Zahnmedizin — alles aus einer Hand.</p>
    </div>
    <div class="grid-3">
      {leistungen.map(l => (
        <div class="leistung-card">
          <div class="leistung-icon">{l.icon}</div>
          <h3>{l.titel}</h3>
          <p>{l.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TEAM -->
<section id="team" class="team-bg">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-label">Wir sind für Sie da</div>
      <h2 class="section-title">Unser Team</h2>
      <p class="section-sub">Erfahren, einfühlsam und stets auf dem neuesten Stand der Zahnmedizin.</p>
    </div>
    <div class="grid-4">
      {team.map((t, i) => {
        const bild = clientImage(slug, t.bild);
        return (
          <div class="team-card">
            <div class="avatar" style={bild ? '' : `background: ${palette[i % palette.length]};`}>
              {bild ? <Image src={bild} alt={t.name} width={72} height={72} /> : initialen(t)}
            </div>
            <h3>{t.name}</h3>
            <p>{t.rolle}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- BEWERTUNGEN -->
<section id="bewertungen">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-label">Was Patienten sagen</div>
      <h2 class="section-title">Bewertungen</h2>
      <p class="section-sub">Über 200 Bewertungen mit durchschnittlich 4,9 von 5 Sternen.</p>
    </div>
    <div class="grid-bewertungen">
      {bewertungen.map(b => (
        <div class="bew-card">
          <div class="sterne">{'★'.repeat(b.sterne)}</div>
          <p>„{b.text}"</p>
          <div class="bew-name">— {b.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- KONTAKT -->
<section id="kontakt" class="kontakt-bg">
  <div class="section-inner">
    <div class="kontakt-grid">
      <div>
        <h2>Termin vereinbaren</h2>
        <p>Rufen Sie uns an oder schreiben Sie uns — wir melden uns innerhalb von 24 Stunden bei Ihnen.</p>
        <div style="display: flex; flex-direction: column; gap: 0.875rem; margin-bottom: 2rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; opacity: 0.9;">
            <span style="font-size: 1.2rem;">📞</span> {telefon}
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; opacity: 0.9;">
            <span style="font-size: 1.2rem;">✉️</span> {email}
          </div>
          {adresse && (
            <div style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; opacity: 0.9;">
              <span style="font-size: 1.2rem;">📍</span> {adresse}
            </div>
          )}
          {oeffnung && (
            <div style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; opacity: 0.9;">
              <span style="font-size: 1.2rem;">⏰</span> {oeffnung}
            </div>
          )}
        </div>
      </div>
      <div>
        <div style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 16px; padding: 2rem;">
          <h3 style="color: white; font-weight: 600; margin-bottom: 1.25rem;">Terminanfrage</h3>
          <div class="form-group">
            <input type="text" placeholder="Ihr Name" />
          </div>
          <div class="form-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <input type="tel" placeholder="Telefon" style="padding: 0.75rem 1rem; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 8px; color: white; font-size: 0.9rem;" />
            <input type="email" placeholder="E-Mail" style="padding: 0.75rem 1rem; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 8px; color: white; font-size: 0.9rem;" />
          </div>
          <div class="form-group">
            <select style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 8px; color: rgba(255,255,255,0.8); font-size: 0.9rem; font-family: inherit;">
              <option value="">Gewünschte Leistung</option>
              <option>Professionelle Reinigung</option>
              <option>Bleaching</option>
              <option>Implantologie</option>
              <option>Zahnersatz</option>
              <option>Notfallbehandlung</option>
            </select>
          </div>
          <div class="form-group">
            <textarea rows="3" placeholder="Ihre Nachricht (optional)" style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 8px; color: white; font-size: 0.9rem; font-family: inherit; resize: vertical;"></textarea>
          </div>
          <button class="form-btn">Terminanfrage senden →</button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p>{name}{adresse ? ` | ${adresse}` : ''} | {telefon}</p>
  <p style="margin-top: 0.5rem;">
    <a href="#">Impressum</a> · <a href="#">Datenschutz</a> · <a href="#">Barrierefreiheit</a>
  </p>
  <p style="margin-top: 0.75rem; font-size: 0.72rem; opacity: 0.5;">
    Demo-Website erstellt von <a href="/" style="color: var(--c-primary);">Blue Ocean Marketing</a>
  </p>
</footer>

</body>
</html>
