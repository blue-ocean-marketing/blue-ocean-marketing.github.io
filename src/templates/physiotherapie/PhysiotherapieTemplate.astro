<script>
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Scroll-Reveal beim Eintreten */
    var els = document.querySelectorAll('.reveal');
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach(function (e) { e.classList.add('in'); });
    } else {
      var io = new IntersectionObserver(function (ents) {
        ents.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { rootMargin: '0px 0px -12% 0px', threshold: 0.12 });
      els.forEach(function (e) { io.observe(e); });
    }

    /* [Hero] Practice Open — Geräte-Reel + Crossfade.
       Reduced-Motion oder Save-Data → gar kein Video, Poster bleibt stehen. */
    (function () {
      var cine = document.querySelector('.cine');
      if (!cine) return;
      var conn = navigator.connection || {};
      if (reduce || conn.saveData === true) return;

      var sel = window.matchMedia('(max-width: 767px)').matches ? 'm' : 'd';
      var vids = [];
      [].slice.call(cine.querySelectorAll('.cine-vid')).forEach(function (v) {
        if (v.getAttribute('data-reel') === sel) vids.push(v);
        else if (v.parentNode) v.parentNode.removeChild(v);
      });
      if (!vids.length) return;
      vids.forEach(function (v) { v.src = v.getAttribute('data-src'); v.load(); });

      function play(v) { var p = v.play(); if (p && p.catch) p.catch(function () {}); }

      if (vids.length === 1) {
        vids[0].loop = true;
        vids[0].classList.add('on');
        play(vids[0]);
        return;
      }

      var i = 0, switching = false;
      function show(n) { vids[n].classList.add('on'); vids[n].currentTime = 0; play(vids[n]); }
      function advance() {
        if (switching) return;
        switching = true;
        var prev = vids[i];
        i = (i + 1) % vids.length;
        show(i);
        setTimeout(function () {
          prev.classList.remove('on'); prev.pause();
          switching = false;
        }, 1200);
      }
      vids.forEach(function (v) {
        v.addEventListener('timeupdate', function () {
          if (v === vids[i] && v.duration && v.currentTime >= v.duration - 1.0) advance();
        });
        v.addEventListener('ended', function () { if (v === vids[i]) advance(); });
      });
      show(0);
    })();

    /* ─────────── [Story] Spine Cinema — Anatomie-Tour ───────────
       Die Säule steht ruhig (Drehung pendelt nur ±15°), die Kamera schwenkt
       pro Szene vertikal auf einen anderen Abschnitt (Hals → Brust → LWS →
       Übersicht) und zoomt rein/raus. cameraTarget-Offsets werden in Prozent
       der Modellhöhe ausgedrückt — unabhängig von der konkreten gltf-Skalierung.
       Anders als Golf/Zahnarzt rollt/dreht hier nichts dauerhaft — der Look
       ist ruhig, lehrbuchartig.
       Gestapelt (Reduced-Motion) → .is-static, Kamera steht ganz ruhig. */
    (function () {
      var cinema = document.querySelector('.cinema');
      if (!cinema) return;

      var track   = document.getElementById('cinemaTrack');
      var bar     = document.getElementById('cinemaBar');
      var hint    = document.getElementById('cinemaHint');
      var spineBox = cinema.querySelector('.cm-spine');
      var aura    = cinema.querySelector('.cm-aura');
      var spine   = document.getElementById('spineViewer');
      var scenes  = [].slice.call(cinema.querySelectorAll('.cm-scene'));
      var N = scenes.length || 1;
      if (!track) return;

      function clamp(v, a, b) { return v < a ? a : (v > b ? b : v); }
      function lerp(a, b, t) { return a + (b - a) * t; }

      /* Choreografie-Tabelle: je Szene Scroll-Band [a,b], Ein-/Ausblend-
         Zonen (fi/fo), feste Text-Seite, Spine-Drift (sx in vw),
         Radius (% Default), und tyPct = vertikaler Kamera-Schwenk als
         Anteil der Modellhöhe. Achtung: dieses gltf ist intern head-down
         orientiert — positives Y in Modellkoords = Richtung Sakrum/LWS,
         negatives Y = Richtung Halswirbel. Darum wirkt "+" wie Schwenk
         nach UNTEN am Bildschirm, "-" wie Schwenk nach OBEN.
         Säule steht IMMER auf der dem Text gegenüberliegenden Bildhälfte. */
      var BANDS = [
        /* Szene 0 (Intro):       Übersicht, weit weg, Kamera mittig          */
        { a: 0.00, b: 0.15, fi: 0.00, fo: 0.05, side: 'left',  sx:  22, rad: 135, tyPct:  0.00 },
        /* Szene 1 (Untersuchung): Halswirbel — Kamera schwenkt HOCH, nah ran */
        { a: 0.20, b: 0.40, fi: 0.05, fo: 0.05, side: 'right', sx: -22, rad:  72, tyPct: -0.32 },
        /* Szene 2 (Behandlung):   Brustwirbel — leicht oberhalb Mitte, nah   */
        { a: 0.44, b: 0.62, fi: 0.04, fo: 0.05, side: 'left',  sx:  22, rad:  72, tyPct: -0.05 },
        /* Szene 3 (Bewegung):     LWS — Kamera schwenkt RUNTER, nah ran      */
        { a: 0.66, b: 0.82, fi: 0.04, fo: 0.05, side: 'right', sx: -22, rad:  78, tyPct:  0.28 },
        /* Szene 4 (CTA):          zurück zur Übersicht, weit                  */
        { a: 0.86, b: 1.00, fi: 0.05, fo: 0.00, side: 'left',  sx:  22, rad: 135, tyPct:  0.00 }
      ];
      function bandOpacity(p, B) {
        if (p < B.a || p > B.b) return 0;
        if (B.fi > 0 && p < B.a + B.fi) return (p - B.a) / B.fi;
        if (B.fo > 0 && p > B.b - B.fo) return clamp((B.b - p) / B.fo, 0, 1);
        return 1;
      }
      /* Seite einmalig als CSS-Klasse setzen (CSS ankert left/right) */
      scenes.forEach(function (s, i) {
        s.classList.remove('on');
        s.classList.add('side-' + ((BANDS[i] && BANDS[i].side) || 'left'));
      });

      /* Modellhöhe (Meter) — wird nach Load gesetzt; default 1 = neutraler
         Schwenk falls API nicht greift (kein Crash, nur kleinere Wirkung). */
      var modelH = 1;
      /* Center der Bounding-Box (Meter) — wird nach Load aus
         model.getBoundingBoxCenter() befüllt. Wir schwenken relativ dazu. */
      var modelCx = 0, modelCy = 0, modelCz = 0;

      /* Kamera nur setzen, wenn model-viewer wirklich da & bereit ist.
         targetY = Meter-Offset relativ zum Modell-Center (+ = hoch). */
      function orbit(el, theta, phi, rad, targetY) {
        if (!el || !el.jumpCameraToGoal) return;
        el.cameraOrbit = theta.toFixed(1) + 'deg ' + phi.toFixed(1) + 'deg ' + rad.toFixed(0) + '%';
        if (typeof targetY === 'number') {
          el.cameraTarget =
            modelCx.toFixed(3) + 'm ' +
            (modelCy + targetY).toFixed(3) + 'm ' +
            modelCz.toFixed(3) + 'm';
        }
        el.jumpCameraToGoal();
      }

      /* aktuelle Band-Werte (sx, rad, tyPct) per scrollP — sanft zwischen
         Bändern interpolieren, sonst springen Drift, Zoom und Schwenk. */
      function bandValues(p) {
        for (var i = 0; i < BANDS.length; i++) {
          var B = BANDS[i], Nx = BANDS[i + 1];
          if (Nx && p > B.b && p < Nx.a) {
            /* zwischen zwei Bändern → linear interpolieren */
            var t = (p - B.b) / (Nx.a - B.b);
            return {
              sx:    lerp(B.sx,    Nx.sx,    t),
              rad:   lerp(B.rad,   Nx.rad,   t),
              tyPct: lerp(B.tyPct, Nx.tyPct, t)
            };
          }
          if (p >= B.a && p <= B.b) return { sx: B.sx, rad: B.rad, tyPct: B.tyPct };
        }
        /* vor dem ersten / nach dem letzten Band → Eckwerte halten */
        if (p < BANDS[0].a) return { sx: BANDS[0].sx, rad: BANDS[0].rad, tyPct: BANDS[0].tyPct };
        var L = BANDS[BANDS.length - 1];
        return { sx: L.sx, rad: L.rad, tyPct: L.tyPct };
      }

      /* Position 0..1 → Spine-Choreografie (Anatomie-Tour).
         theta = sanftes Pendeln um die Y-Achse (±15°, kein Dauer-Spin).
         phi   = kleine Auf-/Ab-Neigung.
         rad   = Zoom pro Szene (Close-up vs. Übersicht).
         targetY = vertikaler Kamera-Schwenk (Halswirbel ↔ LWS).
         sx    = Side-Drift (vw), nur Desktop — Mobile bleibt mittig. */
      function render(p) {
        p = clamp(p, 0, 1);
        var mobile = cinema.classList.contains('is-mobilecine');
        var bv = bandValues(p);
        var targetY = bv.tyPct * modelH;

        /* Theta: sanftes Pendeln, max. ±15° — keine Dauerdrehung mehr,
           damit die längliche Säule nicht wie ein Wurm wirkt. */
        var theta = Math.sin(p * Math.PI * 2) * 15;
        var phi   = 85 + Math.sin(p * Math.PI * 2 + 1) * 3;
        orbit(spine, theta, phi, bv.rad, targetY);

        if (!mobile) {
          /* ── DESKTOP — Säule mittig, driftet sanft links/rechts. */
          if (spineBox) {
            spineBox.style.transform =
              'translate(calc(-50% + ' + bv.sx.toFixed(2) + 'vw), -50%)';
            spineBox.style.opacity = '1';
          }
          if (aura) {
            aura.style.transform =
              'translate(calc(-50% + ' + bv.sx.toFixed(2) + 'vw), -50%)';
            aura.style.opacity = '0.85';
          }

          /* ── SZENEN: feste Seite, Sichtbarkeit per Scroll-Band */
          for (var i = 0; i < N; i++) {
            var B = BANDS[i] || { a: 0, b: 1, fi: 0, fo: 0, side: 'left' };
            var op = bandOpacity(p, B);
            var tx = (1 - op) * (B.side === 'right' ? 34 : -34);
            scenes[i].style.opacity = op.toFixed(3);
            scenes[i].style.transform = 'translate(' + tx.toFixed(1) + 'px, -50%)';
          }
        } else {
          /* ── MOBIL — Säule mittig, Texte abwechselnd oben/unten.
             CTA-Finale: Säule fadet weg (.is-finale → cm-stage opacity 0
             via CSS), Text steht zentriert — sonst überlappt der lange
             CTA-Block die Säule oder wird unten abgeschnitten. */
          var finale = p >= 0.86;
          cinema.classList.toggle('is-finale', finale);
          if (spineBox) {
            spineBox.style.transform = 'translate(-50%, -50%)';
            spineBox.style.opacity = '1';
          }
          if (aura) {
            aura.style.transform = 'translate(-50%, -50%)';
            aura.style.opacity = '0.85';
          }

          for (var j = 0; j < N; j++) {
            var Bm = BANDS[j] || { a: 0, b: 1, fi: 0, fo: 0, side: 'left' };
            var opm = bandOpacity(p, Bm);
            var topZone = (Bm.side === 'right');
            var ty = (1 - opm) * (topZone ? -26 : 26);
            scenes[j].style.opacity = opm.toFixed(3);
            scenes[j].style.transform = 'translate(-50%, ' + ty.toFixed(1) + 'px)';
          }
        }

        if (bar)  bar.style.width = (p * 100).toFixed(1) + '%';
        if (hint) hint.style.opacity = clamp(1 - p * 8, 0, 1);
      }

      /* ── Modus: gepinnt-cinematisch  vs.  gestapelt-statisch ── */
      var reduceMM = window.matchMedia('(prefers-reduced-motion: reduce)');
      var smallMM  = window.matchMedia('(max-width: 880px)');
      var rafId = 0, staticOn = null;

      function scrollP() {
        var vh = window.innerHeight || document.documentElement.clientHeight;
        var span = track.offsetHeight - vh;
        return span > 0 ? clamp(-track.getBoundingClientRect().top / span, 0, 1) : 0;
      }
      function frame() {
        render(scrollP());
        rafId = requestAnimationFrame(frame);
      }
      function apply() {
        var stat = reduceMM.matches;
        if (stat !== staticOn) {
          staticOn = stat;
          if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
          cinema.classList.toggle('is-static', stat);
          if (stat) {
            if (spineBox) { spineBox.style.cssText = ''; }
            if (aura)     { aura.style.cssText = ''; }
            scenes.forEach(function (s) { s.style.opacity = ''; s.style.transform = ''; });
            orbit(spine, 0, 85, 135, 0);
            if (bar)  bar.style.width = '100%';
            if (hint) hint.style.opacity = 0;
          }
        }
        if (!stat) {
          cinema.classList.toggle('is-mobilecine', smallMM.matches);
          if (!rafId) rafId = requestAnimationFrame(frame);
        }
      }
      function onMM(mm, fn) {
        if (mm.addEventListener) mm.addEventListener('change', fn);
        else if (mm.addListener) mm.addListener(fn);
      }

      /* Nach Load: Modellhöhe + Center auslesen, damit die tyPct-Schwenks
         unabhängig von der gltf-Skalierung korrekt umgerechnet werden. */
      function readModelMetrics() {
        try {
          if (spine && spine.getDimensions) {
            var d = spine.getDimensions();
            if (d && typeof d.y === 'number' && d.y > 0) modelH = d.y;
          }
          if (spine && spine.getBoundingBoxCenter) {
            var c = spine.getBoundingBoxCenter();
            if (c) { modelCx = c.x || 0; modelCy = c.y || 0; modelCz = c.z || 0; }
          }
        } catch (e) { /* still — Defaults bleiben (modelH=1, center=0) */ }
      }

      function boot() { readModelMetrics(); apply(); }

      if (spine && window.customElements && window.customElements.whenDefined) {
        window.customElements.whenDefined('model-viewer').then(function () {
          if (spine.loaded) boot();
          else spine.addEventListener('load', boot, { once: true });
          setTimeout(function () { if (staticOn === null) boot(); }, 1500);
        });
      } else {
        boot();
      }
      onMM(reduceMM, apply);
      onMM(smallMM, apply);
      window.addEventListener('resize', apply, { passive: true });
    })();
  })();
</script>

<!-- [Scorecard] Controller — DOM-getrieben, dependency-frei, idempotent -->
<script>
  (function () {
    var card = document.querySelector('[data-sc]');
    if (!card) return;
    var steps = [].slice.call(card.querySelectorAll('.sc-step'));
    var order = steps.map(function (s) { return s.getAttribute('data-step'); });
    var qEls = [].slice.call(card.querySelectorAll('.sc-q'));
    var bar = card.querySelector('.sc-progress > i');
    var picks = {};
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function go(name) {
      steps.forEach(function (s) { s.hidden = (s.getAttribute('data-step') !== name); });
      var i = order.indexOf(name);
      if (bar) bar.style.width = Math.round((i / (order.length - 1)) * 100) + '%';
      try { card.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'center' }); }
      catch (e) { card.scrollIntoView(); }
    }
    function step(from, dir) {
      var i = order.indexOf(from);
      go(order[Math.max(0, Math.min(order.length - 1, i + dir))]);
    }

    card.querySelectorAll('.sc-start').forEach(function (b) {
      b.addEventListener('click', function () { go(order[1]); });
    });
    qEls.forEach(function (q) {
      var key = q.getAttribute('data-step');
      q.querySelectorAll('.sc-opt').forEach(function (opt) {
        opt.addEventListener('click', function () {
          q.querySelectorAll('.sc-opt').forEach(function (o) { o.classList.remove('is-sel'); });
          opt.classList.add('is-sel');
          picks[key] = parseFloat(opt.getAttribute('data-points')) || 0;
          step(key, 1);
        });
      });
    });
    card.querySelectorAll('[data-back]').forEach(function (b) {
      b.addEventListener('click', function () {
        step(b.closest('.sc-step').getAttribute('data-step'), -1);
      });
    });

    function valid() {
      var n = card.querySelector('[data-req="name"]');
      var m = card.querySelector('[data-req="email"]');
      return n && n.value.trim().length > 1 &&
             m && /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(m.value.trim());
    }
    card.querySelectorAll('.sc-reveal').forEach(function (b) {
      b.addEventListener('click', function () {
        var err = card.querySelector('[data-err]');
        if (!valid()) { if (err) err.hidden = false; return; }
        if (err) err.hidden = true;
        var max = 0, got = 0;
        qEls.forEach(function (q) {
          var pts = [].slice.call(q.querySelectorAll('.sc-opt')).map(function (o) {
            return parseFloat(o.getAttribute('data-points')) || 0;
          });
          max += Math.max.apply(null, pts.concat([0]));
          got += picks[q.getAttribute('data-step')] || 0;
        });
        var pct = max > 0 ? Math.round((got / max) * 100) : 0;
        var tiers = [].slice.call(card.querySelectorAll('.sc-tier')).sort(function (a, b2) {
          return (+a.getAttribute('data-min')) - (+b2.getAttribute('data-min'));
        });
        var tier = tiers[0];
        tiers.forEach(function (t) { if (pct >= (+t.getAttribute('data-min'))) tier = t; });
        var sEl = card.querySelector('[data-score]'); if (sEl) sEl.textContent = pct;
        var lEl = card.querySelector('[data-tierlabel]'); if (lEl && tier) lEl.textContent = tier.getAttribute('data-label');
        var mEl = card.querySelector('[data-tiermsg]'); if (mEl && tier) mEl.textContent = tier.textContent;
        go('result');
      });
    });
    card.querySelectorAll('[data-restart]').forEach(function (b) {
      b.addEventListener('click', function () {
        picks = {};
        card.querySelectorAll('.sc-opt.is-sel').forEach(function (o) { o.classList.remove('is-sel'); });
        card.querySelectorAll('.sc-in').forEach(function (i) { i.value = ''; });
        var err = card.querySelector('[data-err]'); if (err) err.hidden = true;
        go('intro');
      });
    });
  })();
</script>

<!-- [Sticky] Mobile CTA Bar — Anrufen + WhatsApp. Erscheint erst nach dem Hero. -->
<aside class="sticky-cta" data-sticky-cta aria-label="Schneller Kontakt">
  <a href={telHref} class="sticky-cta-btn sticky-cta-call">
    <span class="ico" set:html={I.phone} />
    <span>Anrufen</span>
  </a>
  <a href={waHref} class="sticky-cta-btn sticky-cta-wa" target="_blank" rel="noopener">
    <span class="ico" set:html={I.whatsapp} />
    <span>WhatsApp</span>
  </a>
</aside>

<script>
  (function () {
    var bar = document.querySelector('[data-sticky-cta]');
    var hero = document.querySelector('.cine');
    if (!bar || !hero) return;
    if (!('IntersectionObserver' in window)) {
      bar.setAttribute('data-visible', 'true');
      return;
    }
    var io = new IntersectionObserver(function (ents) {
      ents.forEach(function (en) {
        if (en.isIntersecting) bar.removeAttribute('data-visible');
        else bar.setAttribute('data-visible', 'true');
      });
    }, { threshold: 0, rootMargin: '-80px 0px 0px 0px' });
    io.observe(hero);
  })();
</script>

</body>
</html>
